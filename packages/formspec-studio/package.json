{
  "name": "@formspec-org/studio",
  "description": "Visual form designer UI for building and previewing Formspec documents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "BUSL-1.1",
  "main": "dist/formspec-studio.js",
  "types": "src/lib.ts",
  "exports": {
    ".": {
      "import": "./dist/formspec-studio.js",
      "types": "./src/lib.ts"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --config vite.config.lib.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config playwright.config.ts"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^1.7.10",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.1.0",
    "@floating-ui/react": "^0.27.19",
    "@formspec-org/chat": "*",
    "@formspec-org/engine": "*",
    "@formspec-org/layout": "*",
    "@formspec-org/mcp": "*",
    "@formspec-org/studio-core": "*",
    "@formspec-org/types": "*",
    "@formspec-org/webcomponent": "*",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/jszip": "^3.4.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "happy-dom": "^20.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.0"
  }
}
