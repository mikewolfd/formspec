{
  "name": "formspec-studio",
  "description": "Visual form designer UI for building and previewing Formspec documents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/formspec-studio.js",
  "types": "src/lib.ts",
  "exports": {
    ".": {
      "import": "./dist/formspec-studio.js",
      "types": "./src/lib.ts"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --config vite.config.lib.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config playwright.config.ts"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@dnd-kit/dom": "^0.3.2",
    "@dnd-kit/helpers": "^0.3.2",
    "@dnd-kit/react": "^0.3.2",
    "@faker-js/faker": "^10.3.0",
    "@floating-ui/react": "^0.27.19",
    "formspec-chat": "*",
    "formspec-engine": "*",
    "formspec-layout": "*",
    "formspec-mcp": "*",
    "formspec-studio-core": "*",
    "formspec-webcomponent": "*",
    "jszip": "^3.10.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/jszip": "^3.4.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "happy-dom": "^20.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
