{
    "$formspec": "1.0",
    "url": "urn:formspec:test:contact",
    "version": "1.0.0",
    "formId": "contact",
    "title": "Contact Form",
    "items": [
        {
            "key": "fullName",
            "type": "field",
            "dataType": "string",
            "label": "Full Name",
            "bind": { "required": "true()" }
        },
        {
            "key": "email",
            "type": "field",
            "dataType": "string",
            "label": "Email",
            "bind": { "required": "true()", "constraint": "regex($value, '^[^@]+@[^@]+$')" }
        },
        {
            "key": "subscribe",
            "type": "field",
            "dataType": "boolean",
            "label": "Subscribe to newsletter"
        }
    ]
}
