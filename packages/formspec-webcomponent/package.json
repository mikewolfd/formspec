{
  "name": "formspec-webcomponent",
  "description": "Web component renderer (<formspec-render>) with pluggable component registry",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./formspec-layout.css": "./dist/formspec-layout.css",
    "./formspec-default.css": "./dist/formspec-default.css"
  },
  "scripts": {
    "build": "tsc && cp src/formspec-layout.css src/formspec-default.css dist/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "formspec-engine": "*",
    "formspec-layout": "*"
  },
  "devDependencies": {
    "happy-dom": "^17.6.1",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  }
}
