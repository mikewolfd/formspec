{
  "name": "@formspec-org/webcomponent",
  "description": "Web component renderer (<formspec-render>) with pluggable component registry",
  "version": "1.0.0",
  "type": "module",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Formspec-org/formspec.git",
    "directory": "packages/formspec-webcomponent"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./default-theme": "./dist/default-theme.json",
    "./formspec-layout.css": "./dist/formspec-layout.css",
    "./formspec-default.css": "./dist/formspec-default.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc && sh ../../scripts/copy-layout-css-assets.sh ../formspec-layout/src dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@formspec-org/engine": "*",
    "@formspec-org/layout": "*"
  },
  "devDependencies": {
    "happy-dom": "^17.6.1",
    "typescript": "^5.0.0"
  }
}
