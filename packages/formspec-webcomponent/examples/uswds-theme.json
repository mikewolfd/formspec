{
  "$formspecTheme": "1.0",
  "version": "1.0.0",
  "name": "uswds-web",
  "title": "USWDS Web Theme",
  "description": "USWDS-aligned theme using stylesheet loading, theme cascade classes, and widget class slots.",
  "targetDefinition": {
    "url": "urn:formspec:any",
    "compatibleVersions": ">=1.0.0"
  },
  "platform": "web",
  "stylesheets": [
    "/assets/uswds/css/uswds.min.css",
    "/assets/formspec-uswds-bridge.css"
  ],
  "tokens": {
    "uswds.formGroup": "usa-form-group",
    "uswds.label": "usa-label",
    "uswds.input": "usa-input",
    "uswds.hint": "usa-hint",
    "uswds.error": "usa-error-message"
  },
  "defaults": {
    "labelPosition": "top",
    "cssClass": "usa-form-group",
    "widgetConfig": {
      "x-classes": {
        "root": "$token.uswds.formGroup",
        "label": "$token.uswds.label",
        "control": "$token.uswds.input",
        "hint": "$token.uswds.hint",
        "error": "$token.uswds.error"
      }
    }
  },
  "selectors": [
    {
      "match": { "type": "group" },
      "apply": { "cssClass": "usa-fieldset" }
    },
    {
      "match": { "dataType": "boolean" },
      "apply": {
        "widget": "Toggle",
        "labelPosition": "start",
        "widgetConfig": {
          "x-classes": {
            "control": "usa-checkbox__input",
            "label": "usa-checkbox__label"
          }
        }
      }
    },
    {
      "match": { "dataType": "choice" },
      "apply": {
        "widget": "Select",
        "fallback": ["RadioGroup"],
        "widgetConfig": {
          "x-classes": {
            "control": "usa-select"
          }
        }
      }
    },
    {
      "match": { "dataType": "multiChoice" },
      "apply": {
        "widget": "CheckboxGroup"
      }
    }
  ]
}
