{
  "compilerOptions": {
    "target": "es2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "formspec-engine/fel-runtime": ["../formspec-engine/src/fel/fel-api-runtime.ts"],
      "formspec-engine/fel-tools": ["../formspec-engine/src/fel/fel-api-tools.ts"]
    }
  },
  "include": ["src/**/*"]
}
