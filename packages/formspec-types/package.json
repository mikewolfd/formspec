{
  "name": "formspec-types",
  "description": "TypeScript type definitions generated from Formspec JSON schemas",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "types:generate": "node scripts/generate-types.mjs",
    "build": "npm run types:generate && tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "json-schema-faker": "^0.6.0",
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  }
}
