{
  "$formspecTheme": "1.0",
  "version": "1.0.0",
  "name": "formspec-default",
  "title": "Formspec Default Theme",
  "description": "Shared default theme and token set for the canonical Formspec baseline styles.",
  "targetDefinition": {
    "url": "urn:formspec:any",
    "compatibleVersions": ">=1.0.0"
  },
  "tokens": {
    "color.primary": "#1f6a5b",
    "color.primaryForeground": "#ffffff",
    "color.foreground": "#1f2521",
    "color.border": "#c9c1b4",
    "color.card": "#fffdfa",
    "color.muted": "#6f6a61",
    "color.mutedForeground": "#7b756b",
    "color.error": "#d93025",
    "color.warning": "#b7791f",
    "color.ring": "#1f6a5b",
    "color.input": "#b7aea1",
    "color.surface": "#f4efe7",
    "spacing.xs": "0.25rem",
    "spacing.sm": "0.5rem",
    "spacing.md": "1rem",
    "spacing.lg": "1.5rem",
    "spacing.xl": "2rem",
    "spacing.field": "0.75rem",
    "radius.sm": "0.875rem",
    "radius.md": "1.25rem",
    "font.family": "\"Instrument Sans\", \"Avenir Next\", \"Segoe UI\", sans-serif"
  },
  "defaults": {
    "labelPosition": "top",
    "accessibility": {
      "liveRegion": "off"
    }
  },
  "selectors": [
    {
      "match": { "type": "group" },
      "apply": {
        "cssClass": "formspec-themed-group",
        "accessibility": {
          "role": "group"
        }
      }
    },
    {
      "match": { "type": "display" },
      "apply": {
        "cssClass": "formspec-themed-display"
      }
    },
    {
      "match": { "type": "field" },
      "apply": {
        "cssClass": "formspec-themed-field"
      }
    },
    {
      "match": { "dataType": "boolean" },
      "apply": {
        "labelPosition": "start"
      }
    }
  ]
}
