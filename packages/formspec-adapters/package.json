{
  "name": "@formspec/adapters",
  "description": "Render adapter library — design-system-specific DOM implementations for formspec-webcomponent",
  "version": "0.1.0",
  "type": "module",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Formspec-org/formspec.git",
    "directory": "packages/formspec-adapters"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tailwind-formspec-core.css": "./dist/tailwind-formspec-core.css"
  },
  "files": ["dist"],
  "scripts": {
    "build:css": "node scripts/build-css.mjs",
    "build:integration-css": "node scripts/generate-integration-css.mjs",
    "prebuild": "npm run build:css && npm run build:integration-css",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@formspec/webcomponent": "*"
  },
  "devDependencies": {
    "@uswds/uswds": "^3.11.0",
    "@formspec/webcomponent": "*",
    "happy-dom": "^17.6.1",
    "sass": "^1.86.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  }
}
