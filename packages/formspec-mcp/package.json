{
  "name": "@formspec-org/mcp",
  "description": "Model Context Protocol server for AI-driven Formspec form authoring",
  "version": "0.2.0",
  "type": "module",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Formspec-org/formspec.git",
    "directory": "packages/formspec-mcp"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/create-server.d.ts",
      "default": "./dist/create-server.js"
    },
    "./registry": {
      "types": "./dist/registry.d.ts",
      "default": "./dist/registry.js"
    },
    "./dispatch": {
      "types": "./dist/dispatch.d.ts",
      "default": "./dist/dispatch.js"
    }
  },
  "files": ["dist"],
  "bin": {
    "formspec-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "mcpb:bundle": "npx esbuild dist/index.js --bundle --platform=node --format=cjs --outfile=bundle/index.cjs",
    "mcpb:prepare": "mkdir -p lib/schemas && cp -r ../../schemas/*.json lib/schemas/ && npm run mcpb:bundle",
    "mcpb:pack": "npm run build && npm run mcpb:prepare && npx -y @anthropic-ai/mcpb pack ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "@formspec-org/engine": "*",
    "@formspec-org/studio-core": "*",
    "uuid": "^11.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "typescript": "^5.0.0"
  }
}
