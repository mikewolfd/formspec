{
  "manifest_version": "0.3",
  "name": "@formspec/mcp",
  "display_name": "Formspec Authoring Assistant",
  "version": "0.2.0",
  "description": "28 consolidated tools for AI-driven Formspec form authoring. Build complex forms through structured tool calls.",
  "author": {
    "name": "Formspec Project",
    "url": "https://formspec.dev"
  },
  "server": {
    "type": "node",
    "entry_point": "bundle/index.cjs",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/bundle/index.cjs"]
    }
  }
}
