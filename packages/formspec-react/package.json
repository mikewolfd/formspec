{
  "name": "@formspec-org/react",
  "description": "React hooks and auto-renderer for Formspec — use any component library with FormEngine",
  "version": "0.1.0",
  "type": "module",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Formspec-org/formspec.git",
    "directory": "packages/formspec-react"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "default": "./dist/hooks.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@preact/signals-core": "^1.8.0",
    "@formspec-org/engine": "*",
    "@formspec-org/layout": "*",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@formspec-org/engine": "*",
    "@formspec-org/layout": "*",
    "happy-dom": "^17.6.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.0.0"
  }
}
