{
  "name": "formspec-engine",
  "description": "Client-side form state engine with FEL expression language, reactive signals, and validation",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build:wasm:runtime": "wasm-pack build ../../crates/formspec-wasm --target web --out-dir ../../packages/formspec-engine/wasm-pkg-runtime --out-name formspec_wasm_runtime --no-opt && wasm-opt -Os --enable-bulk-memory --enable-nontrapping-float-to-int --enable-simd wasm-pkg-runtime/formspec_wasm_runtime_bg.wasm -o wasm-pkg-runtime/formspec_wasm_runtime_bg.wasm",
    "build:wasm:tools": "wasm-pack build ../../crates/formspec-wasm --target web --out-dir ../../packages/formspec-engine/wasm-pkg-tools --out-name formspec_wasm_tools --no-opt && wasm-opt -Os --enable-bulk-memory --enable-nontrapping-float-to-int --enable-simd wasm-pkg-tools/formspec_wasm_tools_bg.wasm -o wasm-pkg-tools/formspec_wasm_tools_bg.wasm",
    "build:wasm": "npm run build:wasm:runtime && npm run build:wasm:tools",
    "build": "npm run build:wasm && tsc",
    "test:unit": "node --experimental-specifier-resolution=node --import ./tests/setup.mjs --test \"tests/**/*.test.mjs\"",
    "test:wasm-runtime-isolation": "node --experimental-specifier-resolution=node --test tests/isolation/wasm-runtime-isolation.mjs",
    "test": "npm run build && npm run test:unit && npm run test:wasm-runtime-isolation"
  },
  "dependencies": {
    "@preact/signals-core": "^1.6.0",
    "formspec-types": "*"
  },
  "devDependencies": {
    "fast-check": "^4.6.0",
    "typescript": "^5.0.0"
  }
}
