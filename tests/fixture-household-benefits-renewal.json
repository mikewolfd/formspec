{
  "$formspec": "1.0",
  "url": "https://example.org/tests/fixtures/household-benefits-renewal",
  "version": "2026.03.05",
  "versionAlgorithm": "date",
  "status": "draft",
  "title": "Household Benefits Renewal Fixture",
  "description": "Fixture exercising nested repeats, migration metadata, scoped variables, pre-population, and household-level shapes.",
  "date": "2026-03-05",
  "name": "household-benefits-renewal",
  "derivedFrom": "https://example.org/forms/benefits-renewal",
  "nonRelevantBehavior": "keep",
  "formPresentation": {
    "pageMode": "tabs",
    "labelPosition": "top",
    "density": "comfortable"
  },
  "instances": {
    "priorRenewal": {
      "description": "Prior-year renewal response snapshot",
      "readonly": true,
      "data": {
        "street": "100 Main Street",
        "city": "Springfield",
        "state": "MD",
        "postalCode": "20001",
        "email": "household@example.org"
      },
      "schema": {
        "street": "string",
        "city": "string",
        "state": "string",
        "postalCode": "string",
        "email": "string"
      }
    }
  },
  "migrations": {
    "from": {
      "2025.06.01": {
        "description": "Renamed monthly expense note and removed obsolete employer fax.",
        "fieldMap": [
          {
            "source": "household.address.street",
            "target": "household.renewalStreet",
            "transform": "preserve"
          },
          {
            "source": "contacts.employerFax",
            "target": null,
            "transform": "drop"
          },
          {
            "source": "expenses.notes",
            "target": "household.householdExpenseNote",
            "transform": "expression",
            "expression": "string($)"
          }
        ],
        "defaults": {
          "renewalContact.renewalPhone": "",
          "household.householdExpenseNote": ""
        }
      }
    }
  },
  "optionSets": {
    "memberRoles": {
      "options": [
        { "value": "adult", "label": "Adult" },
        { "value": "child", "label": "Child" },
        { "value": "caregiver", "label": "Caregiver" }
      ]
    },
    "expenseTypes": {
      "options": [
        { "value": "rent", "label": "Rent or mortgage" },
        { "value": "utilities", "label": "Utilities" },
        { "value": "childcare", "label": "Child care" },
        { "value": "medical", "label": "Medical expense" }
      ]
    }
  },
  "variables": [
    {
      "name": "householdMemberCount",
      "expression": "count($household.householdMembers[*].memberFullName)"
    },
    {
      "name": "dependentCount",
      "expression": "countWhere($household.householdMembers[*].memberRole, $ = 'child')"
    },
    {
      "name": "householdTotalIncome",
      "expression": "sum($household.householdMembers[*].memberMonthlyIncome)"
    },
    {
      "name": "monthlyExpenseTotal",
      "expression": "sum($household.householdExpenses[*].expenseMonthlyAmount)"
    }
  ],
  "items": [
    {
      "type": "group",
      "key": "household",
      "label": "Household",
      "presentation": {
        "layout": {
          "page": "Household"
        }
      },
      "children": [
        {
          "type": "field",
          "key": "renewalStreet",
          "label": "Street address",
          "dataType": "string",
          "prePopulate": {
            "instance": "priorRenewal",
            "path": "street",
            "editable": true
          }
        },
        {
          "type": "field",
          "key": "renewalCity",
          "label": "City",
          "dataType": "string",
          "initialValue": "=string(@instance('priorRenewal').city)"
        },
        {
          "type": "field",
          "key": "renewalState",
          "label": "State",
          "dataType": "string",
          "initialValue": "=string(@instance('priorRenewal').state)"
        },
        {
          "type": "field",
          "key": "renewalPostalCode",
          "label": "Postal code",
          "dataType": "string",
          "initialValue": "=string(@instance('priorRenewal').postalCode)"
        },
        {
          "type": "group",
          "key": "householdMembers",
          "label": "Household members",
          "repeatable": true,
          "minRepeat": 1,
          "children": [
            {
              "type": "field",
              "key": "memberFullName",
              "label": "Full name",
              "dataType": "string"
            },
            {
              "type": "field",
              "key": "memberRole",
              "label": "Role",
              "dataType": "choice",
              "optionSet": "memberRoles"
            },
            {
              "type": "field",
              "key": "memberAge",
              "label": "Age",
              "dataType": "integer"
            },
            {
              "type": "field",
              "key": "memberIsStudent",
              "label": "Student",
              "dataType": "boolean"
            },
            {
              "type": "field",
              "key": "memberMonthlyIncome",
              "label": "Monthly income",
              "dataType": "decimal",
              "precision": 2,
              "prefix": "$"
            },
            {
              "type": "field",
              "key": "memberNoSsn",
              "label": "No SSN available",
              "dataType": "boolean",
              "children": [
                {
                  "type": "field",
                  "key": "memberNoSsnReason",
                  "label": "Reason no SSN is available",
                  "dataType": "string"
                }
              ]
            },
            {
              "type": "field",
              "key": "memberNeedsCare",
              "label": "Needs dependent care",
              "dataType": "boolean"
            },
            {
              "type": "field",
              "key": "memberCareExplanation",
              "label": "Care explanation",
              "dataType": "text"
            }
          ]
        },
        {
          "type": "group",
          "key": "householdExpenses",
          "label": "Household expenses",
          "repeatable": true,
          "minRepeat": 1,
          "children": [
            {
              "type": "field",
              "key": "expenseType",
              "label": "Expense type",
              "dataType": "choice",
              "optionSet": "expenseTypes"
            },
            {
              "type": "field",
              "key": "expenseMonthlyAmount",
              "label": "Monthly amount",
              "dataType": "decimal",
              "precision": 2,
              "prefix": "$"
            }
          ]
        },
        {
          "type": "field",
          "key": "householdExpenseNote",
          "label": "Household expense note",
          "dataType": "text"
        }
      ]
    },
    {
      "type": "group",
      "key": "renewalContact",
      "label": "Renewal contact",
      "presentation": {
        "layout": {
          "page": "Contact"
        }
      },
      "children": [
        {
          "type": "field",
          "key": "renewalEmail",
          "label": "Email",
          "dataType": "string",
          "prePopulate": {
            "instance": "priorRenewal",
            "path": "email",
            "editable": true
          }
        },
        {
          "type": "field",
          "key": "renewalPhone",
          "label": "Phone",
          "dataType": "string"
        }
      ]
    }
  ],
  "binds": [
    {
      "path": "household.renewalPostalCode",
      "whitespace": "remove",
      "constraint": "matches($, '^[0-9]{5}$')",
      "constraintMessage": "Postal code must be 5 digits."
    },
    {
      "path": "household.householdMembers[*].memberIsStudent",
      "relevant": "$memberRole = 'child'"
    },
    {
      "path": "household.householdMembers[*].memberMonthlyIncome",
      "readonly": "$memberRole = 'child' and $memberAge < 16",
      "constraint": "$ >= 0",
      "constraintMessage": "Income must be zero or greater."
    },
    {
      "path": "household.householdMembers[*].memberNoSsnReason",
      "relevant": "$memberNoSsn = true",
      "required": "$memberNoSsn = true",
      "default": ""
    },
    {
      "path": "household.householdMembers[*].memberCareExplanation",
      "relevant": "$memberNeedsCare = true",
      "required": "$memberNeedsCare = true",
      "excludedValue": "null"
    },
    {
      "path": "household.householdExpenses[*].expenseMonthlyAmount",
      "constraint": "$ >= 0",
      "constraintMessage": "Expense amounts must be zero or greater."
    },
    {
      "path": "renewalContact.renewalEmail",
      "whitespace": "trim",
      "constraint": "empty($) or matches($, '^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')",
      "constraintMessage": "Enter a valid email address."
    },
    {
      "path": "renewalContact.renewalPhone",
      "whitespace": "remove",
      "constraint": "empty($) or matches($, '^[0-9]{10}$')",
      "constraintMessage": "Enter a 10-digit phone number."
    }
  ],
  "shapes": [
    {
      "id": "renewal-contact-channel",
      "target": "#",
      "severity": "error",
      "or": [
        "present($renewalContact.renewalEmail)",
        "present($renewalContact.renewalPhone)"
      ],
      "message": "Provide an email address or phone number."
    },
    {
      "id": "renewal-at-least-one-adult",
      "target": "#",
      "severity": "error",
      "constraint": "countWhere($household.householdMembers[*].memberRole, $ = 'adult') >= 1",
      "message": "The household must include at least one adult member."
    },
    {
      "id": "renewal-child-age-rule",
      "target": "household.householdMembers[*].memberAge",
      "severity": "error",
      "activeWhen": "$memberRole = 'child'",
      "constraint": "$ < 19 or ($ < 22 and $memberIsStudent = true)",
      "message": "Children must be under 19, or under 22 if marked as a student.",
      "code": "CHILD_AGE_RULE"
    },
    {
      "id": "renewal-budget-warning",
      "target": "#",
      "severity": "warning",
      "constraint": "@householdTotalIncome >= @monthlyExpenseTotal",
      "message": "Monthly expenses exceed reported monthly income.",
      "context": {
        "income": "@householdTotalIncome",
        "expenses": "@monthlyExpenseTotal"
      }
    }
  ]
}
