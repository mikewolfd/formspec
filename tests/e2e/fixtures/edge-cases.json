{
  "$formspec": "1.0",
  "items": [
    {
      "type": "group",
      "key": "parent",
      "visible": "showParent == true",
      "children": [
        { "type": "field", "dataType": "string", "key": "child", "label": "Child Field" }
      ]
    },
    { "type": "field", "dataType": "boolean", "key": "showParent", "label": "Show Parent" },
    { "type": "field", "dataType": "number", "key": "price", "label": "Price" },
    { "type": "field", "dataType": "number", "key": "quantity", "label": "Quantity" },
    { "type": "field", "dataType": "number", "key": "total", "calculate": "price * quantity" },
    { "type": "field", "dataType": "string", "key": "requiredIfVisible", "label": "Required if visible", "valid": "present(requiredIfVisible) || !relevant(requiredIfVisible)" }
  ]
}
