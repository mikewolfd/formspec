{
  "$formspec": "1.0",
  "items": [
    {
      "type": "group",
      "key": "invoice",
      "label": "Project Invoice",
      "children": [
        {
          "type": "field",
          "dataType": "string",
          "key": "clientName",
          "label": "Client Name"
        },
        {
          "type": "group",
          "key": "phases",
          "label": "Project Phases",
          "repeatable": true,
          "children": [
            {
              "type": "field",
              "dataType": "string",
              "key": "phaseName",
              "label": "Phase Name"
            },
            {
              "type": "group",
              "key": "tasks",
              "label": "Tasks in Phase",
              "repeatable": true,
              "children": [
                {
                  "type": "field",
                  "dataType": "string",
                  "key": "taskDescription",
                  "label": "Description"
                },
                {
                  "type": "field",
                  "dataType": "number",
                  "key": "hours",
                  "label": "Hours"
                },
                {
                  "type": "field",
                  "dataType": "number",
                  "key": "rate",
                  "label": "Hourly Rate"
                },
                {
                  "type": "field",
                  "dataType": "number",
                  "key": "taskTotal",
                  "label": "Task Cost",
                  "calculate": "hours * rate"
                }
              ]
            },
            {
              "type": "field",
              "dataType": "number",
              "key": "phaseSubtotal",
              "label": "Phase Subtotal",
              "calculate": "sum(tasks.taskTotal)"
            }
          ]
        },
        {
          "type": "field",
          "dataType": "number",
          "key": "invoiceTotal",
          "label": "Total Invoice Amount",
          "calculate": "sum(phases.phaseSubtotal)"
        },
        {
          "type": "field",
          "dataType": "number",
          "key": "taxRate",
          "label": "Tax Rate (%)",
          "calculate": "if(invoiceTotal > 1000, 15, 10)"
        },
        {
          "type": "field",
          "dataType": "number",
          "key": "finalAmount",
          "label": "Final Amount (with Tax)",
          "calculate": "round(invoiceTotal * (1 + taxRate / 100), 2)"
        }
      ]
    },
    {
      "type": "group",
      "key": "itinerary",
      "label": "Travel Itinerary",
      "repeatable": true,
      "children": [
        {
          "type": "field",
          "dataType": "string",
          "key": "destination",
          "label": "Destination"
        },
        {
          "type": "field",
          "dataType": "date",
          "key": "arrival",
          "label": "Arrival Date"
        },
        {
          "type": "field",
          "dataType": "date",
          "key": "departure",
          "label": "Departure Date",
          "valid": "departure >= arrival"
        },
        {
          "type": "field",
          "dataType": "number",
          "key": "stayDuration",
          "label": "Days in City",
          "calculate": "dateDiff(departure, arrival, 'days')"
        },
        {
          "type": "field",
          "dataType": "string",
          "key": "travelConflict",
          "label": "Sequence Status",
          "calculate": "if(isNull(prev('departure')), 'First Stop', if(arrival < prev('departure'), 'CONFLICT', 'OK'))",
          "visible": "present(arrival)"
        }
      ]
    }
  ]
}
