{
  "$formspec": "1.0",
  "items": [
    {
      "type": "group",
      "key": "lineItems",
      "label": "Line Items",
      "repeatable": true,
      "children": [
        {
          "type": "field", "dataType": "number",
          "key": "price",
          "label": "Price"
        },
        {
          "type": "field", "dataType": "number",
          "key": "quantity",
          "label": "Quantity"
        },
        {
          "type": "field", "dataType": "number",
          "key": "subtotal",
          "label": "Subtotal",
          "calculate": "lineItems[$index].price * lineItems[$index].quantity"
        }
      ]
    }
  ]
}
