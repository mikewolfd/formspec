{
  "$formspec": "1.0",
  "url": "http://example.org/fixtures/repeating-sections",
  "version": "1.0.0",
  "status": "active",
  "title": "Repeating Sections Test",
  "items": [
    {
      "type": "group",
      "key": "lineItems",
      "label": "Line Items",
      "repeatable": true,
      "minRepeat": 1,
      "children": [
        {
          "type": "field", "dataType": "decimal",
          "key": "price",
          "label": "Price"
        },
        {
          "type": "field", "dataType": "decimal",
          "key": "quantity",
          "label": "Quantity"
        },
        {
          "type": "field", "dataType": "decimal",
          "key": "subtotal",
          "label": "Subtotal"
        }
      ]
    }
  ],
  "binds": [
    {
      "target": "lineItems.subtotal",
      "calculate": "price * quantity"
    }
  ]
}
