  "binds": [
    { "target": "prices.prevVal", "calculate": "prev('val')" },
    { "target": "prices.nextVal", "calculate": "next('val')" },
    { "target": "totalSum", "calculate": "sum(prices.val)" },
    { "target": "upperText", "calculate": "upper(rawText)" },
    { "target": "roundedNum", "calculate": "round(rawNum, 2)" },
    { "target": "dateYear", "calculate": "year(testDate)" },
    { "target": "coalesced", "calculate": "coalesce(opt1, opt2, 'Default')" },
    { "target": "isOpt1Null", "calculate": "isNull(opt1)" },
    { "target": "textContains", "calculate": "contains('hello world', 'world')", "readonly": true },
    { "target": "mathPower", "calculate": "power(2, 3)", "readonly": true },
    { "target": "mathAbs", "calculate": "abs(-42)", "readonly": true },
    { "target": "typeEmpty", "calculate": "empty('')", "readonly": true },
    { "target": "dateAddStr", "calculate": "dateAdd('2025-01-01', 5, 'days')", "readonly": true },
    { "target": "dateDiffVal", "calculate": "dateDiff('2025-01-10', '2025-01-01', 'days')", "readonly": true },
    { "target": "ifExpr", "calculate": "if(1 > 0, 'yes', 'no')", "readonly": true },
    { "target": "valCount", "calculate": "count(prices.val)" },
    { "target": "valAvg", "calculate": "avg(prices.val)" },
    { "target": "valMin", "calculate": "min(prices.val)" },
    { "target": "valMax", "calculate": "max(prices.val)" },
    { "target": "strLength", "calculate": "length(rawText)" },
    { "target": "strStartsWith", "calculate": "startsWith(rawText, 'hello')" },
    { "target": "strEndsWith", "calculate": "endsWith(rawText, 'world')" },
    { "target": "strSubstring", "calculate": "substring(rawText, 0, 5)" },
    { "target": "strReplace", "calculate": "replace(rawText, 'world', 'there')" },
    { "target": "strLower", "calculate": "lower('HELLO')" },
    { "target": "strTrim", "calculate": "trim('  trimmed  ')" },
    { "target": "strMatches", "calculate": "matches(rawText, '^hello')" },
    { "target": "strFormat", "calculate": "format('Value: %s', rawNum)" },
    { "target": "numFloor", "calculate": "floor(12.9)" },
    { "target": "numCeil", "calculate": "ceil(12.1)" },
    { "target": "dtToday", "calculate": "today()" },
    { "target": "dtNow", "calculate": "now()" },
    { "target": "dtMonth", "calculate": "month('2025-05-20')" },
    { "target": "dtDay", "calculate": "day('2025-05-20')" },
    { "target": "dtHours", "calculate": "hours('2025-05-20T15:30:00')" },
    { "target": "dtMinutes", "calculate": "minutes('2025-05-20T15:30:00')" },
    { "target": "dtSeconds", "calculate": "seconds('2025-05-20T15:30:45')" },
    { "target": "dtTime", "calculate": "time('2025-05-20T15:30:45')" },
    { "target": "dtTimeDiff", "calculate": "timeDiff('15:30:00', '14:30:00', 'minutes')" },
    { "target": "valSelected", "calculate": "selected('a', 'a')" },
    { "target": "valIsNumber", "calculate": "isNumber(rawNum)" },
    { "target": "valIsString", "calculate": "isString(rawText)" },
    { "target": "valIsDate", "calculate": "isDate(testDate)" },
    { "target": "valTypeOf", "calculate": "typeOf(rawNum)" },
    { "target": "valToNumber", "calculate": "number('123.45')" },
    { "target": "mAmount", "calculate": "moneyAmount(money(100, 'USD'))" },
    { "target": "mCurrency", "calculate": "moneyCurrency(money(100, 'USD'))" },
    { "target": "mAdd", "calculate": "moneyAmount(moneyAdd(money(100, 'USD'), money(50, 'USD')))" },
    { "target": "ledger.entryMoney", "calculate": "money(amount, 'USD')" },
    { "target": "totalLedger", "calculate": "moneyAmount(moneySum(ledger.entryMoney))" },
    { "target": "parentGroup.parentVal", "calculate": "parent('rawText')" }
