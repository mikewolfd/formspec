{
  "$formspec": "1.0",
  "items": [
    {
      "type": "group",
      "key": "prices",
      "repeatable": true,
      "children": [
        {
          "type": "field", "dataType": "number",
          "key": "val",
          "label": "Value"
        },
        {
          "type": "field", "dataType": "number",
          "key": "prevVal",
          "calculate": "prev('val')"
        },
        {
          "type": "field", "dataType": "number",
          "key": "nextVal",
          "calculate": "next('val')"
        }
      ]
    },
    {
      "type": "field", "dataType": "number",
      "key": "totalSum",
      "calculate": "sum(prices.val)"
    },
    {
      "type": "field", "dataType": "string",
      "key": "rawText",
      "label": "Text"
    },
    {
      "type": "field", "dataType": "string",
      "key": "upperText",
      "calculate": "upper(rawText)"
    },
    {
      "type": "field", "dataType": "number",
      "key": "rawNum",
      "label": "Number"
    },
    {
      "type": "field", "dataType": "number",
      "key": "roundedNum",
      "calculate": "round(rawNum, 2)"
    },
    {
      "type": "field", "dataType": "date",
      "key": "testDate",
      "label": "Date"
    },
    {
      "type": "field", "dataType": "number",
      "key": "dateYear",
      "calculate": "year(testDate)"
    },
    {
      "type": "field", "dataType": "string",
      "key": "opt1",
      "label": "Option 1"
    },
    {
      "type": "field", "dataType": "string",
      "key": "opt2",
      "label": "Option 2"
    },
    {
      "type": "field", "dataType": "string",
      "key": "coalesced",
      "calculate": "coalesce(opt1, opt2, 'Default')"
    },
    {
      "type": "field", "dataType": "boolean",
      "key": "isOpt1Null",
      "calculate": "isNull(opt1)"
    },
    {
      "type": "field", "dataType": "string",
      "key": "textContains",
      "calculate": "contains('hello world', 'world')",
      "readonly": true
    },
    {
      "type": "field", "dataType": "number",
      "key": "mathPower",
      "calculate": "power(2, 3)",
      "readonly": true
    },
    {
      "type": "field", "dataType": "number",
      "key": "mathAbs",
      "calculate": "abs(-42)",
      "readonly": true
    },
    {
      "type": "field", "dataType": "boolean",
      "key": "typeEmpty",
      "calculate": "empty('')",
      "readonly": true
    },
    {
      "type": "field", "dataType": "string",
      "key": "dateAddStr",
      "calculate": "dateAdd('2025-01-01', 5, 'days')",
      "readonly": true
    },
    {
      "type": "field", "dataType": "number",
      "key": "dateDiffVal",
      "calculate": "dateDiff('2025-01-10', '2025-01-01', 'days')",
      "readonly": true
    },
    {
      "type": "field", "dataType": "string",
      "key": "ifExpr",
      "calculate": "if(1 > 0, 'yes', 'no')",
      "readonly": true
    },
    {
      "type": "field", "dataType": "number",
      "key": "valCount",
      "calculate": "count(prices.val)"
    },
    {
      "type": "field", "dataType": "number",
      "key": "valAvg",
      "calculate": "avg(prices.val)"
    },
    {
      "type": "field", "dataType": "number",
      "key": "valMin",
      "calculate": "min(prices.val)"
    },
    {
      "type": "field", "dataType": "number",
      "key": "valMax",
      "calculate": "max(prices.val)"
    },
    {
      "type": "field", "dataType": "number",
      "key": "valCountWhere",
      "calculate": "countWhere(prices.val, $ > 10)"
    },
    {
      "type": "field", "dataType": "number",
      "key": "strLength",
      "calculate": "length(rawText)"
    },
    {
      "type": "field", "dataType": "boolean",
      "key": "strStartsWith",
      "calculate": "startsWith(rawText, 'hello')"
    },
    {
      "type": "field", "dataType": "boolean",
      "key": "strEndsWith",
      "calculate": "endsWith(rawText, 'world')"
    },
    {
      "type": "field", "dataType": "string",
      "key": "strSubstring",
      "calculate": "substring(rawText, 0, 5)"
    },
    {
      "type": "field", "dataType": "string",
      "key": "strReplace",
      "calculate": "replace(rawText, 'world', 'there')"
    },
    {
      "type": "field", "dataType": "string",
      "key": "strLower",
      "calculate": "lower('HELLO')"
    },
    {
      "type": "field", "dataType": "string",
      "key": "strTrim",
      "calculate": "trim('  trimmed  ')"
    },
    {
      "type": "field", "dataType": "boolean",
      "key": "strMatches",
      "calculate": "matches(rawText, '^hello')"
    },
    {
      "type": "field", "dataType": "string",
      "key": "strFormat",
      "calculate": "format('Value: %s', rawNum)"
    },
    {
      "type": "field", "dataType": "number",
      "key": "numFloor",
      "calculate": "floor(12.9)"
    },
    {
      "type": "field", "dataType": "number",
      "key": "numCeil",
      "calculate": "ceil(12.1)"
    },
    {
      "type": "field", "dataType": "string",
      "key": "dtToday",
      "calculate": "today()"
    },
    {
      "type": "field", "dataType": "string",
      "key": "dtNow",
      "calculate": "now()"
    },
    {
      "type": "field", "dataType": "number",
      "key": "dtMonth",
      "calculate": "month('2025-05-20')"
    },
    {
      "type": "field", "dataType": "number",
      "key": "dtDay",
      "calculate": "day('2025-05-20')"
    },
    {
      "type": "field", "dataType": "number",
      "key": "dtHours",
      "calculate": "hours('2025-05-20T15:30:00')"
    },
    {
      "type": "field", "dataType": "number",
      "key": "dtMinutes",
      "calculate": "minutes('2025-05-20T15:30:00')"
    },
    {
      "type": "field", "dataType": "number",
      "key": "dtSeconds",
      "calculate": "seconds('2025-05-20T15:30:45')"
    },
    {
      "type": "field", "dataType": "string",
      "key": "dtTime",
      "calculate": "time('2025-05-20T15:30:45')"
    },
    {
      "type": "field", "dataType": "number",
      "key": "dtTimeDiff",
      "calculate": "timeDiff('15:30:00', '14:30:00', 'minutes')"
    },
    {
      "type": "field", "dataType": "boolean",
      "key": "valSelected",
      "calculate": "selected('a', 'a')"
    },
    {
      "type": "field", "dataType": "boolean",
      "key": "valIsNumber",
      "calculate": "isNumber(rawNum)"
    },
    {
      "type": "field", "dataType": "boolean",
      "key": "valIsString",
      "calculate": "isString(rawText)"
    },
    {
      "type": "field", "dataType": "boolean",
      "key": "valIsDate",
      "calculate": "isDate(testDate)"
    },
    {
      "type": "field", "dataType": "string",
      "key": "valTypeOf",
      "calculate": "typeOf(rawNum)"
    },
    {
      "type": "field", "dataType": "number",
      "key": "valToNumber",
      "calculate": "number('123.45')"
    },
    {
      "type": "field", "dataType": "number",
      "key": "mAmount",
      "calculate": "moneyAmount(money(100, 'USD'))"
    },
    {
      "type": "field", "dataType": "string",
      "key": "mCurrency",
      "calculate": "moneyCurrency(money(100, 'USD'))"
    },
    {
      "type": "field", "dataType": "number",
      "key": "mAdd",
      "calculate": "moneyAmount(moneyAdd(money(100, 'USD'), money(50, 'USD')))"
    },
    {
      "type": "group",
      "key": "ledger",
      "repeatable": true,
      "children": [
        {
          "type": "field", "dataType": "number",
          "key": "amount",
          "label": "Amount"
        },
        {
          "type": "field", "dataType": "string",
          "key": "entryMoney",
          "calculate": "money(amount, 'USD')"
        }
      ]
    },
    {
      "type": "field", "dataType": "number",
      "key": "totalLedger",
      "calculate": "moneyAmount(moneySum(ledger.entryMoney))"
    },
    {
      "type": "group",
      "key": "parentGroup",
      "children": [
        {
          "type": "field", "dataType": "string",
          "key": "parentVal",
          "calculate": "parent('rawText')"
        }
      ]
    }
  ]
}