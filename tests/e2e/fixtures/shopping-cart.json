{
  "$formspec": "1.0",
  "url": "http://example.org/forms/shopping-cart",
  "version": "1.0.0",
  "status": "draft",
  "title": "Shopping Cart",
  "items": [
    {
      "type": "field",
      "dataType": "decimal",
      "key": "price",
      "label": "Price"
    },
    {
      "type": "field",
      "dataType": "decimal",
      "key": "quantity",
      "label": "Quantity"
    },
    {
      "type": "field",
      "dataType": "decimal",
      "key": "total",
      "label": "Total"
    },
    {
      "type": "field",
      "dataType": "string",
      "key": "discountCode",
      "label": "Discount Code"
    }
  ],
  "binds": [
    {
      "target": "total",
      "calculate": "price * quantity",
      "readonly": true
    },
    {
      "target": "discountCode",
      "relevant": "total > 50"
    }
  ]
}
