{
  "name": "formspec-workspace",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/grant-application"
  ],
  "scripts": {
    "test:serve": "vite --port 8080 --host 127.0.0.1",
    "start:grant-app": "npm run build --workspace=formspec-engine && npm run build --workspace=formspec-webcomponent && npm run dev --workspace=grant-application-example",
    "test": "npm run test:e2e",
    "test:e2e": "playwright test",
    "test:kitchen-sink:python": "PYTHONPATH=src python3 tests/e2e/kitchen_sink/conformance_runner.py --output /tmp/formspec-kitchen-sink-python-report.json",
    "test:kitchen-sink:playwright": "playwright test tests/e2e/playwright/integration/kitchen-sink-holistic-conformance.spec.ts",
    "test:kitchen-sink": "npm run test:kitchen-sink:python && npm run test:kitchen-sink:playwright",
    "test:unit": "npm run --workspace formspec-engine test && npm run --workspace formspec-webcomponent test",
    "test:all": "npm run test:unit && npm run test:e2e",
    "docs:generate": "node scripts/generate-spec-artifacts.mjs",
    "docs:check": "node scripts/generate-spec-artifacts.mjs --check && python3 -m pytest tests/unit/schema/contracts/test_cross_spec_contracts.py -q"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@types/node": "^20.0.0",
    "@uswds/uswds": "^3.13.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "chevrotain": "^11.1.1"
  }
}
