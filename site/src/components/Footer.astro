---
import Newsletter from "./Newsletter.astro";
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label="Formspec home">
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <rect x="2" y="2" width="16" height="16" rx="4" stroke="currentColor" stroke-width="1.5"/>
          <path d="M6 7h8M6 10h5M6 13h7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <span>formspec</span>
      </a>
      <p class="footer-tagline">Open source form specification for high-stakes environments.</p>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <div class="footer-nav-group">
        <p class="footer-nav-label">Product</p>
        <ul role="list">
          <li><a href="/#personas">Who it's for</a></li>
          <li><a href="/#developers">Developers</a></li>
          <li><a href="/about/">About</a></li>
          <li><a href="/blog/">Blog</a></li>
        </ul>
      </div>
      <div class="footer-nav-group">
        <p class="footer-nav-label">Resources</p>
        <ul role="list">
          <li><a href="/docs/">Documentation</a></li>
          <li><a href="https://github.com/Formspec-org/formspec" target="_blank" rel="noopener noreferrer">GitHub</a></li>
          <li><a href="/blog/rss.xml">RSS Feed</a></li>
        </ul>
      </div>
      <div class="footer-nav-group">
        <Newsletter variant="stacked" />
      </div>
    </nav>
  </div>

  <div class="footer-bottom">
    <p>
      &copy; {year} <a href="https://www.linkedin.com/in/michael-deeb/" target="_blank" rel="noopener noreferrer">Michael Deeb</a>
      and <a href="https://tealwolf.consulting/" target="_blank" rel="noopener noreferrer">TealWolf Consulting</a>, with
      <a href="https://focusconsulting.io/" target="_blank" rel="noopener noreferrer">Focus Consulting</a> as a strategic partner.
      <a href="https://github.com/Formspec-org/formspec/blob/main/LICENSING.md" target="_blank" rel="noopener noreferrer">Open-core license</a>.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
    margin-top: auto;
  }

  .footer-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 3rem clamp(1.25rem, 4vw, 2.5rem) 2.5rem;
    display: flex;
    justify-content: space-between;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .footer-brand {
    max-width: 22rem;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 0.9375rem;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    text-decoration: none;
    margin-bottom: 0.75rem;
  }

  .footer-logo:hover { color: var(--color-accent); }

  .footer-tagline {
    font-size: 0.875rem;
    color: var(--color-ink-tertiary);
    line-height: 1.6;
    margin: 0;
  }

  .footer-nav {
    display: flex;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .footer-nav-group ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-nav-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-ink-tertiary);
    margin: 0 0 0.75rem;
  }

  .footer-nav-group a {
    font-size: 0.875rem;
    color: var(--color-ink-secondary);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-nav-group a:hover { color: var(--color-ink); }

  .footer-bottom {
    max-width: 72rem;
    margin: 0 auto;
    padding: 1.25rem clamp(1.25rem, 4vw, 2.5rem);
    border-top: 1px solid var(--color-border);
  }

  .footer-bottom p {
    font-size: 0.8125rem;
    color: var(--color-ink-tertiary);
    margin: 0;
  }

  .footer-bottom a {
    color: var(--color-ink-tertiary);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.15s;
  }

  .footer-bottom a:hover { color: var(--color-ink-secondary); }
</style>
