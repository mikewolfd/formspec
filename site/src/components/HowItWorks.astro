---
// HowItWorks — 4-step horizontal sequence.
// Numbers do the visual work. No icons needed.
// Background alternates from Personas (surface) back to bg.

const steps = [
  {
    number: "01",
    title: "Describe",
    body: "Tell the AI what your form needs. Fields, rules, calculations, page flow — in plain English.",
  },
  {
    number: "02",
    title: "Build",
    body: "AI generates a complete form definition through typed tool calls. Every field and rule passes through validation automatically.",
  },
  {
    number: "03",
    title: "Review",
    body: "You see the result instantly. Tweak anything — the AI handles boilerplate, you make the decisions.",
  },
  {
    number: "04",
    title: "Deploy",
    body: "Your form works everywhere. Browser, mobile, offline. Same validation rules on client and server.",
  },
];
---

<section class="hiw-section" aria-labelledby="hiw-heading">
  <div class="hiw-inner">
    <header class="hiw-header">
      <div class="section-eyebrow" aria-hidden="true">How it works</div>
      <h2 class="hiw-title" id="hiw-heading">From description to deployment.</h2>
    </header>

    <ol class="hiw-steps" aria-label="Process steps">
      {steps.map((step) => (
        <li class="hiw-step">
          <span class="hiw-number" aria-hidden="true">{step.number}</span>
          <h3 class="hiw-step-title">{step.title}</h3>
          <p class="hiw-step-body">{step.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .hiw-section {
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    padding: 5rem 0;
  }

  .hiw-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 2.5rem);
  }

  .hiw-header {
    margin-bottom: 3rem;
  }

  .section-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: 0.625rem;
  }

  .hiw-title {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    color: var(--color-ink);
    margin: 0;
  }

  .hiw-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    counter-reset: none;
  }

  .hiw-step {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    /* Subtle left rule connects the steps visually */
    padding-left: 1.25rem;
    border-left: 2px solid var(--color-border);
    position: relative;
  }

  .hiw-number {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--color-accent);
    font-variant-numeric: tabular-nums;
    /* Sit outside the left rule */
    position: absolute;
    left: -0.125rem;
    top: -0.625rem;
    background: var(--color-bg);
    padding-right: 0.5rem;
    /* Visually connects number to the rule */
  }

  .hiw-step-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 1.75rem 0 0;
    letter-spacing: -0.01em;
  }

  .hiw-step-body {
    font-size: 0.9375rem;
    color: var(--color-ink-secondary);
    line-height: 1.65;
    margin: 0;
  }

  @media (max-width: 900px) {
    .hiw-steps {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 540px) {
    .hiw-steps {
      grid-template-columns: 1fr;
    }
  }
</style>
