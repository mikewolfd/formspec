---
// Newsletter signup — email input + submit.
// Action URL is a placeholder. Wire to Buttondown, ConvertKit, Mailchimp, etc.
// TODO: Set the form action to your email service endpoint.

export interface Props {
  /** "inline" renders compact (for CTA sections), "stacked" renders with heading (for footer) */
  variant?: "inline" | "stacked";
}

const { variant = "stacked" } = Astro.props;
---

<div class={`newsletter newsletter--${variant}`}>
  {variant === "stacked" && (
    <div class="newsletter-text">
      <p class="newsletter-label">Stay in the loop</p>
      <p class="newsletter-desc">Spec updates, new features, and the occasional design deep dive. No spam.</p>
    </div>
  )}
  {variant === "inline" && (
    <p class="newsletter-inline-label">Get spec updates and new feature announcements:</p>
  )}
  <form
    class="newsletter-form"
    action="https://buttondown.com/api/emails/embed-subscribe/formspec"
    method="post"
    target="_blank"
  >
    <label for={`newsletter-email-${variant}`} class="sr-only">Email address</label>
    <input
      type="email"
      name="email"
      id={`newsletter-email-${variant}`}
      placeholder="you@example.com"
      required
      autocomplete="email"
      class="newsletter-input"
    />
    <button type="submit" class="newsletter-btn">Subscribe</button>
  </form>
</div>

<style>
  .newsletter {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .newsletter--inline {
    gap: 0.5rem;
  }

  .newsletter-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-ink-tertiary);
    margin: 0 0 0.25rem;
  }

  .newsletter-desc {
    font-size: 0.875rem;
    color: var(--color-ink-secondary);
    line-height: 1.5;
    margin: 0;
  }

  .newsletter-inline-label {
    font-size: 0.9375rem;
    color: var(--color-ink-secondary);
    margin: 0;
  }

  .newsletter-form {
    display: flex;
    gap: 0.5rem;
    max-width: 24rem;
  }

  .newsletter-input {
    flex: 1;
    min-width: 0;
    font-size: 0.875rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius);
    background: var(--color-bg);
    color: var(--color-ink);
    font-family: var(--font-sans);
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .newsletter-input::placeholder {
    color: var(--color-ink-tertiary);
  }

  .newsletter-input:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgb(61 82 213 / 0.12);
  }

  .newsletter-btn {
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.5rem 1rem;
    border: none;
    border-radius: var(--radius);
    background: var(--color-accent);
    color: white;
    cursor: pointer;
    font-family: var(--font-sans);
    white-space: nowrap;
    transition: background-color 0.15s, transform 0.1s;
    box-shadow: 0 1px 2px rgb(61 82 213 / 0.3);
  }

  .newsletter-btn:hover {
    background: #2c42c4;
    transform: translateY(-1px);
  }

  .newsletter-btn:active {
    transform: translateY(0);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 480px) {
    .newsletter-form {
      flex-direction: column;
      max-width: none;
    }

    .newsletter-btn {
      width: 100%;
    }
  }
</style>
