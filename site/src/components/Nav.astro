---
export interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

/** Normalize pathname for nav “active” (trailing slash, references static entry). */
function normalizeNavPath(pathname: string): string {
  let p = pathname.replace(/\/$/, "") || "/";
  if (p === "/references/index.html") p = "/references";

  return p;
}

function pathForActive(pathname: string, linkHref: string): boolean {
  const p = normalizeNavPath(pathname);
  const h = normalizeNavPath(linkHref.split("#")[0]);
  return p === h;
}

const links = [
  { href: "/#personas", label: "Who it's for" },
  { href: "/features/", label: "Features" },
  { href: "/architecture/", label: "Architecture" },
  { href: "/references", label: "References" },
  { href: "/docs/", label: "Docs" },
  { href: "/blog/", label: "Blog" },
  { href: "/about/", label: "About" },
];
---

<header class="site-nav" id="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="Formspec home">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <rect x="2" y="2" width="16" height="16" rx="4" stroke="currentColor" stroke-width="1.5"/>
        <path d="M6 7h8M6 10h5M6 13h7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <span>formspec</span>
    </a>

    <nav aria-label="Primary navigation">
      <ul class="nav-links" role="list">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              class={pathForActive(currentPath, link.href) ? "nav-link active" : "nav-link"}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a
      href="https://github.com/Formspec-org/formspec"
      class="nav-cta"
      target="_blank"
      rel="noopener noreferrer"
    >
      <svg width="13" height="13" viewBox="0 0 14 14" fill="currentColor" aria-hidden="true">
        <path d="M7 1l1.545 3.13 3.455.502-2.5 2.437.59 3.441L7 8.885l-3.09 1.625.59-3.441L2 4.632l3.455-.503L7 1z"/>
      </svg>
      Star on GitHub
    </a>

    <!-- Mobile hamburger -->
    <button
      class="nav-hamburger"
      aria-label="Toggle navigation"
      aria-expanded="false"
      aria-controls="mobile-nav"
      id="nav-toggle"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Mobile nav drawer -->
  <div class="mobile-nav" id="mobile-nav" role="dialog" aria-label="Navigation" aria-modal="true" hidden>
    <nav>
      <ul role="list">
        {links.map((link) => (
          <li>
            <a href={link.href} class="mobile-nav-link">{link.label}</a>
          </li>
        ))}
        <li>
          <a
            href="https://github.com/Formspec-org/formspec"
            class="mobile-nav-link mobile-nav-cta"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="13" height="13" viewBox="0 0 14 14" fill="currentColor" aria-hidden="true" style="vertical-align: -1px;">
              <path d="M7 1l1.545 3.13 3.455.502-2.5 2.437.59 3.441L7 8.885l-3.09 1.625.59-3.441L2 4.632l3.455-.503L7 1z"/>
            </svg>
            Star on GitHub
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgb(250 250 249 / 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 2.5rem);
    height: 60px;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 0.9375rem;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav-logo:hover { color: var(--color-accent); }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1;
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink-secondary);
    text-decoration: none;
    padding: 0.375rem 0.625rem;
    border-radius: var(--radius-sm);
    transition: color 0.15s, background-color 0.15s;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-ink);
    background-color: var(--color-surface-raised);
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 600;
    padding: 0.4375rem 0.875rem;
    border-radius: var(--radius);
    border: 1px solid var(--color-border-strong);
    color: var(--color-ink);
    text-decoration: none;
    transition: border-color 0.15s, background-color 0.15s;
    flex-shrink: 0;
  }

  .nav-cta:hover {
    border-color: var(--color-accent);
    background-color: var(--color-accent-light);
    color: var(--color-accent);
  }

  .nav-hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: var(--radius-sm);
    margin-left: auto;
  }

  .nav-hamburger span {
    display: block;
    width: 20px;
    height: 1.5px;
    background: var(--color-ink-secondary);
    border-radius: 1px;
    transition: transform 0.2s, opacity 0.2s;
  }

  .nav-hamburger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .nav-hamburger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .nav-hamburger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  .mobile-nav {
    border-top: 1px solid var(--color-border);
    padding: 1rem clamp(1.25rem, 4vw, 2.5rem) 1.5rem;
  }

  .mobile-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .mobile-nav-link {
    display: block;
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-ink-secondary);
    text-decoration: none;
    padding: 0.625rem 0.5rem;
    border-radius: var(--radius-sm);
    transition: color 0.15s, background-color 0.15s;
  }

  .mobile-nav-link:hover { color: var(--color-ink); background: var(--color-surface-raised); }

  .mobile-nav-cta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--color-accent);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .nav-links,
    .nav-cta {
      display: none;
    }

    .nav-hamburger {
      display: flex;
    }
  }

  @media (min-width: 769px) {
    .mobile-nav {
      display: none !important;
    }
  }
</style>

<script>
  const toggle = document.getElementById("nav-toggle");
  const mobileNav = document.getElementById("mobile-nav");

  if (toggle && mobileNav) {
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      mobileNav.hidden = expanded;
    });

    // Close on link click
    mobileNav.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        toggle.setAttribute("aria-expanded", "false");
        mobileNav.hidden = true;
      });
    });
  }
</script>
