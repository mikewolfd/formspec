// Developer section — for the people who will actually implement this.
// Show them what they're getting, make it concrete with code.

// Code examples defined as HTML strings to avoid parser conflicts
// with script/style tags in template.
const codePython = `<span class="tok-comment"># Server-side re-verification — same rules the browser ran</span>
<span class="tok-kw">from</span> formspec.fel <span class="tok-kw">import</span> Evaluator
<span class="tok-kw">from</span> formspec.validator <span class="tok-kw">import</span> validate_response

<span class="tok-comment"># Load the definition that ran in the browser</span>
evaluator = Evaluator(definition)
report = validate_response(evaluator, submitted_data)

<span class="tok-kw">if</span> report.has_errors:
    <span class="tok-kw">return</span> {<span class="tok-str">"errors"</span>: report.results}`;

const codeTypeScript = `<span class="tok-comment">// Browser — reactive signals, live validation</span>
<span class="tok-kw">import</span> { FormEngine } <span class="tok-kw">from</span> <span class="tok-str">"@formspec-org/engine"</span>;

<span class="tok-kw">const</span> engine = <span class="tok-kw">new</span> FormEngine();
engine.setDefinition(definition);
engine.setValue(<span class="tok-str">"org_type"</span>, <span class="tok-str">"nonprofit"</span>);

<span class="tok-comment">// Signals update — EIN field becomes relevant</span>
<span class="tok-kw">const</span> report = engine.getValidationReport();
<span class="tok-kw">const</span> response = engine.getResponse();`;

const codeHTML = `<span class="tok-comment">&lt;!-- Drop-in web component. No framework required. --&gt;</span>
<span class="tok-kw">&lt;script</span> type=<span class="tok-str">"module"</span><span class="tok-kw">&gt;</span>
  <span class="tok-kw">import</span> <span class="tok-str">"@formspec-org/webcomponent"</span>;
<span class="tok-kw">&lt;/scr</span><span class="tok-kw">ipt&gt;</span>

<span class="tok-kw">&lt;formspec-render&gt;&lt;/formspec-render&gt;</span>

<span class="tok-kw">&lt;scr</span><span class="tok-kw">ipt&gt;</span>
  <span class="tok-kw">const</span> el = document.querySelector(<span class="tok-str">"formspec-render"</span>);
  el.definition = myDefinition;
<span class="tok-kw">&lt;/scr</span><span class="tok-kw">ipt&gt;</span>`;

const codeReact = `<span class="tok-comment">// React — hooks + auto-renderer with custom components</span>
<span class="tok-kw">import</span> { FormspecForm } <span class="tok-kw">from</span> <span class="tok-str">"@formspec-org/react"</span>;

<span class="tok-comment">// Drop in with defaults — semantic HTML, zero opinions</span>
&lt;<span class="tok-kw">FormspecForm</span> <span class="tok-prop">definition</span>={definition} /&gt;

<span class="tok-comment">// Or bring your own components</span>
&lt;<span class="tok-kw">FormspecForm</span>
  <span class="tok-prop">definition</span>={definition}
  <span class="tok-prop">components</span>={{ <span class="tok-prop">fields</span>: { <span class="tok-prop">TextInput</span>: MyShadcnInput } }}
/&gt;`;

const codeMCP = `<span class="tok-comment">// AI builds a grant application via MCP tool calls</span>
<span class="tok-kw">formspec_field</span><span class="tok-punct">({</span> <span class="tok-prop">path</span><span class="tok-punct">:</span> <span class="tok-str">"org_name"</span><span class="tok-punct">,</span> <span class="tok-prop">label</span><span class="tok-punct">:</span> <span class="tok-str">"Organization Name"</span><span class="tok-punct">,</span> <span class="tok-prop">type</span><span class="tok-punct">:</span> <span class="tok-str">"string"</span> <span class="tok-punct">})</span>
<span class="tok-kw">formspec_field</span><span class="tok-punct">({</span> <span class="tok-prop">path</span><span class="tok-punct">:</span> <span class="tok-str">"budget"</span><span class="tok-punct">,</span> <span class="tok-prop">label</span><span class="tok-punct">:</span> <span class="tok-str">"Requested Amount"</span><span class="tok-punct">,</span> <span class="tok-prop">type</span><span class="tok-punct">:</span> <span class="tok-str">"decimal"</span> <span class="tok-punct">})</span>
<span class="tok-kw">formspec_group</span><span class="tok-punct">({</span> <span class="tok-prop">path</span><span class="tok-punct">:</span> <span class="tok-str">"line_items"</span><span class="tok-punct">,</span> <span class="tok-prop">label</span><span class="tok-punct">:</span> <span class="tok-str">"Budget Line Items"</span><span class="tok-punct">,</span>
  <span class="tok-prop">props</span><span class="tok-punct">:</span> <span class="tok-punct">{</span> <span class="tok-prop">repeat</span><span class="tok-punct">:</span> <span class="tok-punct">{</span> <span class="tok-prop">min</span><span class="tok-punct">:</span> <span class="tok-str">1</span><span class="tok-punct">,</span> <span class="tok-prop">max</span><span class="tok-punct">:</span> <span class="tok-str">20</span> <span class="tok-punct">}</span> <span class="tok-punct">}</span> <span class="tok-punct">})</span>
<span class="tok-kw">formspec_behavior</span><span class="tok-punct">({</span>
  <span class="tok-prop">action</span><span class="tok-punct">:</span> <span class="tok-str">"add_rule"</span><span class="tok-punct">,</span> <span class="tok-prop">target</span><span class="tok-punct">:</span> <span class="tok-str">"budget"</span><span class="tok-punct">,</span>
  <span class="tok-prop">rule</span><span class="tok-punct">:</span> <span class="tok-str">"$budget &gt; 0"</span><span class="tok-punct">,</span>
  <span class="tok-prop">message</span><span class="tok-punct">:</span> <span class="tok-str">"Budget must be positive"</span>
<span class="tok-punct">})</span>
<span class="tok-kw">formspec_flow</span><span class="tok-punct">({</span> <span class="tok-prop">action</span><span class="tok-punct">:</span> <span class="tok-str">"set_mode"</span><span class="tok-punct">,</span> <span class="tok-prop">mode</span><span class="tok-punct">:</span> <span class="tok-str">"wizard"</span> <span class="tok-punct">})</span>`;
---

<section class="dev-section" id="developers" aria-labelledby="dev-heading">
  <div class="dev-inner">

    <div class="dev-copy">
      <div class="section-eyebrow">For developers</div>
      <h2 class="section-title" id="dev-heading">
        A specification, not a platform.
      </h2>
      <p class="dev-lead">Self-hosted. Free forever. Apache-2.0 runtime.</p>

      <div class="dev-groups">
        <div class="dev-group">
          <h3 class="dev-group-label">The Specification</h3>
          <ul class="dev-list">
            <li>JSON-native form definitions validated by JSON Schema</li>
            <li>FEL (Formspec Expression Language) — deterministic, side-effect-free expressions for calculations, conditions, and validation</li>
            <li>Companion sidecars for references, ontology bindings, and locale translations — metadata that attaches without altering core behavior</li>
            <li>Static linter catches definition errors before runtime</li>
          </ul>
        </div>

        <div class="dev-group">
          <h3 class="dev-group-label">Five Runtimes</h3>
          <ul class="dev-list">
            <li>Rust shared kernel — single implementation of FEL, linting, evaluation, mapping, compiled to WASM and PyO3</li>
            <li>TypeScript form engine — reactive signals, framework-agnostic, calls Rust via WASM for all pure logic</li>
            <li><code class="inline-code">&lt;formspec-render&gt;</code> web component — drop a tag, get a form. WCAG 2.1 AA and Section 508 compliant.</li>
            <li><code class="inline-code">formspec-react</code> — React hooks + auto-renderer. <code class="inline-code">useField</code>, granular subscriptions, overridable component map. Semantic HTML defaults.</li>
            <li><code class="inline-code">formspec-swift</code> (iOS/macOS) and <code class="inline-code">formspec-kotlin</code> (Android) — native renderers with Jetpack Compose and SwiftUI, same engine via hidden WebView bridge</li>
            <li>Headless adapter architecture — USWDS ships built-in; plug in Bootstrap, Tailwind, Material, Shadcn, or your own design system</li>
            <li>Python evaluator — server-side re-validation via PyO3, same Rust core, same results</li>
            <li>Mapping engine — output transformation to any format</li>
          </ul>
        </div>

        <div class="dev-group">
          <h3 class="dev-group-label">AI Integration</h3>
          <ul class="dev-list">
            <li>MCP server with 28 typed tools — AI agents build forms through structured calls, not freeform text generation</li>
            <li>Automatic validation catches errors in AI-generated forms before they reach production</li>
            <li>Formspec Studio — describe what you need, watch the AI build it in real time</li>
            <li>Expression language is deterministic and verifiable — AI-generated logic can be audited</li>
          </ul>
        </div>
      </div>

      <p class="dev-scope">
        Formspec is the form engine — data, logic, validation, rendering.
        Hosting, auth, workflows — that's your stack.
      </p>

    </div>

    <!-- Code examples -->
    <div class="dev-code" role="region" aria-label="Code examples">
      <div class="code-tabs-wrapper">
        <div class="code-tab-bar" role="tablist" aria-label="Language examples">
          <button
            class="code-tab active"
            role="tab"
            aria-selected="true"
            aria-controls="tab-python"
            data-tab="python"
            id="tab-btn-python"
          >Python</button>
          <button
            class="code-tab"
            role="tab"
            aria-selected="false"
            aria-controls="tab-ts"
            data-tab="ts"
            id="tab-btn-ts"
          >TypeScript</button>
          <button
            class="code-tab"
            role="tab"
            aria-selected="false"
            aria-controls="tab-react"
            data-tab="react"
            id="tab-btn-react"
          >React</button>
          <button
            class="code-tab"
            role="tab"
            aria-selected="false"
            aria-controls="tab-html"
            data-tab="html"
            id="tab-btn-html"
          >HTML</button>
          <button
            class="code-tab"
            role="tab"
            aria-selected="false"
            aria-controls="tab-mcp"
            data-tab="mcp"
            id="tab-btn-mcp"
          >AI / MCP</button>
        </div>

        <div class="code-panels">
          <!-- Python -->
          <div class="code-panel" id="tab-python" role="tabpanel" aria-labelledby="tab-btn-python">
            <div class="code-window">
              <div class="code-window-bar">
                <span class="code-window-dot" style="background: #ff5f57;"></span>
                <span class="code-window-dot" style="background: #febc2e;"></span>
                <span class="code-window-dot" style="background: #28c840;"></span>
                <span class="code-filename">validate.py</span>
              </div>
              <div class="code-window-body">
                <pre set:html={codePython}></pre>
              </div>
            </div>
          </div>

          <!-- TypeScript -->
          <div class="code-panel hidden" id="tab-ts" role="tabpanel" aria-labelledby="tab-btn-ts">
            <div class="code-window">
              <div class="code-window-bar">
                <span class="code-window-dot" style="background: #ff5f57;"></span>
                <span class="code-window-dot" style="background: #febc2e;"></span>
                <span class="code-window-dot" style="background: #28c840;"></span>
                <span class="code-filename">engine.ts</span>
              </div>
              <div class="code-window-body">
                <pre set:html={codeTypeScript}></pre>
              </div>
            </div>
          </div>

          <!-- React -->
          <div class="code-panel hidden" id="tab-react" role="tabpanel" aria-labelledby="tab-btn-react">
            <div class="code-window">
              <div class="code-window-bar">
                <span class="code-window-dot" style="background: #ff5f57;"></span>
                <span class="code-window-dot" style="background: #febc2e;"></span>
                <span class="code-window-dot" style="background: #28c840;"></span>
                <span class="code-filename">App.tsx</span>
              </div>
              <div class="code-window-body">
                <pre set:html={codeReact}></pre>
              </div>
            </div>
          </div>

          <!-- HTML -->
          <div class="code-panel hidden" id="tab-html" role="tabpanel" aria-labelledby="tab-btn-html">
            <div class="code-window">
              <div class="code-window-bar">
                <span class="code-window-dot" style="background: #ff5f57;"></span>
                <span class="code-window-dot" style="background: #febc2e;"></span>
                <span class="code-window-dot" style="background: #28c840;"></span>
                <span class="code-filename">index.html</span>
              </div>
              <div class="code-window-body">
                <pre set:html={codeHTML}></pre>
              </div>
            </div>
          </div>

          <!-- AI / MCP -->
          <div class="code-panel hidden" id="tab-mcp" role="tabpanel" aria-labelledby="tab-btn-mcp">
            <div class="code-window">
              <div class="code-window-bar">
                <span class="code-window-dot" style="background: #ff5f57;"></span>
                <span class="code-window-dot" style="background: #febc2e;"></span>
                <span class="code-window-dot" style="background: #28c840;"></span>
                <span class="code-filename">studio-session.mcp</span>
              </div>
              <div class="code-window-body">
                <pre set:html={codeMCP}></pre>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .dev-section {
    padding: 5rem 0;
  }

  .dev-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 2.5rem);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .section-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: 0.625rem;
  }

  .section-title {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.25;
    color: var(--color-ink);
    margin: 0 0 1rem;
  }

  .dev-lead {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-ink-secondary);
    margin: 0 0 2rem;
  }

  .dev-groups {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    margin-bottom: 1.75rem;
  }

  .dev-group-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-ink-tertiary);
    margin: 0 0 0.75rem;
  }

  .dev-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .dev-list li {
    font-size: 0.9375rem;
    color: var(--color-ink-secondary);
    line-height: 1.6;
    padding-left: 1.25rem;
    position: relative;
  }

  .dev-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent);
    opacity: 0.5;
  }

  .inline-code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-surface-sunken);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    padding: 0.1em 0.35em;
  }

  .dev-scope {
    font-size: 0.875rem;
    color: var(--color-ink-tertiary);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 0.875rem 1rem;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  /* Code tab interface */
  .code-tabs-wrapper {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow);
  }

  .code-tab-bar {
    display: flex;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface-raised);
    padding: 0.5rem 0.5rem 0;
    gap: 0.25rem;
  }

  .code-tab {
    font-size: 0.8125rem;
    font-weight: 500;
    padding: 0.375rem 0.875rem;
    border-radius: var(--radius-sm) var(--radius-sm) 0 0;
    border: 1px solid transparent;
    background: none;
    color: var(--color-ink-tertiary);
    cursor: pointer;
    transition: color 0.15s, background-color 0.15s;
    font-family: var(--font-mono);
  }

  .code-tab:hover { color: var(--color-ink-secondary); }

  .code-tab.active {
    color: var(--color-ink);
    background: var(--color-surface);
    border-color: var(--color-border);
    border-bottom-color: var(--color-surface);
    margin-bottom: -1px;
    position: relative;
  }

  .code-panel.hidden { display: none; }

  .code-window {
    background: #1e1e2e;
    overflow: hidden;
  }

  .code-window-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: #161625;
    border-bottom: 1px solid rgb(255 255 255 / 0.07);
  }

  .code-window-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .code-filename {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: rgb(255 255 255 / 0.4);
    margin-left: 0.5rem;
  }

  .code-window-body {
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
  }

  .code-window-body pre {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.7;
    color: #c9d1d9;
    margin: 0;
    white-space: pre;
  }

  @media (max-width: 900px) {
    .dev-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>

<script>
  const tabs = document.querySelectorAll(".code-tab");
  const panels = document.querySelectorAll(".code-panel");

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const target = (tab as HTMLElement).dataset.tab;

      tabs.forEach((t) => {
        t.classList.remove("active");
        t.setAttribute("aria-selected", "false");
      });

      panels.forEach((p) => {
        p.classList.add("hidden");
      });

      tab.classList.add("active");
      tab.setAttribute("aria-selected", "true");

      const panel = document.getElementById("tab-" + target);
      if (panel) panel.classList.remove("hidden");
    });
  });
</script>
