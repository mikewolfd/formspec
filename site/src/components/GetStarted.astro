---
// GetStarted — three entry points, each showing who it's for
// and what the experience looks like.
const cloneCmd = 'git clone https://github.com/Formspec-org/formspec.git && cd formspec && npm i && npm run build';
---

<section class="getstarted" aria-label="Getting started">
  <div class="gs-demo-row">
    <a href="/react" class="gs-demo-link" data-track="click_react_demo" data-track-section="getstarted">
      <span class="gs-demo-badge">Live demo</span>
      <span class="gs-demo-text">See a working form built with <strong>formspec-react</strong> — zero component overrides, default rendering</span>
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M2.5 7H11.5M7.5 3L11.5 7L7.5 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
    <a href="/uswds-grant" class="gs-demo-link" data-track="click_uswds_demo" data-track-section="getstarted">
      <span class="gs-demo-badge">Live demo</span>
      <span class="gs-demo-text">Federal grant application rendered with the <strong>USWDS design system adapter</strong></span>
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M2.5 7H11.5M7.5 3L11.5 7L7.5 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
  <div class="getstarted-inner">

    <a href="/studio/" class="gs-card" data-track="click_try_studio" data-track-section="getstarted">
      <div class="gs-preview gs-preview--studio">
        <div class="gs-mock-editor">
          <div class="gs-mock-sidebar">
            <span class="gs-mock-sidebar-item gs-mock-sidebar-item--active"></span>
            <span class="gs-mock-sidebar-item"></span>
            <span class="gs-mock-sidebar-item"></span>
          </div>
          <div class="gs-mock-canvas">
            <span class="gs-mock-field"></span>
            <span class="gs-mock-field gs-mock-field--short"></span>
            <span class="gs-mock-field"></span>
          </div>
        </div>
      </div>
      <div class="gs-content">
        <span class="gs-label">Formspec Studio</span>
        <span class="gs-audience">Full form builder</span>
        <span class="gs-desc">Visual editor for building, editing, and managing complex forms. Full control over every field and rule.</span>
      </div>
    </a>

    <div class="gs-card">
      <div class="gs-preview gs-preview--mcp">
        <div class="gs-mock-terminal">
          <span class="gs-mock-prompt">$</span> formspec-mcp
          <div class="gs-mock-output">28 tools registered</div>
        </div>
      </div>
      <div class="gs-content">
        <span class="gs-label">MCP Server</span>
        <span class="gs-audience">IDE &amp; AI agent users</span>
        <span class="gs-desc">28 typed tools for AI-driven form authoring. Add to Claude, Cursor, or any MCP client.</span>
        <div class="gs-actions">
          <div class="gs-copy-wrapper">
            <button
              class="gs-btn gs-btn--copy"
              data-copy={cloneCmd}
              aria-expanded="false"
            >
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
                <path d="M11 5V3.5A1.5 1.5 0 009.5 2h-6A1.5 1.5 0 002 3.5v6A1.5 1.5 0 003.5 11H5" stroke="currentColor" stroke-width="1.5"/>
              </svg>
              <span class="gs-btn-text">Clone</span>
            </button>
            <div class="gs-popover" role="tooltip">
              <div class="gs-popover-arrow"></div>
              <div class="gs-popover-label">Run in your terminal</div>
              <pre class="gs-popover-code"><code>{cloneCmd}</code></pre>
              <div class="gs-popover-status"></div>
            </div>
          </div>
          <a href="/formspec-mcp.mcpb" class="gs-btn gs-btn--download" download data-track="click_install_mcp" data-track-section="getstarted">
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M8 1v9m0 0L5 7m3 3l3-3M2 12v1a1 1 0 001 1h10a1 1 0 001-1v-1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Claude Desktop
          </a>
        </div>
      </div>
    </div>

    <a href="/chat/" class="gs-card">
      <div class="gs-preview gs-preview--chat">
        <div class="gs-mock-chat">
          <div class="gs-mock-bubble gs-mock-bubble--user">I need a grant application with budget tracking</div>
          <div class="gs-mock-bubble gs-mock-bubble--ai">Building form with 12 fields, 3 pages...</div>
        </div>
      </div>
      <div class="gs-content">
        <span class="gs-label">Chat</span>
        <span class="gs-audience">AI-powered kickstart</span>
        <span class="gs-desc">Describe what you need. AI builds a working form in minutes. No install, no IDE.</span>
      </div>
    </a>

  </div>
</section>

<style>
  .getstarted {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: 2.5rem 0;
  }

  .gs-demo-row {
    max-width: 72rem;
    margin: 0 auto 1rem;
    padding: 0 clamp(1.25rem, 4vw, 2.5rem);
  }

  .gs-demo-link {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.625rem 1rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .gs-demo-link:hover {
    border-color: var(--color-accent);
    box-shadow: 0 1px 4px rgb(61 82 213 / 0.1);
  }

  .gs-demo-badge {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: white;
    background: var(--color-accent);
    padding: 0.15rem 0.5rem;
    border-radius: 100px;
    flex-shrink: 0;
  }

  .gs-demo-text {
    font-size: 0.8125rem;
    color: var(--color-ink-secondary);
    flex: 1;
  }

  .gs-demo-link svg {
    color: var(--color-ink-tertiary);
    flex-shrink: 0;
    transition: transform 0.15s;
  }

  .gs-demo-link:hover svg {
    transform: translateX(2px);
    color: var(--color-accent);
  }

  .getstarted-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 2.5rem);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .gs-card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: visible;
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .gs-preview {
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  }

  .gs-card:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  /* Preview area — mini visual of what the experience looks like */
  .gs-preview {
    padding: 1rem 1rem 0.75rem;
    min-height: 5.5rem;
    display: flex;
    align-items: flex-end;
  }

  .gs-preview--studio {
    background: linear-gradient(135deg, #2a2a3d, #1e1e2e);
  }

  .gs-preview--mcp {
    background: linear-gradient(135deg, #1a1a2e, #0f0f1a);
  }

  .gs-preview--chat {
    background: linear-gradient(135deg, #2d2a3d, #1e1b2e);
  }

  /* Mock editor (Studio) */
  .gs-mock-editor {
    display: flex;
    gap: 0.375rem;
    width: 100%;
    height: 100%;
  }

  .gs-mock-sidebar {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    width: 2.5rem;
    flex-shrink: 0;
  }

  .gs-mock-sidebar-item {
    display: block;
    height: 6px;
    background: rgb(255 255 255 / 0.12);
    border-radius: 2px;
  }

  .gs-mock-sidebar-item--active {
    background: rgb(61 82 213 / 0.5);
  }

  .gs-mock-canvas {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    background: rgb(255 255 255 / 0.04);
    border-radius: 3px;
    padding: 0.375rem;
  }

  /* Mock chat bubbles */
  .gs-mock-chat {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    width: 100%;
  }

  .gs-mock-bubble {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    line-height: 1.4;
    padding: 0.375rem 0.5rem;
    border-radius: 4px;
    max-width: 85%;
  }

  .gs-mock-bubble--user {
    background: rgb(61 82 213 / 0.25);
    color: rgb(255 255 255 / 0.8);
    align-self: flex-end;
  }

  .gs-mock-bubble--ai {
    background: rgb(255 255 255 / 0.08);
    color: rgb(255 255 255 / 0.6);
    align-self: flex-start;
  }

  /* Mock terminal */
  .gs-mock-terminal {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: rgb(255 255 255 / 0.7);
    line-height: 1.6;
    width: 100%;
  }

  .gs-mock-prompt {
    color: var(--color-accent);
    margin-right: 0.375rem;
  }

  .gs-mock-output {
    color: rgb(80 250 123 / 0.7);
    margin-top: 0.125rem;
  }

  /* Mock form fields in chat preview */
  .gs-mock-field {
    display: block;
    height: 6px;
    background: rgb(255 255 255 / 0.15);
    border-radius: 2px;
    margin-top: 0.25rem;
  }

  .gs-mock-field--short {
    width: 60%;
  }

  /* Card content area */
  .gs-content {
    padding: 1rem 1.125rem 1.125rem;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .gs-label {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: -0.01em;
  }

  .gs-audience {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    margin-bottom: 0.25rem;
  }

  .gs-desc {
    font-size: 0.8125rem;
    color: var(--color-ink-secondary);
    line-height: 1.5;
  }

  /* Copy popover */
  .gs-copy-wrapper {
    position: relative;
  }

  .gs-popover {
    position: absolute;
    bottom: calc(100% + 0.5rem);
    left: 0;
    width: max-content;
    max-width: 28rem;
    background: #1e1e2e;
    border: 1px solid rgb(255 255 255 / 0.1);
    border-radius: var(--radius);
    padding: 1rem;
    box-shadow: 0 8px 24px rgb(0 0 0 / 0.3);
    opacity: 0;
    pointer-events: none;
    transform: translateY(4px);
    transition: opacity 0.15s, transform 0.15s;
    z-index: 10;
  }

  .gs-popover.is-visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .gs-popover-arrow {
    position: absolute;
    bottom: -5px;
    left: 1.25rem;
    width: 10px;
    height: 10px;
    background: #1e1e2e;
    border-right: 1px solid rgb(255 255 255 / 0.1);
    border-bottom: 1px solid rgb(255 255 255 / 0.1);
    transform: rotate(45deg);
  }

  .gs-popover-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: rgb(255 255 255 / 0.5);
    margin-bottom: 0.375rem;
  }

  .gs-popover-label code {
    color: rgb(255 255 255 / 0.7);
    font-family: var(--font-mono);
    font-size: 0.625rem;
  }

  .gs-popover-code {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.6;
    color: #c9d1d9;
    background: rgb(0 0 0 / 0.2);
    border-radius: var(--radius-sm);
    padding: 0.75rem 0.875rem;
    margin: 0;
    overflow-x: auto;
    white-space: pre;
  }

  .gs-popover-status {
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #50fa7b;
    margin-top: 0.375rem;
    min-height: 1em;
  }

  /* MCP card action buttons */
  .gs-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.5rem;
  }

  .gs-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.6875rem;
    font-weight: 600;
    padding: 0.3rem 0.625rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.15s, border-color 0.15s, color 0.15s;
    white-space: nowrap;
  }

  .gs-btn--copy {
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-ink-secondary);
    font-family: var(--font-mono);
  }

  .gs-btn--copy:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .gs-btn--download {
    border: 1px solid rgb(61 82 213 / 0.3);
    background: rgb(61 82 213 / 0.08);
    color: var(--color-accent);
  }

  .gs-btn--download:hover {
    background: rgb(61 82 213 / 0.15);
    border-color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .getstarted-inner {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .gs-card {
      flex-direction: row;
    }

    .gs-preview {
      min-height: 0;
      width: 8rem;
      flex-shrink: 0;
      padding: 0.75rem;
      align-items: center;
    }

    .gs-content {
      padding: 0.75rem 1rem;
    }

    .gs-popover {
      width: 15rem;
      left: auto;
      right: 0;
    }

    .gs-popover-arrow {
      left: auto;
      right: 1.25rem;
    }
  }
</style>

<script>
  document.querySelectorAll('.gs-copy-wrapper').forEach((wrapper) => {
    const btn = wrapper.querySelector('.gs-btn--copy') as HTMLButtonElement;
    const popover = wrapper.querySelector('.gs-popover') as HTMLElement;
    if (!btn || !popover) return;

    const originalLabel = btn.querySelector('.gs-btn-text')!.textContent!;
    let hideTimer: ReturnType<typeof setTimeout>;

    btn.addEventListener('click', () => {
      // Close all other popovers first
      document.querySelectorAll('.gs-popover.is-visible').forEach(p => {
        if (p !== popover) p.classList.remove('is-visible');
      });

      clearTimeout(hideTimer);
      const text = btn.dataset.copy || '';
      const status = popover.querySelector('.gs-popover-status') as HTMLElement;
      const btnText = btn.querySelector('.gs-btn-text') as HTMLElement;

      popover.classList.add('is-visible');
      btn.setAttribute('aria-expanded', 'true');

      navigator.clipboard.writeText(text).then(() => {
        if (status) status.textContent = 'Copied to clipboard';
        if (btnText) btnText.textContent = 'Copied!';

        hideTimer = setTimeout(() => {
          popover.classList.remove('is-visible');
          btn.setAttribute('aria-expanded', 'false');
          if (status) status.textContent = '';
          if (btnText) btnText.textContent = originalLabel;
        }, 3000);
      });
    });
  });

  // Close all popovers on click outside
  document.addEventListener('click', (e) => {
    const target = e.target as Element;
    if (!target.closest?.('.gs-copy-wrapper')) {
      document.querySelectorAll('.gs-popover.is-visible').forEach(p => p.classList.remove('is-visible'));
      document.querySelectorAll('.gs-btn--copy[aria-expanded="true"]').forEach(b => b.setAttribute('aria-expanded', 'false'));
    }
  });
</script>
