---
// Hero section — the value proposition above the fold.
// Light, clean, confident. Typography does the heavy lifting.
---

<section class="hero" aria-label="Introduction">
  <div class="hero-inner">

    <div class="hero-badge" aria-label="Project status">
      <span class="badge-dot" aria-hidden="true"></span>
      <span>Open source · MIT License</span>
    </div>

    <p class="hero-descriptor">An open-source form specification for high-stakes environments</p>

    <h1 class="hero-headline">
      Build complex forms<br />
      in an afternoon.<br />
      <span class="hero-headline-dim">They work everywhere. Even offline.</span>
    </h1>

    <p class="hero-sub">
      Describe what you need in plain English. AI builds a working form — with conditional logic,
      validation rules, calculated fields, multi-page wizards. Every form works offline, on any
      device, with no vendor lock-in.
    </p>

    <div class="hero-actions">
      <a href="/studio/" class="btn-primary">
        Try Formspec Studio
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2.5 7H11.5M7.5 3L11.5 7L7.5 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a
        href="https://github.com/formspec/formspec"
        class="btn-ghost"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        GitHub
      </a>
      <a href="/#developers" class="btn-ghost">
        Read the spec
      </a>
    </div>

    <p class="hero-cta-caption">A browser-based form builder with AI chat. Describe what you need, watch it build.</p>

    <div class="hero-proof" role="list" aria-label="Key properties">
      <span role="listitem">Works offline</span>
      <span class="proof-sep" aria-hidden="true">/</span>
      <span role="listitem">Automatic validation</span>
      <span class="proof-sep" aria-hidden="true">/</span>
      <span role="listitem">No vendor lock-in</span>
      <span class="proof-sep" aria-hidden="true">/</span>
      <span role="listitem">AI-assisted</span>
      <span class="proof-sep" aria-hidden="true">/</span>
      <span role="listitem">Open source</span>
    </div>

  </div>

  <!-- Structured data visual — JSON definition preview -->
  <div class="hero-code" aria-hidden="true">
    <div class="code-window">
      <div class="code-window-bar">
        <span class="code-window-dot" style="background: #ff5f57;"></span>
        <span class="code-window-dot" style="background: #febc2e;"></span>
        <span class="code-window-dot" style="background: #28c840;"></span>
        <span class="code-filename">grant-application.definition.json</span>
      </div>
      <div class="code-window-body">
<pre><span class="tok-punct">{</span>
  <span class="tok-prop">"title"</span><span class="tok-punct">:</span> <span class="tok-str">"Grant Application"</span><span class="tok-punct">,</span>
  <span class="tok-prop">"items"</span><span class="tok-punct">:</span> <span class="tok-punct">[</span>
    <span class="tok-punct">{</span>
      <span class="tok-prop">"id"</span><span class="tok-punct">:</span> <span class="tok-str">"org_type"</span><span class="tok-punct">,</span>
      <span class="tok-prop">"type"</span><span class="tok-punct">:</span> <span class="tok-str">"choice"</span>
    <span class="tok-punct">}</span><span class="tok-punct">,</span>
    <span class="tok-punct">{</span>
      <span class="tok-prop">"id"</span><span class="tok-punct">:</span> <span class="tok-str">"ein"</span><span class="tok-punct">,</span>
      <span class="tok-prop">"bind"</span><span class="tok-punct">:</span> <span class="tok-punct">{</span>
        <span class="tok-prop">"relevant"</span><span class="tok-punct">:</span> <span class="tok-str">"$org_type = 'nonprofit'"</span><span class="tok-punct">,</span>
        <span class="tok-prop">"required"</span><span class="tok-punct">:</span> <span class="tok-str">"true"</span>
      <span class="tok-punct">}</span>
    <span class="tok-punct">}</span><span class="tok-punct">,</span>
    <span class="tok-punct">{</span>
      <span class="tok-prop">"id"</span><span class="tok-punct">:</span> <span class="tok-str">"monthly_budget"</span><span class="tok-punct">,</span>
      <span class="tok-prop">"bind"</span><span class="tok-punct">:</span> <span class="tok-punct">{</span>
        <span class="tok-prop">"calculate"</span><span class="tok-punct">:</span> <span class="tok-str">"$amount / $duration"</span>
      <span class="tok-punct">}</span>
    <span class="tok-punct">}</span>
  <span class="tok-punct">]</span>
<span class="tok-punct">}</span></pre>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    max-width: 72rem;
    margin: 0 auto;
    padding: 5rem clamp(1.25rem, 4vw, 2.5rem) 4rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-inner {
    /* left column */
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-ink-secondary);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    padding: 0.25rem 0.75rem;
    margin-bottom: 1.75rem;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-green);
    flex-shrink: 0;
  }

  .hero-descriptor {
    font-size: 0.875rem;
    color: var(--color-ink-secondary);
    margin: 0 0 0.75rem;
    line-height: 1.5;
  }

  .hero-cta-caption {
    font-size: 0.8125rem;
    color: var(--color-ink-tertiary);
    margin: -1.25rem 0 2rem;
    line-height: 1.5;
  }

  .hero-headline {
    font-size: clamp(2.25rem, 4.5vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.1;
    color: var(--color-ink);
    margin: 0 0 1.5rem;
  }

  .hero-headline-dim {
    color: var(--color-ink-tertiary);
  }

  .hero-sub {
    font-size: 1.0625rem;
    color: var(--color-ink-secondary);
    line-height: 1.7;
    max-width: 38rem;
    margin: 0 0 2rem;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.625rem 1.25rem;
    border-radius: var(--radius);
    background: var(--color-accent);
    color: white;
    text-decoration: none;
    transition: background-color 0.15s, transform 0.1s;
    box-shadow: 0 1px 2px rgb(61 82 213 / 0.3), 0 0 0 1px rgb(61 82 213 / 0.1);
  }

  .btn-primary:hover {
    background: #2c42c4;
    transform: translateY(-1px);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 500;
    padding: 0.625rem 1.25rem;
    border-radius: var(--radius);
    border: 1px solid var(--color-border-strong);
    color: var(--color-ink-secondary);
    text-decoration: none;
    background: var(--color-surface);
    transition: border-color 0.15s, color 0.15s;
  }

  .btn-ghost:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .hero-proof {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
    font-size: 0.8125rem;
    color: var(--color-ink-tertiary);
  }

  .proof-sep {
    color: var(--color-border-strong);
  }

  .hero-code {
    /* right column */
  }

  .code-filename {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: rgb(255 255 255 / 0.4);
    margin-left: 0.5rem;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding-top: 3rem;
    }

    .hero-code {
      max-width: 100%;
    }
  }

  @media (max-width: 600px) {
    .hero-headline {
      font-size: clamp(2rem, 8vw, 2.5rem);
    }
  }
</style>
