---
// Hero section — the value proposition above the fold.
// Light, clean, confident. Typography does the heavy lifting.
import '@formspec-org/webcomponent/formspec-default.css';
import Newsletter from "./Newsletter.astro";
---

<section class="hero" aria-label="Introduction">
  <div class="hero-inner">

    <div class="hero-badge" aria-label="Project status">
      <span class="badge-dot" aria-hidden="true"></span>
      <span>Open source · Apache-2.0</span>
    </div>

    <p class="hero-descriptor">An open-source form specification for high-stakes environments</p>

    <h1 class="hero-headline">
      Build complex forms<br />
      in an afternoon.<br />
      <span class="hero-headline-dim">They work everywhere. Even offline.</span>
    </h1>

    <p class="hero-sub">
      Describe what you need in plain English. AI builds a working form — complete with
      business rules, smart defaults, and multi-page workflows. One definition renders
      on web, React, iOS, and Android. Works offline. No vendor lock-in.
    </p>

    <div class="hero-actions">
      <a href="/studio/" class="btn-primary" data-track="click_try_studio" data-track-section="hero">
        Try Formspec Studio
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2.5 7H11.5M7.5 3L11.5 7L7.5 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a
        href="https://github.com/Formspec-org/formspec"
        class="btn-ghost"
        target="_blank"
        rel="noopener noreferrer"
        data-track="click_github"
        data-track-section="hero"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        GitHub
      </a>
      <a href="/docs/" class="btn-ghost">
        Docs
      </a>
    </div>

    <div class="hero-pills" role="list" aria-label="Technologies">
      <span role="listitem" class="hero-pill">Rust</span>
      <span role="listitem" class="hero-pill">TypeScript</span>
      <span role="listitem" class="hero-pill">React</span>
      <span role="listitem" class="hero-pill">Swift</span>
      <span role="listitem" class="hero-pill">Kotlin</span>
      <span role="listitem" class="hero-pill">Python</span>
      <span role="listitem" class="hero-pill">WASM</span>
      <span role="listitem" class="hero-pill">Web Components</span>
      <span role="listitem" class="hero-pill">Tailwind</span>
      <span role="listitem" class="hero-pill">USWDS</span>
      <span role="listitem" class="hero-pill">JSON Schema</span>
      <span role="listitem" class="hero-pill">MCP Server</span>
      <span role="listitem" class="hero-pill">FHIR</span>
      <span role="listitem" class="hero-pill">schema.org</span>
      <span role="listitem" class="hero-pill">ICD-10</span>
      <span role="listitem" class="hero-pill">Field-level guidance</span>
      <span role="listitem" class="hero-pill">i18n</span>
      <span role="listitem" class="hero-pill">AI-native</span>
      <span role="listitem" class="hero-pill">Apache-2.0</span>
    </div>

    <div class="hero-newsletter">
      <Newsletter variant="inline" />
    </div>

  </div>

  <!-- Interactive playground — editable definition JSON and live rendered form -->
  <div class="hero-code">
    <div class="code-window split-window">
      <div class="code-window-bar">
        <span class="code-window-dot" style="background: #ff5f57;"></span>
        <span class="code-window-dot" style="background: #febc2e;"></span>
        <span class="code-window-dot" style="background: #28c840;"></span>
        <span class="code-filename">definition.json</span>
        <span class="split-window-label">Preview</span>
      </div>
      <div class="split-window-body">

        <!-- Left: editable JSON -->
        <div class="split-pane split-pane--code">
          <textarea
            id="hero-editor"
            class="hero-editor"
            spellcheck="false"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            aria-label="Edit form definition JSON — changes update the preview"
          ></textarea>
          <div class="hero-editor-status" id="hero-editor-status"></div>
        </div>

        <!-- Right: live rendered form -->
        <div class="split-pane split-pane--preview" id="hero-preview-pane">
          <p class="live-demo-hint">
            <span class="live-demo-hint-dot" aria-hidden="true"></span><span class="live-demo-hint-text">Live demo — edits on the left update this form in real time.</span>
          </p>
          <div class="live-demo-body">
            <div class="preview-loading" id="hero-loading" aria-hidden="true">
              <div class="preview-loading-spinner"></div>
              <span>Rendering...</span>
            </div>
            <formspec-render id="hero-form"></formspec-render>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    max-width: 76rem;
    margin: 0 auto;
    padding: 5rem clamp(1.25rem, 4vw, 2.5rem) 4rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-inner {
    /* left column */
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-ink-secondary);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    padding: 0.25rem 0.75rem;
    margin-bottom: 1.75rem;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-green);
    flex-shrink: 0;
  }

  .hero-descriptor {
    font-size: 0.875rem;
    color: var(--color-ink-secondary);
    margin: 0 0 0.75rem;
    line-height: 1.5;
  }

  .hero-headline {
    font-size: clamp(2.25rem, 4.5vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.1;
    color: var(--color-ink);
    margin: 0 0 1.5rem;
  }

  .hero-headline-dim {
    color: var(--color-ink-secondary);
  }

  .hero-sub {
    font-size: 1.0625rem;
    color: var(--color-ink-secondary);
    line-height: 1.7;
    max-width: 38rem;
    margin: 0 0 1.5rem;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.625rem 1.25rem;
    border-radius: var(--radius);
    background: var(--color-accent);
    color: white;
    text-decoration: none;
    transition: background-color 0.15s, transform 0.1s;
    box-shadow: 0 1px 2px rgb(61 82 213 / 0.3), 0 0 0 1px rgb(61 82 213 / 0.1);
  }

  .btn-primary:hover {
    background: #2c42c4;
    transform: translateY(-1px);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 500;
    padding: 0.625rem 1.25rem;
    border-radius: var(--radius);
    border: 1px solid var(--color-border-strong);
    color: var(--color-ink-secondary);
    text-decoration: none;
    background: var(--color-surface);
    transition: border-color 0.15s, color 0.15s;
  }

  .btn-ghost:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .hero-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 1.25rem;
  }

  .hero-pill {
    font-size: 0.6875rem;
    font-weight: 500;
    padding: 0.2rem 0.5rem;
    border-radius: 100px;
    border: 1px solid var(--color-border);
    color: var(--color-ink-tertiary);
    background: var(--color-surface);
  }

  .hero-newsletter {
    margin-top: 1.25rem;
  }

  .hero-code {
    min-width: 32rem;
  }

  .code-filename {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: rgb(255 255 255 / 0.4);
    margin-left: 0.5rem;
  }

  /* ── Split window layout ── */

  .split-window {
    overflow: hidden;
  }

  .split-window-label {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgb(255 255 255 / 0.25);
    padding: 0.2rem 0.5rem;
    border: 1px solid rgb(255 255 255 / 0.1);
    border-radius: 3px;
  }

  .split-window-body {
    display: grid;
    grid-template-columns: 55fr 45fr;
    min-height: 0;
  }

  .split-pane {
    min-width: 0;
    overflow: hidden;
  }

  /* ── Left: editor pane ── */

  .split-pane--code {
    border-right: 1px solid rgb(255 255 255 / 0.07);
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .hero-editor {
    flex: 1;
    background: transparent;
    color: #c9d1d9;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1.65;
    padding: 1rem 1.125rem 1rem 0.75rem;
    border: none;
    outline: none;
    resize: none;
    tab-size: 2;
    white-space: pre;
    overflow: auto;
  }

  .hero-editor::selection {
    background: rgb(88 110 230 / 0.35);
  }

  .hero-editor-status {
    position: absolute;
    bottom: 0.5rem;
    right: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.15rem 0.4rem;
    border-radius: 2px;
    opacity: 0;
    transition: opacity 0.2s;
    pointer-events: none;
  }

  .hero-editor-status.error {
    color: #ff6b6b;
    background: rgb(255 107 107 / 0.1);
    opacity: 1;
  }

  .hero-editor-status.ok {
    color: #50fa7b;
    background: rgb(80 250 123 / 0.1);
    opacity: 1;
  }

  /* ── Right: preview pane ── */

  .split-pane--preview {
    background: #f0f0ee;
    padding: 1rem 1.125rem;
    overflow-y: auto;
    position: relative;
    transition: opacity 0.15s;
  }

  .live-demo-hint {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    flex-wrap: wrap;
    font-size: 0.75rem;
    color: var(--color-ink-secondary);
    line-height: 1.35;
    margin: 0 0 0.75rem;
  }

  .live-demo-hint-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-green);
    flex-shrink: 0;
    animation: live-demo-dot-pulse 1.75s ease-in-out infinite;
    will-change: opacity, transform;
  }

  .live-demo-hint-text {
    flex: 1;
    min-width: 0;
  }

  .live-demo-body {
    position: relative;
    flex: 1;
    min-height: 200px;
  }

  .split-pane--preview.is-pending .live-demo-body formspec-render {
    opacity: 0.3;
    filter: blur(1px);
    transition: opacity 0.1s, filter 0.1s;
  }

  .split-pane--preview formspec-render {
    font-size: 0.8125rem;
    transition: opacity 0.2s, filter 0.2s;
  }

  .split-pane--preview .formspec-submit {
    margin-top: 0.75rem;
    padding: 0.5rem 1.25rem;
    font-size: 0.8125rem;
    font-weight: 600;
    border: none;
    border-radius: 6px;
    background: var(--color-accent, #3d52d5);
    color: white;
    cursor: pointer;
    transition: background 0.15s;
  }

  .split-pane--preview .formspec-submit:hover {
    background: #2c42c4;
  }

  /* Loading overlay — scoped to live form body */
  .preview-loading {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    z-index: 2;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s;
    border-radius: 6px;
    background: rgb(240 240 238 / 0.85);
  }

  .split-pane--preview.is-pending .preview-loading {
    opacity: 1;
  }

  .preview-loading span {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    color: #6b7b8d;
    letter-spacing: 0.02em;
  }

  .preview-loading-spinner {
    width: 18px;
    height: 18px;
    border: 2px solid #ddd;
    border-top-color: var(--color-accent, #3d52d5);
    border-radius: 50%;
    animation: hero-spin 0.6s linear infinite;
  }

  @keyframes hero-spin {
    to { transform: rotate(360deg); }
  }

  @keyframes live-demo-dot-pulse {
    0%, 100% {
      opacity: 0.55;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.2);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .live-demo-hint-dot {
      animation: none;
      opacity: 0.9;
      transform: none;
    }
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding-top: 3rem;
    }

    .hero-code {
      min-width: 0;
      max-width: 100%;
    }
  }

  @media (max-width: 600px) {
    .hero-headline {
      font-size: clamp(2rem, 8vw, 2.5rem);
    }

    .split-window-body {
      grid-template-columns: 1fr;
    }

    .split-pane--code {
      border-right: none;
      border-bottom: 1px solid rgb(255 255 255 / 0.07);
      min-height: 200px;
    }
  }
</style>

<script>
  import { FormspecRender, initFormspecEngine } from '@formspec-org/webcomponent';
  import registry from '../../../registries/formspec-common.registry.json';
  import { track } from '../lib/analytics';

  if (!customElements.get('formspec-render')) {
    customElements.define('formspec-render', FormspecRender);
  }

  const initialDef = {
    "$formspec": "1.0",
    "url": "https://formspec.dev/demo/grant-application",
    "title": "Grant Application",
    "items": [
      {
        "type": "field",
        "key": "org_type",
        "dataType": "choice",
        "label": "Organization Type",
        "options": [
          { "value": "nonprofit", "label": "Nonprofit (501c3)" },
          { "value": "government", "label": "Government" },
          { "value": "tribal", "label": "Tribal Organization" }
        ]
      },
      {
        "type": "field", "key": "ein", "dataType": "string",
        "label": "EIN", "extensions": { "x-formspec-ein": true }
      },
      { "type": "field", "key": "amount", "dataType": "money", "label": "Request Amount" },
      { "type": "field", "key": "duration", "dataType": "number", "label": "Duration (months)" },
      { "type": "field", "key": "budget", "dataType": "money", "label": "Monthly Budget" }
    ],
    "binds": [
      { "path": "ein", "relevant": "org_type = 'nonprofit'", "required": "true" },
      { "path": "budget", "calculate": "amount / duration", "readonly": "true" }
    ],
    "formPresentation": { "defaultCurrency": "USD" }
  };

  const form = document.getElementById('hero-form') as FormspecRender | null;
  const editor = document.getElementById('hero-editor') as HTMLTextAreaElement | null;
  const status = document.getElementById('hero-editor-status');
  const previewPane = document.getElementById('hero-preview-pane');

  /** Map definition items → component tree nodes + a SubmitButton at the end. */
  function buildComponentDoc(def: any) {
    const children: any[] = [];
    for (const item of def.items || []) {
      if (item.type === 'field') {
        const dt = item.dataType;
        let component = 'TextInput';
        if (dt === 'choice') component = 'Select';
        else if (dt === 'number') component = 'NumberInput';
        else if (dt === 'money') component = 'MoneyInput';
        else if (dt === 'date') component = 'DatePicker';
        else if (dt === 'boolean') component = 'Toggle';
        children.push({ component, bind: item.key });
      }
    }
    children.push({ component: 'SubmitButton', label: 'Submit Application' });
    return {
      $formspecComponent: '1.0',
      version: '1.0.0',
      targetDefinition: { url: def.url },
      tree: { component: 'Stack', children },
    };
  }

  function applyDefinition(def: any) {
    if (!form) return;
    def.$formspec = def.$formspec || '1.0';
    def.url = def.url || 'https://formspec.dev/demo/grant-application';
    form.registryDocuments = registry;
    form.componentDocument = buildComponentDoc(def);
    form.definition = def;
  }

  function prefillValues() {
    const apply = () => {
      const engine = form?.getEngine?.();
      if (!engine) return;
      engine.setValue('org_type', 'nonprofit');
      engine.setValue('ein', '47-0123456');
      engine.setValue('amount', { amount: 100000, currency: 'USD' });
      engine.setValue('duration', 12);
    };
    // Render is scheduled on a microtask; field `effect()` hooks attach during that pass.
    // Double rAF runs after the following frame so control bindings exist before we setValue.
    requestAnimationFrame(() => {
      requestAnimationFrame(apply);
    });
  }

  function showStatus(type: 'ok' | 'error', text: string) {
    if (!status) return;
    status.textContent = text;
    status.className = 'hero-editor-status ' + type;
    if (type === 'ok') {
      setTimeout(() => { status.className = 'hero-editor-status'; }, 1200);
    }
  }

  function setPending(on: boolean) {
    if (!previewPane) return;
    if (on) {
      previewPane.classList.add('is-pending');
    } else {
      previewPane.classList.remove('is-pending');
    }
  }

  if (editor && form) {
    // Populate textarea with pretty-printed JSON (strip envelope fields for cleaner display)
    const { $formspec, url, ...display } = initialDef;
    editor.value = JSON.stringify(display, null, 2);

    // Live editing — show pending state immediately, debounce the actual render
    let timer: ReturnType<typeof setTimeout>;
    let playgroundTracked = false;
    editor.addEventListener('input', () => {
      if (!playgroundTracked) {
        playgroundTracked = true;
        track('hero_playground_edit');
      }
      clearTimeout(timer);
      setPending(true);
      showStatus('ok', ''); // clear any previous status
      status!.className = 'hero-editor-status'; // hide status while typing

      timer = setTimeout(() => {
        try {
          const parsed = JSON.parse(editor.value);
          applyDefinition(parsed);
          prefillValues();
          setPending(false);
          showStatus('ok', 'Updated');
        } catch {
          setPending(false);
          showStatus('error', 'Invalid JSON');
        }
      }, 600);
    });

    // Tab inserts spaces
    editor.addEventListener('keydown', (e) => {
      if (e.key === 'Tab') {
        e.preventDefault();
        const start = editor.selectionStart;
        const end = editor.selectionEnd;
        editor.value = editor.value.substring(0, start) + '  ' + editor.value.substring(end);
        editor.selectionStart = editor.selectionEnd = start + 2;
        editor.dispatchEvent(new Event('input'));
      }
    });

    void (async () => {
      await initFormspecEngine();
      applyDefinition(initialDef);
      prefillValues();
    })();
  }
</script>
