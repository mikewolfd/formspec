---
// WhatIs — grounding section between Hero and ProofStrip.
// No cards, no grid. A single centered text block that answers
// "wait, what exactly is Formspec?" before the reader scrolls further.
---

<section class="whatis-section" aria-labelledby="whatis-heading">
  <div class="whatis-inner">
    <div class="section-eyebrow" aria-hidden="true">What is Formspec</div>
    <h2 class="whatis-title" id="whatis-heading">
      An open standard for complex forms —<br />
      not another form builder.
    </h2>
    <p class="whatis-body">
      Formspec is a JSON-native specification that defines everything about a form: fields, validation,
      conditional logic, calculated values, page flow, and output mapping. It's technology-agnostic —
      the same definition renders in a browser, validates on a server, and works offline on a phone.
      AI agents can read it, write it, and verify it. Your developers implement it once; your team
      uses it everywhere.
    </p>
  </div>
</section>

<style>
  .whatis-section {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 4.5rem 0;
  }

  .whatis-inner {
    max-width: 44rem;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 2.5rem);
    text-align: center;
  }

  .section-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .whatis-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.25;
    color: var(--color-ink);
    margin: 0 0 1.25rem;
  }

  .whatis-body {
    font-size: 1.0625rem;
    color: var(--color-ink-secondary);
    line-height: 1.75;
    margin: 0;
  }
</style>
