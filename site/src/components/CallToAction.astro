---
// Bottom CTA — close the loop with a clear next action.
// Understated: this isn't a sales page closer, it's an invitation.
---

<section class="cta-section" aria-labelledby="cta-heading">
  <div class="cta-inner">
    <div class="cta-content">
      <h2 class="cta-title" id="cta-heading">Stop building forms by hand.</h2>
      <p class="cta-sub">
        Describe what you need. AI builds it. Automatic validation makes sure it's right.
        One definition deploys to web, React, iOS, and Android. Open source, no vendor lock-in.
        Your team ships in days, not months.
      </p>
      <div class="cta-paths" aria-label="Getting started paths">
        <div class="cta-path">
          <span class="cta-path-label">Formspec Studio</span>
          <span class="cta-path-desc">Visual editor for building, editing, and managing complex forms. Full control over every field, rule, and workflow.</span>
        </div>
        <div class="cta-path">
          <span class="cta-path-label">MCP Server</span>
          <span class="cta-path-desc">28 typed tools that let AI agents build forms through structured tool calls. Add it to Claude Desktop or your IDE in 30 seconds.</span>
        </div>
        <div class="cta-path">
          <span class="cta-path-label">Chat</span>
          <span class="cta-path-desc">AI-powered kickstart. Describe what you need, get a working form in minutes. No install, no IDE.</span>
        </div>
      </div>

      <div class="cta-actions">
        <a href="/studio/" class="cta-btn-primary" data-track="click_try_studio" data-track-section="cta">
          Try Formspec Studio
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2.5 7H11.5M7.5 3L11.5 7L7.5 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/formspec-mcp.mcpb" class="cta-btn-primary cta-btn-mcp" download data-track="click_install_mcp" data-track-section="cta">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M8 1v9m0 0L5 7m3 3l3-3M2 12v1a1 1 0 001 1h10a1 1 0 001-1v-1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Install MCP Server
        </a>
        <a
          href="https://github.com/Formspec-org/formspec"
          class="cta-btn-ghost"
          target="_blank"
          rel="noopener noreferrer"
          data-track="click_github"
          data-track-section="cta"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          View on GitHub
        </a>
        <a
          href="https://github.com/Formspec-org/formspec/tree/main/specs"
          class="cta-btn-ghost"
          target="_blank"
          rel="noopener noreferrer"
        >
          Read the specification
        </a>
      </div>

    </div>
  </div>
</section>

<style>
  .cta-section {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding: 5rem 0;
  }

  .cta-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 2.5rem);
  }

  .cta-content {
    max-width: 44rem;
  }

  .cta-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    margin: 0 0 0.75rem;
  }

  .cta-sub {
    font-size: 1.0625rem;
    color: var(--color-ink-secondary);
    line-height: 1.65;
    margin: 0 0 2rem;
  }

  .cta-paths {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin: 0 0 2rem;
  }

  .cta-path {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem 1.125rem;
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .cta-path-label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: -0.01em;
  }

  .cta-path-desc {
    font-size: 0.8125rem;
    color: var(--color-ink-secondary);
    line-height: 1.55;
  }

  .cta-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .cta-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.625rem 1.25rem;
    border-radius: var(--radius);
    background: var(--color-accent);
    color: white;
    text-decoration: none;
    transition: background-color 0.15s, transform 0.1s;
    box-shadow: 0 1px 2px rgb(61 82 213 / 0.3), 0 0 0 1px rgb(61 82 213 / 0.1);
  }

  .cta-btn-primary:hover {
    background: #2c42c4;
    transform: translateY(-1px);
  }

  .cta-btn-mcp {
    background: #1a1a2e;
    box-shadow: 0 1px 2px rgb(0 0 0 / 0.3), 0 0 0 1px rgb(255 255 255 / 0.08);
  }

  .cta-btn-mcp:hover {
    background: #252540;
  }

  .cta-btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 500;
    padding: 0.625rem 1.25rem;
    border-radius: var(--radius);
    border: 1px solid var(--color-border-strong);
    color: var(--color-ink-secondary);
    text-decoration: none;
    background: var(--color-surface);
    transition: border-color 0.15s, color 0.15s;
  }

  .cta-btn-ghost:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  @media (max-width: 700px) {
    .cta-paths {
      grid-template-columns: 1fr;
    }
  }
</style>
