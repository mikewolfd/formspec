---
// Newsletter signup — calm, centered, minimal.
// Static form for now; action/method will be wired to a service later.
---

<section class="newsletter" aria-labelledby="newsletter-heading">
  <div class="newsletter-inner">
    <div class="newsletter-content">
      <h2 class="newsletter-heading" id="newsletter-heading">Stay in the loop</h2>
      <p class="newsletter-sub">
        Get occasional updates on releases, new features, and community projects.
        No spam.
      </p>

      <form
        class="newsletter-form"
        action="#"
        method="POST"
        aria-label="Email signup"
      >
        <div class="newsletter-row">
          <label for="newsletter-email" class="sr-only">Email address</label>
          <input
            id="newsletter-email"
            class="newsletter-input"
            type="email"
            name="email"
            placeholder="you@example.com"
            autocomplete="email"
            required
            aria-required="true"
          />
          <button class="newsletter-btn" type="submit">
            Subscribe
          </button>
        </div>
      </form>

      <p class="newsletter-fine-print">
        We'll never share your email. Unsubscribe anytime.
      </p>
    </div>
  </div>
</section>

<style>
  .newsletter {
    background: var(--color-surface-raised);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: var(--spacing-section) clamp(1.25rem, 4vw, 2.5rem);
  }

  .newsletter-inner {
    max-width: 72rem;
    margin: 0 auto;
    display: flex;
    justify-content: center;
  }

  .newsletter-content {
    max-width: 36rem;
    text-align: center;
  }

  .newsletter-heading {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    margin: 0 0 0.75rem;
  }

  .newsletter-sub {
    font-size: 1rem;
    color: var(--color-ink-secondary);
    line-height: 1.65;
    margin: 0 0 1.75rem;
  }

  .newsletter-form {
    /* constraint: no Astro template parser issues — pure HTML form */
  }

  .newsletter-row {
    display: flex;
    align-items: stretch;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    background: var(--color-surface);
    /* joined input + button treatment */
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .newsletter-row:focus-within {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgb(61 82 213 / 0.12);
  }

  .newsletter-input {
    flex: 1;
    min-width: 0;
    padding: 0.625rem 1rem;
    font-family: inherit;
    font-size: 0.9375rem;
    color: var(--color-ink);
    background: transparent;
    border: none;
    outline: none;
    /* let the row handle focus ring */
  }

  .newsletter-input::placeholder {
    color: var(--color-ink-tertiary);
  }

  .newsletter-btn {
    flex-shrink: 0;
    padding: 0.625rem 1.25rem;
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    color: white;
    background: var(--color-accent);
    border: none;
    border-left: 1px solid rgb(61 82 213 / 0.3);
    cursor: pointer;
    transition: background-color 0.15s;
    /* slightly right-rounded to match outer border-radius */
    border-radius: 0 calc(var(--radius) - 1px) calc(var(--radius) - 1px) 0;
  }

  .newsletter-btn:hover {
    background: #2c42c4;
  }

  .newsletter-btn:active {
    background: #2438b0;
  }

  .newsletter-fine-print {
    margin: 1rem 0 0;
    font-size: 0.8125rem;
    color: var(--color-ink-tertiary);
    line-height: 1.5;
  }

  /* Screen-reader-only label utility */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 480px) {
    .newsletter-row {
      flex-direction: column;
      border-radius: var(--radius);
    }

    .newsletter-btn {
      border-left: none;
      border-top: 1px solid rgb(61 82 213 / 0.2);
      border-radius: 0 0 calc(var(--radius) - 1px) calc(var(--radius) - 1px);
      padding: 0.75rem 1rem;
    }
  }
</style>
