---
// Proof strip — concrete statements that cut through the pitch.
// The first item leads with the time-saving stat. The rest are specific capabilities.

const hero = {
  headline: "A 200-field form in 20 minutes, not 3 months",
  body: "Traditional form development takes weeks to months — requirements, design, build, test, iterate. Describe what you need to the AI and get a working form with validation, conditional logic, and calculations in a single session.",
  stat: "~100x",
  statLabel: "faster",
};

const points = [
  {
    headline: "Your applicants can't submit invalid budgets",
    body: "Even on a plane. Same validation rules on every platform — web, React, iOS, Android, and server. Five runtimes, one set of rules.",
  },
  {
    headline: "Flag a $50,000 travel budget without blocking the submission",
    body: "Your reviewer sees the warning. Your applicant keeps moving. Errors and warnings are distinct.",
  },
  {
    headline: "Submit once. Get the data in every format your systems need.",
    body: "No re-entry. No export macros. The mapping engine handles transformation.",
  },
  {
    headline: "AI can't produce a form that breaks your rules",
    body: "Every AI-generated form passes through the same validation as human-built forms. Three layers of checks catch errors before anything reaches your users.",
  },
  {
    headline: "WCAG 2.1 AA and Section 508 compliant out of the box",
    body: "Accessibility is built into the behavior layer — ARIA, keyboard navigation, focus management, validation announcements. Every component, every adapter, every design system.",
  },
  {
    headline: "USWDS adapter included — bring any design system",
    body: "Federal agencies get USWDS branding out of the box. The headless adapter architecture lets you plug in Bootstrap, Tailwind, Material, or your own system — same behavior, different DOM.",
  },
  {
    headline: "Built-in i18n — serve applicants in their language",
    body: "Locale sidecar documents add translated labels, help text, and error messages to any form. Add a language by adding a file — never edit the original. Smart fallbacks mean no blank fields, even with partial translations.",
  },
];
---

<div class="proof-strip" aria-label="Key differentiators">
  <div class="proof-inner">
    <div class="proof-hero">
      <div class="proof-stat" aria-label={`${hero.stat} ${hero.statLabel}`}>
        <span class="proof-stat-number">{hero.stat}</span>
        <span class="proof-stat-label">{hero.statLabel}</span>
      </div>
      <div>
        <p class="proof-headline proof-headline--hero">{hero.headline}</p>
        <p class="proof-body">{hero.body}</p>
      </div>
    </div>

    <div class="proof-grid">
      {points.map((s) => (
        <div class="proof-item">
          <p class="proof-headline">{s.headline}</p>
          <p class="proof-body">{s.body}</p>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .proof-strip {
    background: var(--color-surface-raised);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 3.5rem 0;
  }

  .proof-inner {
    max-width: 56rem;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 2.5rem);
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .proof-hero {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .proof-stat {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1;
  }

  .proof-stat-number {
    font-size: 2.25rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-accent);
  }

  .proof-stat-label {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-ink-tertiary);
    margin-top: 0.25rem;
  }

  .proof-headline {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 0.375rem;
    line-height: 1.4;
    letter-spacing: -0.01em;
  }

  .proof-headline--hero {
    font-size: 1.125rem;
  }

  .proof-body {
    font-size: 0.9375rem;
    color: var(--color-ink-secondary);
    line-height: 1.65;
    margin: 0;
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .proof-item {
    padding-left: 1rem;
    border-left: 2px solid var(--color-border);
  }

  @media (max-width: 600px) {
    .proof-hero {
      flex-direction: column;
      gap: 1rem;
    }

    .proof-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
