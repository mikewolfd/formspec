direction: down

spec: {
  label: Formspec Specification
  style: {
    fill: "#f8f9fb"
    stroke: "#8b95b0"
    border-radius: 10
    font-size: 15
    bold: true
  }

  grid-rows: 1
  grid-gap: 16

  s1: "schemas/ (structural truth)" {
    shape: text
    style.font-size: 12
    style.font-color: "#5a6175"
  }
  s2: "specs/ (behavioral truth)" {
    shape: text
    style.font-size: 12
    style.font-color: "#5a6175"
  }
  s3: "FEL grammar (expression truth)" {
    shape: text
    style.font-size: 12
    style.font-color: "#5a6175"
  }
}

ts: {
  label: TypeScript Engine
  style: {
    fill: "#ffffff"
    stroke: "#c4c9d4"
    border-radius: 10
    font-size: 14
    bold: true
  }

  grid-rows: 1
  grid-gap: 16

  s1: "Reactive signals" {shape: text; style.font-size: 12; style.font-color: "#8b95b0"}
  s2: "FEL compiler" {shape: text; style.font-size: 12; style.font-color: "#8b95b0"}
  s3: "Live validation" {shape: text; style.font-size: 12; style.font-color: "#8b95b0"}
}

py: {
  label: Python Implementation
  style: {
    fill: "#ffffff"
    stroke: "#c4c9d4"
    border-radius: 10
    font-size: 14
    bold: true
  }

  grid-rows: 1
  grid-gap: 16

  s1: "CLI & server tooling" {shape: text; style.font-size: 12; style.font-color: "#8b95b0"}
  s2: "FEL compiler" {shape: text; style.font-size: 12; style.font-color: "#8b95b0"}
  s3: "Static linting & mapping" {shape: text; style.font-size: 12; style.font-color: "#8b95b0"}
}

planner: {
  label: Layout Planner
  style: {
    fill: "#f4f5f7"
    stroke: "#c4c9d4"
    border-radius: 10
    font-size: 14
    bold: true
  }

  grid-rows: 1
  grid-gap: 16

  s1: "Theme cascade" {shape: text; style.font-size: 12; style.font-color: "#8b95b0"}
  s2: "Token resolution" {shape: text; style.font-size: 12; style.font-color: "#8b95b0"}
  s3: "Responsive merge" {shape: text; style.font-size: 12; style.font-color: "#8b95b0"}
}

studio: {
  label: Studio Core
  style: {
    fill: "#f4f5f7"
    stroke: "#c4c9d4"
    border-radius: 10
    font-size: 14
    bold: true
  }

  grid-rows: 1
  grid-gap: 16

  s1: "Command model" {shape: text; style.font-size: 12; style.font-color: "#8b95b0"}
  s2: "Queries & diagnostics" {shape: text; style.font-size: 12; style.font-color: "#8b95b0"}
  s3: "Undo/redo, replay" {shape: text; style.font-size: 12; style.font-color: "#8b95b0"}
}

wc: Web Component {
  style.fill: "#ffffff"
  style.stroke: "#c4c9d4"
  style.border-radius: 20
  style.font-size: 12
}

yours: Your renderer {
  style.fill: "#eef1f8"
  style.stroke: "#5a6dc8"
  style.stroke-dash: 5
  style.border-radius: 20
  style.font-size: 12
  style.font-color: "#5a6dc8"
}

mcp: MCP {
  style.fill: "#ffffff"
  style.stroke: "#c4c9d4"
  style.border-radius: 20
  style.font-size: 12
}

chat: Chat {
  style.fill: "#ffffff"
  style.stroke: "#c4c9d4"
  style.border-radius: 20
  style.font-size: 12
}

cli: CLI tool {
  style.fill: "#ffffff"
  style.stroke: "#c4c9d4"
  style.border-radius: 20
  style.font-size: 12
}

studioui: Studio {
  style.fill: "#ffffff"
  style.stroke: "#c4c9d4"
  style.border-radius: 20
  style.font-size: 12
}

llm: LLM {
  style.fill: "#ffffff"
  style.stroke: "#c4c9d4"
  style.border-radius: 20
  style.font-size: 12
}

spec -> ts
spec -> py

ts -> planner: rendering {
  style.font-size: 10
  style.font-color: "#8b95b0"
  style.italic: true
}
ts -> studio: authoring {
  style.font-size: 10
  style.font-color: "#8b95b0"
  style.italic: true
}

planner -> wc
planner -> yours

studio -> mcp
studio -> chat
studio -> cli
studio -> studioui
studio -> llm
