---
import Base from "./Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import {
  DEFAULT_DESCRIPTION,
  createBreadcrumbSchema,
  createOrganizationSchema,
  createWebPageSchema,
  createWebSiteSchema,
  stripSiteName,
  type StructuredData,
} from "../lib/seo";

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  noIndex?: boolean;
  structuredData?: StructuredData | StructuredData[];
}

const props = Astro.props;
const currentPath = Astro.url.pathname;
const pageDescription = props.description ?? DEFAULT_DESCRIPTION;
const customStructuredData = props.structuredData
  ? Array.isArray(props.structuredData)
    ? props.structuredData
    : [props.structuredData]
  : [];
const baseStructuredData = currentPath === "/"
  ? [
      createWebPageSchema({
        title: props.title,
        description: pageDescription,
        pathname: currentPath,
      }),
      createWebSiteSchema(),
      createOrganizationSchema(),
    ]
  : [
      createWebPageSchema({
        title: props.title,
        description: pageDescription,
        pathname: currentPath,
      }),
      createBreadcrumbSchema([
        { name: "Home", path: "/" },
        { name: stripSiteName(props.title), path: currentPath },
      ]),
    ];
const structuredData = [...baseStructuredData, ...customStructuredData];
---

<Base {...props} structuredData={structuredData}>
  <Nav currentPath={currentPath} />
  <main>
    <slot />
  </main>
  <Footer />
</Base>

<style>
  main {
    min-height: calc(100vh - 60px);
  }
</style>
