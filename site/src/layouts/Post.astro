---
import Base from "./Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import {
  createBlogPostingSchema,
  createBreadcrumbSchema,
  createWebPageSchema,
} from "../lib/seo";

export interface Props {
  title: string;
  description: string;
  date: Date;
  author?: string;
  tags?: string[];
}

const { title, description, date, author = "Formspec Team", tags = [] } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const isoDate = date.toISOString();
const currentPath = Astro.url.pathname;
const structuredData = [
  createWebPageSchema({
    title,
    description,
    pathname: currentPath,
    type: "Article",
  }),
  createBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Blog", path: "/blog/" },
    { name: title, path: currentPath },
  ]),
  createBlogPostingSchema({
    title,
    description,
    pathname: currentPath,
    datePublished: isoDate,
    author,
    tags,
  }),
];
---

<Base
  title={title}
  description={description}
  ogType="article"
  articlePublishedTime={isoDate}
  articleModifiedTime={isoDate}
  articleTags={tags}
  structuredData={structuredData}
>
  <Nav currentPath={currentPath} />

  <main class="post-main">
    <article class="post-article">
      <header class="post-header">
        <div class="post-meta">
          <time datetime={isoDate} class="post-date">{formattedDate}</time>
          {tags.length > 0 && (
            <div class="post-tags" aria-label="Tags">
              {tags.map((tag) => (
                <a href={`/blog/tags/${tag}/`} class="post-tag">{tag}</a>
              ))}
            </div>
          )}
        </div>

        <h1 class="post-title">{title}</h1>
        <p class="post-description">{description}</p>

        <div class="post-author">
          <span class="post-author-name">{author}</span>
        </div>
      </header>

      <div class="post-divider" aria-hidden="true"></div>

      <div class="prose post-body">
        <slot />
      </div>
    </article>

    <nav class="post-nav" aria-label="Back to blog">
      <a href="/blog/" class="post-back">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M8.5 2.5L4 7l4.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        All posts
      </a>
    </nav>
  </main>

  <Footer />
</Base>

<style>
  .post-main {
    max-width: 48rem;
    margin: 0 auto;
    padding: 3rem clamp(1.25rem, 4vw, 2.5rem) 5rem;
  }

  .post-article {
    /* structural wrapper */
  }

  .post-header {
    margin-bottom: 2.5rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .post-date {
    font-size: 0.8125rem;
    color: var(--color-ink-tertiary);
    font-weight: 500;
  }

  .post-tags {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .post-tag {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.125rem 0.5rem;
    border-radius: 100px;
    background: var(--color-accent-light);
    color: var(--color-accent);
    text-decoration: none;
    border: 1px solid rgb(61 82 213 / 0.15);
    transition: background-color 0.15s;
  }

  .post-tag:hover { background-color: rgb(61 82 213 / 0.1); }

  .post-title {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    color: var(--color-ink);
    margin: 0 0 1rem;
  }

  .post-description {
    font-size: 1.0625rem;
    color: var(--color-ink-secondary);
    line-height: 1.65;
    margin: 0 0 1.5rem;
  }

  .post-author {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .post-author-name {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink-secondary);
  }

  .post-divider {
    height: 1px;
    background: var(--color-border);
    margin-bottom: 2.5rem;
  }

  .post-body {
    /* prose styles applied via global.css .prose class */
  }

  .post-nav {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .post-back {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink-secondary);
    text-decoration: none;
    transition: color 0.15s;
  }

  .post-back:hover { color: var(--color-accent); }
</style>
