  }

  .arch-header {
    margin-bottom: 3rem;
  }

  .arch-header h1 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    color: var(--color-ink);
    margin: 0 0 1rem;
  }

