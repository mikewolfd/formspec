---
import { getCollection } from "astro:content";
import Page from "../../../layouts/Page.astro";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog", ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  });

  const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags))];

  return allTags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: allPosts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<Page
  title={`Posts tagged "${tag}"`}
  description={`Blog posts tagged with "${tag}" on Formspec.`}
  noIndex={true}
>
  <div class="tag-page">
    <header class="tag-header">
      <nav class="tag-breadcrumb" aria-label="Breadcrumb">
        <a href="/blog/">Blog</a>
        <span aria-hidden="true">/</span>
        <span>Tags</span>
        <span aria-hidden="true">/</span>
        <span aria-current="page">{tag}</span>
      </nav>
      <h1 class="tag-title">
        Posts tagged <span class="tag-name">"{tag}"</span>
      </h1>
      <p class="tag-count">{posts.length} {posts.length === 1 ? "post" : "posts"}</p>
    </header>

    <ol class="post-list">
      {posts.map((post) => {
        const formattedDate = post.data.date.toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
        });

        return (
          <li class="post-item">
            <article>
              <div class="post-item-meta">
                <time datetime={post.data.date.toISOString()} class="post-item-date">
                  {formattedDate}
                </time>
              </div>
              <h2 class="post-item-title">
                <a href={`/blog/${post.id}/`}>{post.data.title}</a>
              </h2>
              <p class="post-item-desc">{post.data.description}</p>
            </article>
          </li>
        );
      })}
    </ol>

    <div class="tag-footer">
      <a href="/blog/" class="tag-back">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M8.5 2.5L4 7l4.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        All posts
      </a>
    </div>
  </div>
</Page>

<style>
  .tag-page {
    max-width: 48rem;
    margin: 0 auto;
    padding: 3rem clamp(1.25rem, 4vw, 2.5rem) 5rem;
  }

  .tag-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .tag-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-ink-tertiary);
    margin-bottom: 1rem;
  }

  .tag-breadcrumb a {
    color: var(--color-ink-secondary);
    text-decoration: none;
    transition: color 0.15s;
  }

  .tag-breadcrumb a:hover { color: var(--color-accent); }

  .tag-title {
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0 0 0.5rem;
  }

  .tag-name {
    color: var(--color-accent);
  }

  .tag-count {
    font-size: 0.875rem;
    color: var(--color-ink-tertiary);
    margin: 0;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-item {
    padding: 1.875rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-item:first-child { padding-top: 0; }

  .post-item-meta {
    margin-bottom: 0.5rem;
  }

  .post-item-date {
    font-size: 0.8125rem;
    color: var(--color-ink-tertiary);
    font-weight: 500;
  }

  .post-item-title {
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin: 0 0 0.5rem;
  }

  .post-item-title a {
    color: var(--color-ink);
    text-decoration: none;
    transition: color 0.15s;
  }

  .post-item-title a:hover { color: var(--color-accent); }

  .post-item-desc {
    font-size: 0.9375rem;
    color: var(--color-ink-secondary);
    line-height: 1.65;
    margin: 0;
  }

  .tag-footer {
    margin-top: 2.5rem;
  }

  .tag-back {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink-secondary);
    text-decoration: none;
    transition: color 0.15s;
  }

  .tag-back:hover { color: var(--color-accent); }
</style>
