---
import { getCollection } from "astro:content";
import Page from "../../layouts/Page.astro";

const allPosts = await getCollection("blog", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Collect all tags
const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<Page
  title="Blog"
  description="Updates, deep dives, and design notes from the Formspec project."
>
  <div class="blog-index">
    <header class="blog-header">
      <h1 class="blog-title">Blog</h1>
      <p class="blog-sub">Updates, deep dives, and design notes from the Formspec project.</p>

      {allTags.length > 0 && (
        <div class="blog-tags" aria-label="Filter by tag">
          {allTags.map((tag) => (
            <a href={`/blog/tags/${tag}/`} class="blog-tag">{tag}</a>
          ))}
        </div>
      )}
    </header>

    {posts.length === 0 ? (
      <div class="blog-empty">
        <p>No posts yet. Check back soon.</p>
      </div>
    ) : (
      <ol class="post-list" reversed>
        {posts.map((post) => {
          const formattedDate = post.data.date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          });

          return (
            <li class="post-item">
              <article>
                <div class="post-item-meta">
                  <time datetime={post.data.date.toISOString()} class="post-item-date">
                    {formattedDate}
                  </time>
                  {post.data.tags.length > 0 && (
                    <div class="post-item-tags" aria-label="Tags">
                      {post.data.tags.map((tag) => (
                        <a href={`/blog/tags/${tag}/`} class="post-item-tag">{tag}</a>
                      ))}
                    </div>
                  )}
                </div>
                <h2 class="post-item-title">
                  <a href={`/blog/${post.id}/`}>{post.data.title}</a>
                </h2>
                <p class="post-item-desc">{post.data.description}</p>
                <div class="post-item-footer">
                  <span class="post-item-author">{post.data.author}</span>
                </div>
              </article>
            </li>
          );
        })}
      </ol>
    )}
  </div>
</Page>

<style>
  .blog-index {
    max-width: 48rem;
    margin: 0 auto;
    padding: 3rem clamp(1.25rem, 4vw, 2.5rem) 5rem;
  }

  .blog-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .blog-title {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    margin: 0 0 0.625rem;
  }

  .blog-sub {
    font-size: 1.0625rem;
    color: var(--color-ink-secondary);
    margin: 0 0 1.5rem;
    line-height: 1.65;
  }

  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .blog-tag {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.25rem 0.625rem;
    border-radius: 100px;
    border: 1px solid var(--color-border);
    color: var(--color-ink-secondary);
    text-decoration: none;
    background: var(--color-surface);
    transition: border-color 0.15s, color 0.15s;
  }

  .blog-tag:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .blog-empty {
    text-align: center;
    color: var(--color-ink-tertiary);
    padding: 3rem 0;
    font-size: 0.9375rem;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post-item {
    padding: 1.875rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-item:first-child {
    padding-top: 0;
  }

  .post-item-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.625rem;
    flex-wrap: wrap;
  }

  .post-item-date {
    font-size: 0.8125rem;
    color: var(--color-ink-tertiary);
    font-weight: 500;
  }

  .post-item-tags {
    display: flex;
    gap: 0.25rem;
    flex-wrap: wrap;
  }

  .post-item-tag {
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.1rem 0.4rem;
    border-radius: 100px;
    background: var(--color-accent-light);
    color: var(--color-accent);
    text-decoration: none;
    border: 1px solid rgb(61 82 213 / 0.12);
    transition: background-color 0.15s;
  }

  .post-item-tag:hover { background-color: rgb(61 82 213 / 0.1); }

  .post-item-title {
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin: 0 0 0.5rem;
  }

  .post-item-title a {
    color: var(--color-ink);
    text-decoration: none;
    transition: color 0.15s;
  }

  .post-item-title a:hover { color: var(--color-accent); }

  .post-item-desc {
    font-size: 0.9375rem;
    color: var(--color-ink-secondary);
    line-height: 1.65;
    margin: 0 0 0.875rem;
  }

  .post-item-footer {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .post-item-author {
    font-size: 0.8125rem;
    color: var(--color-ink-tertiary);
    font-weight: 500;
  }
</style>
