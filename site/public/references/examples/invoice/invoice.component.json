{
  "$formspecComponent": "1.0",
  "version": "1.0.0",
  "name": "invoice-component",
  "title": "Invoice Layout",
  "targetDefinition": {
    "url": "https://formspec.org/examples/invoice",
    "compatibleVersions": ">=1.0.0 <2.0.0"
  },
  "tree": {
    "component": "Stack",
    "gap": "24px",
    "children": [
      {
        "component": "Card",
        "title": "Invoice Details",
        "children": [
          {
            "component": "Grid",
            "columns": 2,
            "gap": "16px",
            "children": [
              { "component": "TextInput", "bind": "header.invoiceNumber" },
              { "component": "TextInput", "bind": "header.customerName" },
              { "component": "DatePicker", "bind": "header.invoiceDate" },
              { "component": "DatePicker", "bind": "header.dueDate" },
              { "component": "TextInput", "bind": "header.customerEmail" },
              { "component": "Spacer" }
            ]
          }
        ]
      },
      {
        "component": "Card",
        "title": "Line Items",
        "subtitle": "Add one row per billable item. Line totals and invoice totals are calculated automatically.",
        "children": [
          {
            "component": "DataTable",
            "bind": "lineItems",
            "allowAdd": true,
            "allowRemove": true,
            "showRowNumbers": true,
            "columns": [
              { "header": "Description", "bind": "itemDescription" },
              { "header": "Qty", "bind": "quantity", "min": 0, "step": 1 },
              { "header": "Unit Price", "bind": "unitPrice", "min": 0, "step": 0.01 },
              { "header": "Line Total", "bind": "lineTotal" }
            ]
          }
        ]
      },
      {
        "component": "Card",
        "title": "Totals",
        "children": [
          {
            "component": "Grid",
            "columns": 2,
            "gap": "16px",
            "children": [
              { "component": "MoneyInput", "bind": "totals.subtotal", "currency": "USD", "showCurrency": true },
              { "component": "NumberInput", "bind": "totals.taxRate", "step": 0.01, "min": 0, "max": 100, "showStepper": true },
              { "component": "MoneyInput", "bind": "totals.taxAmount", "currency": "USD", "showCurrency": true },
              { "component": "NumberInput", "bind": "totals.discountPercent", "step": 0.01, "min": 0, "max": 100, "showStepper": true },
              { "component": "MoneyInput", "bind": "totals.discountAmount", "currency": "USD", "showCurrency": true },
              { "component": "MoneyInput", "bind": "totals.grandTotal", "currency": "USD", "showCurrency": true }
            ]
          }
        ]
      },
      {
        "component": "Card",
        "title": "Notes",
        "children": [
          { "component": "TextInput", "bind": "notes", "maxLines": 4 }
        ]
      },
      {
        "component": "Card",
        "title": "Review & Submit",
        "children": [
          {
            "component": "ValidationSummary",
            "source": "live",
            "mode": "submit",
            "showFieldErrors": true,
            "jumpLinks": true
          },
          {
            "component": "SubmitButton",
            "label": "Submit Invoice",
            "mode": "submit",
            "emitEvent": true,
            "pendingLabel": "Submitting..."
          }
        ]
      }
    ]
  }
}
