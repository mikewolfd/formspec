  "formPresentation": {
    "pageMode": "wizard",
    "showProgress": true
  },
  "binds": [
    {
      "path": "employee_information.first_name",
      "required": "true"
    },
    {
      "path": "employee_information.last_name",
      "required": "true"
    },
    {
      "path": "employee_information.employee_id",
      "required": "true"
    },
    {
      "path": "employee_information.personal_email",
      "required": "true",
      "constraint": "matches($, '^[^\\\\s@]+@[^\\\\s@]+\\\\.[^\\\\s@]+$')"
    },
    {
      "path": "employee_information.phone",
      "required": "true",
      "constraint": "matches($, '^[+]?[0-9\\\\s\\\\-().]+$')"
    },
    {
      "path": "employee_information.start_date",
      "required": "true"
    },
    {
      "path": "employee_information.manager_name",
      "required": "true"
    },
    {
      "path": "department_role.department",
      "required": "true"
    },
    {
      "path": "department_role.job_title",
      "required": "true"
    },
    {
      "path": "department_role.employment_type",
      "required": "true"
    },
    {
      "path": "department_role.work_location",
      "required": "true"
    },
    {
      "path": "equipment_checklist.manufacturing_equipment",
      "relevant": "$department_role.department = 'manufacturing'"
    },
    {
      "path": "equipment_checklist.office_equipment",
      "relevant": "$department_role.department = 'office'"
    },
    {
      "path": "equipment_checklist.it_equipment",
      "relevant": "$department_role.department = 'it'"
    },
    {
      "path": "equipment_checklist.warehouse_equipment",
      "relevant": "$department_role.department = 'warehouse'"
    },
    {
      "path": "training_modules.common_training.harassment_prevention",
      "required": "true"
    },
    {
      "path": "training_modules.common_training.safety_orientation",
      "required": "true"
    },
    {
      "path": "training_modules.common_training.it_security",
      "required": "true"
    },
    {
      "path": "training_modules.common_training.handbook_review",
      "required": "true"
    },
    {
      "path": "training_modules.manufacturing_training",
      "relevant": "$department_role.department = 'manufacturing'"
    },
    {
      "path": "training_modules.office_training",
      "relevant": "$department_role.department = 'office'"
    },
    {
      "path": "training_modules.it_training",
      "relevant": "$department_role.department = 'it'"
    },
    {
      "path": "training_modules.warehouse_training",
