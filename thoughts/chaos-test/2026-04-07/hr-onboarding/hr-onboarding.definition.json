    {
      "key": "compliance_documents",
      "type": "group",
      "label": "Compliance Documents",
      "children": [
        {
          "key": "common_compliance",
          "type": "group",
          "label": "All Employees — Required Compliance Documents",
          "children": [
            {
              "key": "i9_completed",
              "type": "field",
              "label": "I-9 Employment Eligibility Verification (completed)",
              "dataType": "boolean",
              "presentation": {
                "widgetHint": "toggle"
              },
              "hint": "Check only after the I-9 form has been fully completed, reviewed, and filed."
