    {
      "key": "confirmation",
      "type": "group",
      "label": "Confirmation",
      "children": [
        {
          "key": "review_heading",
          "type": "display",
          "label": "Review & Submit",
          "presentation": {
            "widgetHint": "heading"
          }
        },
        {
          "key": "review_instructions",
          "type": "display",
          "label": "Please review all sections of this onboarding checklist before submitting. By signing below, you confirm that all items marked as completed have been issued, reviewed, or acknowledged by the employee named above.",
          "presentation": {
            "widgetHint": "paragraph"
          }
        },
        {
          "key": "hr_representative_name",
          "type": "field",
          "label": "HR Representative Name",
          "dataType": "string"
        },
        {
          "key": "hr_signature_date",
          "type": "field",
          "label": "Date Completed",
          "dataType": "date",
          "presentation": {
            "widgetHint": "datePicker"
          },
          "initialValue": "=today()"
        },
        {
          "key": "additional_notes",
          "type": "field",
          "label": "Additional Notes",
          "dataType": "text",
          "hint": "Any follow-up items, exceptions, or notes for this employee's onboarding",
          "presentation": {
            "widgetHint": "textarea"
          }
        }
      ]
