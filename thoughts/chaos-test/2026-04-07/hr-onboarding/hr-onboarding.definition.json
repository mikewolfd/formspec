{
  "$formspec": "1.0",
  "url": "urn:formspec:cmh0lzqu",
  "version": "0.1.0",
  "status": "draft",
  "title": "Employee Onboarding Checklist",
  "items": [
    {
      "key": "employee_information",
      "type": "group",
      "label": "Employee Information",
      "children": [
        {
          "key": "first_name",
          "type": "field",
          "label": "First Name",
          "dataType": "string"
        },
        {
          "key": "last_name",
          "type": "field",
          "label": "Last Name",
          "dataType": "string"
        },
        {
          "key": "employee_id",
          "type": "field",
          "label": "Employee ID",
          "dataType": "string",
          "hint": "Assigned by HR — format: EMP-XXXXX"
        },
        {
          "key": "personal_email",
          "type": "field",
          "label": "Personal Email Address",
          "dataType": "string"
        },
        {
          "key": "phone",
          "type": "field",
          "label": "Phone Number",
          "dataType": "string"
        },
        {
          "key": "start_date",
          "type": "field",
          "label": "Start Date",
          "dataType": "date",
          "presentation": {
            "widgetHint": "datePicker"
          }
        },
        {
          "key": "manager_name",
          "type": "field",
          "label": "Hiring Manager Name",
          "dataType": "string"
        }
      ]
    },
    {
      "key": "department_role",
      "type": "group",
      "label": "Department & Role",
      "children": [
        {
          "key": "department",
          "type": "field",
          "label": "Department",
          "dataType": "choice",
          "presentation": {
            "widgetHint": "dropdown"
          },
          "options": [
            {
              "value": "manufacturing",
              "label": "Manufacturing Floor"
            },
            {
              "value": "office",
              "label": "Office / Administration"
            },
            {
              "value": "it",
              "label": "Information Technology"
            },
            {
              "value": "warehouse",
              "label": "Warehouse / Logistics"
            }
          ],
          "hint": "The department selected here determines which equipment, training, and compliance sections appear in later pages."
        },
        {
          "key": "job_title",
          "type": "field",
          "label": "Job Title",
          "dataType": "string"
        },
        {
          "key": "employment_type",
          "type": "field",
          "label": "Employment Type",
          "dataType": "choice",
          "presentation": {
            "widgetHint": "dropdown"
          },
          "options": [
            {
              "value": "full_time",
              "label": "Full-Time"
            },
            {
              "value": "part_time",
              "label": "Part-Time"
            },
            {
              "value": "contract",
              "label": "Contract"
            },
            {
              "value": "temp",
              "label": "Temporary"
            }
          ]
        },
        {
          "key": "work_location",
          "type": "field",
          "label": "Work Location / Shift",
          "dataType": "string",
          "hint": "e.g., Building A - Day Shift, Remote, Main Office"
        }
      ]
    },
