      "constraint": "matches($, '^[+]?[0-9\\\\s\\\\-().]+$')",
      "required": "true"
    },
    {
      "path": "emergency_contact_phone",
      "constraint": "matches($, '^[+]?[0-9\\\\s\\\\-().]+$')"
