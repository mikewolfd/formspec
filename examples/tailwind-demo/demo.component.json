{
  "$formspecComponent": "1.0",
  "version": "1.0.0",
  "name": "tailwind-demo-layout",
  "title": "Tailwind Demo Layout",
  "targetDefinition": {
    "url": "https://formspec.org/examples/tailwind-demo",
    "compatibleVersions": ">=1.0.0 <2.0.0"
  },
  "tree": {
    "component": "Stack",
    "gap": "28px",
    "children": [
      {
        "component": "Card",
        "title": "Profile",
        "subtitle": "Basics we use to personalize the demo workspace.",
        "children": [
          {
            "component": "Grid",
            "columns": 2,
            "gap": "20px",
            "children": [
              { "component": "TextInput", "bind": "profile.fullName" },
              { "component": "TextInput", "bind": "profile.email" },
              { "component": "Select", "bind": "profile.role" },
              { "component": "DatePicker", "bind": "profile.startDate" }
            ]
          }
        ]
      },
      {
        "component": "Card",
        "title": "Experience",
        "subtitle": "Slider, multi-select, and a short narrative — all Tailwind-styled.",
        "children": [
          {
            "component": "Stack",
            "gap": "20px",
            "children": [
              { "component": "Slider", "bind": "experience.years" },
              { "component": "CheckboxGroup", "bind": "experience.skills" },
              { "component": "TextInput", "bind": "experience.bio", "maxLines": 4 }
            ]
          }
        ]
      },
      {
        "component": "Card",
        "title": "Feedback",
        "subtitle": "Toggle and a star rating row from the adapter.",
        "children": [
          {
            "component": "Grid",
            "columns": 2,
            "gap": "20px",
            "children": [
              {
                "component": "Toggle",
                "bind": "feedback.newsletter",
                "onLabel": "Subscribed",
                "offLabel": "Not subscribed"
              },
              { "component": "Rating", "bind": "feedback.satisfaction" }
            ]
          }
        ]
      },
      {
        "component": "Card",
        "title": "Review",
        "children": [
          {
            "component": "ValidationSummary",
            "source": "live",
            "mode": "submit",
            "showFieldErrors": true,
            "jumpLinks": true
          },
          {
            "component": "SubmitButton",
            "label": "Submit demo",
            "mode": "submit",
            "emitEvent": true,
            "pendingLabel": "Sending…"
          }
        ]
      }
    ]
  }
}
