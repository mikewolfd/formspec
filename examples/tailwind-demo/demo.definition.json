{
  "$formspec": "1.0",
  "url": "https://formspec.org/examples/tailwind-demo",
  "version": "1.0.0",
  "status": "active",
  "name": "tailwind-demo",
  "title": "Tailwind Adapter Demo Form",
  "description": "Small canonical demo form for exercising the Tailwind adapter with common input widgets and lightweight validation.",
  "formPresentation": {
    "pageMode": "single",
    "labelPosition": "top",
    "density": "comfortable"
  },
  "items": [
    {
      "key": "profile",
      "type": "group",
      "label": "Profile",
      "children": [
        {
          "key": "fullName",
          "type": "field",
          "dataType": "string",
          "label": "Full Name",
          "description": "Enter the name you want displayed on the demo profile."
        },
        {
          "key": "email",
          "type": "field",
          "dataType": "string",
          "label": "Email Address"
        },
        {
          "key": "role",
          "type": "field",
          "dataType": "choice",
          "label": "Primary Role",
          "options": [
            { "value": "engineer", "label": "Engineer" },
            { "value": "designer", "label": "Designer" },
            { "value": "product", "label": "Product" },
            { "value": "operations", "label": "Operations" }
          ]
        },
        {
          "key": "startDate",
          "type": "field",
          "dataType": "date",
          "label": "Start Date"
        }
      ]
    },
    {
      "key": "experience",
      "type": "group",
      "label": "Experience",
      "children": [
        {
          "key": "years",
          "type": "field",
          "dataType": "integer",
          "label": "Years of Experience",
          "initialValue": 3
        },
        {
          "key": "skills",
          "type": "field",
          "dataType": "multiChoice",
          "label": "Favorite Tools",
          "options": [
            { "value": "tailwind", "label": "Tailwind CSS" },
            { "value": "react", "label": "React" },
            { "value": "typescript", "label": "TypeScript" },
            { "value": "a11y", "label": "Accessibility Testing" }
          ]
        },
        {
          "key": "bio",
          "type": "field",
          "dataType": "text",
          "label": "Short Bio",
          "hint": "A few sentences is enough for the demo."
        }
      ]
    },
    {
      "key": "feedback",
      "type": "group",
      "label": "Feedback",
      "children": [
        {
          "key": "newsletter",
          "type": "field",
          "dataType": "boolean",
          "label": "Subscribe to release notes"
        },
        {
          "key": "satisfaction",
          "type": "field",
          "dataType": "integer",
          "label": "Overall Satisfaction",
          "initialValue": 4
        }
      ]
    }
  ],
  "binds": [
    {
      "path": "profile.fullName",
      "required": "true",
      "whitespace": "trim"
    },
    {
      "path": "profile.email",
      "required": "true",
      "whitespace": "trim"
    },
    {
      "path": "experience.years",
      "constraint": "isNull($) or ($ >= 0 and $ <= 40)",
      "constraintMessage": "Years of experience must be between 0 and 40."
    },
    {
      "path": "feedback.satisfaction",
      "constraint": "isNull($) or ($ >= 1 and $ <= 5)",
      "constraintMessage": "Satisfaction must be between 1 and 5."
    }
  ]
}
