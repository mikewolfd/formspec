{
  "$formspecTheme": "1.0",
  "url": "https://formspec.org/examples/tailwind-demo/theme",
  "version": "1.0.0",
  "name": "tailwind-demo",
  "title": "Tailwind CSS — studio theme",
  "description": "Reference theme for the Tailwind adapter: utility classes, layered cards, slider, rating, and multi-select. Fonts and Tailwind utilities are bundled by the host app (Vite + @tailwindcss/vite), not the Play CDN.",
  "targetDefinition": {
    "url": "https://formspec.org/examples/tailwind-demo",
    "compatibleVersions": ">=1.0.0 <2.0.0"
  },
  "platform": "web",
  "stylesheets": [],
  "breakpoints": {
    "sm": 640,
    "md": 768,
    "lg": 1024
  },
  "tokens": {
    "color.primary": "#0d9488",
    "color.primary.dark": "#0f766e",
    "color.primary.light": "#ccfbf1",
    "color.secondary": "#7c3aed",
    "color.secondary.light": "#ede9fe",
    "color.error": "#dc2626",
    "color.warning": "#d97706",
    "color.success": "#16a34a",
    "color.background": "#f4f4f5",
    "color.surface": "#ffffff",
    "color.text": "#18181b",
    "color.text.secondary": "#71717a",
    "spacing.xs": "0.25rem",
    "spacing.sm": "0.5rem",
    "spacing.md": "1rem",
    "spacing.lg": "1.5rem",
    "spacing.xl": "2rem",
    "spacing.xxl": "3rem",
    "typography.family": "'Outfit', system-ui, sans-serif",
    "typography.family.display": "'Syne', system-ui, sans-serif",
    "typography.size.body": "0.9375rem",
    "typography.size.sm": "0.8125rem",
    "typography.size.lg": "1.125rem",
    "typography.size.xl": "1.375rem",
    "typography.weight.normal": "400",
    "typography.weight.bold": "600",
    "border.radius": "0.75rem",
    "border.width": "1px",
    "border.color": "#e4e4e7"
  },
  "defaults": {
    "labelPosition": "top",
    "style": {
      "fontFamily": "$token.typography.family"
    }
  },
  "items": {
    "experience.years": {
      "widget": "slider",
      "widgetConfig": {
        "min": 0,
        "max": 40,
        "step": 1,
        "showValue": true
      }
    },
    "feedback.satisfaction": {
      "widget": "rating",
      "widgetConfig": {
        "max": 5,
        "icon": "star"
      }
    },
    "experience.skills": {
      "widgetConfig": {
        "columns": 2
      }
    }
  },
  "selectors": [
    {
      "match": { "dataType": "string" },
      "apply": { "widget": "textInput" }
    },
    {
      "match": { "dataType": "text" },
      "apply": { "widget": "textarea", "widgetConfig": { "rows": 4 } }
    },
    {
      "match": { "dataType": "choice" },
      "apply": { "widget": "dropdown" }
    },
    {
      "match": { "dataType": "multiChoice" },
      "apply": { "widget": "checkboxGroup" }
    },
    {
      "match": { "dataType": "boolean" },
      "apply": { "widget": "toggle" }
    },
    {
      "match": { "dataType": "date" },
      "apply": { "widget": "datePicker" }
    },
    {
      "match": { "dataType": "integer" },
      "apply": { "widget": "numberInput" }
    }
  ]
}
