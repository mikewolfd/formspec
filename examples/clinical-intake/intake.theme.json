{
  "$formspecTheme": "1.0",
  "version": "1.0.0",
  "name": "clinical-intake-theme",
  "title": "Clinical Intake Theme",
  "platform": "web",
  "targetDefinition": {
    "url": "https://formspec.org/examples/clinical-intake",
    "compatibleVersions": ">=1.0.0 <2.0.0"
  },
  "tokens": {
    "color.primary": "#0369a1",
    "color.primaryDark": "#0c4a6e",
    "color.primaryLight": "#e0f2fe",
    "color.success": "#16a34a",
    "color.warning": "#ea580c",
    "color.error": "#dc2626",
    "color.neutral50": "#f8fafc",
    "color.neutral100": "#f1f5f9",
    "color.neutral200": "#e2e8f0",
    "color.neutral700": "#334155",
    "color.text": "#0f172a",
    "space.sm": "8px",
    "space.md": "16px",
    "space.lg": "24px",
    "radius.sm": "8px",
    "radius.md": "12px",
    "type.fontFamily": "ui-sans-serif, system-ui, -apple-system, 'Segoe UI', sans-serif",
    "type.baseSize": "16px"
  },
  "defaults": {
    "labelPosition": "top"
  }
}
