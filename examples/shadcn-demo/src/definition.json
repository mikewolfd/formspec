{
  "$formspec": "1.0",
  "url": "https://example.com/forms/shadcn-demo",
  "version": "1.0.0",
  "status": "active",
  "title": "shadcn Adapter Showcase",
  "description": "Demonstrates field types rendered through the shadcn/React adapter.",
  "name": "shadcn-demo",
  "formPresentation": {
    "labelPosition": "top",
    "density": "comfortable"
  },
  "items": [
    {
      "key": "contactInfo",
      "type": "group",
      "label": "Contact Information",
      "items": [
        {
          "key": "fullName",
          "type": "field",
          "dataType": "string",
          "label": "Full Name",
          "hint": "Enter your first and last name."
        },
        {
          "key": "email",
          "type": "field",
          "dataType": "string",
          "label": "Email Address"
        },
        {
          "key": "phone",
          "type": "field",
          "dataType": "string",
          "label": "Phone Number",
          "hint": "Optional — we'll only use this for urgent follow-ups."
        },
        {
          "key": "age",
          "type": "field",
          "dataType": "integer",
          "label": "Age"
        },
        {
          "key": "dob",
          "type": "field",
          "dataType": "date",
          "label": "Date of Birth"
        }
      ]
    },
    {
      "key": "preferences",
      "type": "group",
      "label": "Preferences",
      "items": [
        {
          "key": "role",
          "type": "field",
          "dataType": "choice",
          "label": "Primary Role",
          "hint": "Pick the role that best describes you.",
          "options": [
            { "value": "developer", "label": "Developer" },
            { "value": "designer", "label": "Designer" },
            { "value": "manager", "label": "Product Manager" },
            { "value": "other", "label": "Other" }
          ]
        },
        {
          "key": "interests",
          "type": "field",
          "dataType": "multiChoice",
          "label": "Areas of Interest",
          "hint": "Select all that apply.",
          "options": [
            { "value": "frontend", "label": "Frontend" },
            { "value": "backend", "label": "Backend" },
            { "value": "devops", "label": "DevOps" },
            { "value": "ai", "label": "AI / ML" },
            { "value": "design", "label": "Design Systems" }
          ]
        },
        {
          "key": "newsletter",
          "type": "field",
          "dataType": "boolean",
          "label": "Subscribe to newsletter"
        }
      ]
    },
    {
      "key": "details",
      "type": "group",
      "label": "Details",
      "items": [
        {
          "key": "bio",
          "type": "field",
          "dataType": "text",
          "label": "Bio",
          "hint": "Tell us about yourself in a few sentences."
        },
        {
          "key": "resume",
          "type": "field",
          "dataType": "attachment",
          "label": "Upload Resume",
          "hint": "PDF, DOCX, or TXT files accepted."
        }
      ]
    }
  ],
  "binds": [
    { "path": "contactInfo.fullName", "required": "true" },
    { "path": "contactInfo.email", "required": "true" },
    { "path": "preferences.role", "required": "true" },
    { "path": "contactInfo.age", "constraint": ". >= 0 and . <= 150" }
  ]
}
