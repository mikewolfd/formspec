{
    "$formspecTheme": "1.0",
    "version": "1.0.0",
    "targetDefinition": {
        "url": "https://acf.hhs.gov/formspec/csbg/tribal-short",
        "compatibleVersions": ">=3.0.0 <4.0.0"
    },
    "description": "USWDS-aligned theme for CSBG grant forms. Uses US Web Design System tokens and Public Sans typeface.",
    "tokens": {
        "color.primary": "#005EA2",
        "color.primaryDark": "#1A4480",
        "color.primaryLight": "#D9E8F6",
        "color.error": "#B50909",
        "color.warning": "#D39900",
        "color.success": "#008817",
        "color.info": "#00BDE3",
        "color.background": "#F0F0F0",
        "color.surface": "#FFFFFF",
        "color.border": "#A9AEB1",
        "color.text": "#1B1B1B",
        "color.textMuted": "#565C65",
        "spacing.xs": "4px",
        "spacing.sm": "8px",
        "spacing.md": "16px",
        "spacing.lg": "24px",
        "spacing.xl": "32px",
        "typography.fontFamily": "'Public Sans', -apple-system, BlinkMacSystemFont, sans-serif",
        "typography.monoFamily": "'Roboto Mono', 'Courier New', monospace",
        "border.radius": "4px",
        "border.width": "1px"
    },
    "defaults": {
        "labelPosition": "top",
        "style": {
            "fontFamily": "$token.typography.fontFamily",
            "fontSize": "1rem",
            "color": "$token.color.text"
        }
    },
    "selectors": [
        {
            "match": {
                "dataType": "decimal"
            },
            "apply": {
                "style": {
                    "textAlign": "right",
                    "fontFamily": "$token.typography.monoFamily"
                }
            }
        },
        {
            "match": {
                "dataType": "integer"
            },
            "apply": {
                "style": {
                    "textAlign": "right",
                    "fontFamily": "$token.typography.monoFamily"
                }
            }
        }
    ],
    "items": {
        "expenditures.total": {
            "style": {
                "fontWeight": "bold",
                "borderTop": "2px solid $token.color.border"
            }
        }
    }
}