{
    "$formspecComponent": "1.0",
    "version": "1.0.4",
    "targetDefinition": {
        "url": "https://acf.hhs.gov/formspec/csbg/tribal-long",
        "compatibleVersions": ">=3.0.0 <4.0.0"
    },
    "tree": {
        "component": "Wizard",
        "children": [
            {
                "component": "Page",
                "title": "Basic Information",
                "children": [
                    {
                        "component": "Card",
                        "title": "Tribal Organization",
                        "children": [
                            { "component": "Heading", "text": "Tribal Organization", "level": 3 },
                            { "component": "TextInput", "bind": "basicInfo.orgName" }
                        ]
                    },
                    {
                        "component": "Card",
                        "title": "CSBG Program Contact",
                        "children": [
                            { "component": "Heading", "text": "CSBG Program Contact", "level": 3 },
                            { "component": "TextInput", "bind": "basicInfo.contactName" },
                            { "component": "TextInput", "bind": "basicInfo.contactTitle" },
                            { "component": "TextInput", "bind": "basicInfo.phone" },
                            { "component": "TextInput", "bind": "basicInfo.email" }
                        ]
                    }
                ]
            },
            {
                "component": "Page",
                "title": "Expenditure Categories",
                "children": [
                    {
                        "component": "Card",
                        "title": "Select Applicable Topics",
                        "children": [
                            { "component": "CheckboxGroup", "bind": "applicableTopics" }
                        ]
                    },
                    {
                        "component": "Card",
                        "title": "Expenditure Amounts",
                        "children": [
                            { "component": "Text", "text": "Provide the amounts for each selected category." },
                            { "component": "MoneyInput", "bind": "expenditures.employment", "when": "selected($applicableTopics, 'employment')", "min": 0, "step": 0.01 },
                            { "component": "MoneyInput", "bind": "expenditures.childcare", "when": "selected($applicableTopics, 'childcare')", "min": 0, "step": 0.01 },
                            { "component": "MoneyInput", "bind": "expenditures.assetBuilding", "when": "selected($applicableTopics, 'assetBuilding')", "min": 0, "step": 0.01 },
                            { "component": "MoneyInput", "bind": "expenditures.housing", "when": "selected($applicableTopics, 'housing')", "min": 0, "step": 0.01 },
                            { "component": "MoneyInput", "bind": "expenditures.health", "when": "selected($applicableTopics, 'health')", "min": 0, "step": 0.01 },
                            { "component": "MoneyInput", "bind": "expenditures.civic", "when": "selected($applicableTopics, 'civic')", "min": 0, "step": 0.01 },
                            { "component": "MoneyInput", "bind": "expenditures.transportation", "when": "selected($applicableTopics, 'transportation')", "min": 0, "step": 0.01 },
                            { "component": "MoneyInput", "bind": "expenditures.partnerships", "when": "selected($applicableTopics, 'partnerships')", "min": 0, "step": 0.01 },
                            { "component": "MoneyInput", "bind": "expenditures.other", "when": "selected($applicableTopics, 'other')", "min": 0, "step": 0.01 },
                            { "component": "Divider" },
                            { "component": "MoneyInput", "bind": "expenditures.total", "min": 0, "step": 0.01 }
                        ]
                    },
                    {
                        "component": "Card",
                        "title": "Administration Costs",
                        "children": [
                            { "component": "Text", "text": "To learn more about what qualifies as Administration costs, refer to guidance IM37." },
                            { "component": "Toggle", "bind": "hasAdministrationCosts" },
                            { "component": "MoneyInput", "bind": "administrationExpenditure", "when": "$hasAdministrationCosts = true", "min": 0, "step": 0.01 }
                        ]
                    }
                ]
            },
            {
                "component": "Page",
                "title": "Expenditure Details",
                "children": [
                    {
                        "component": "Stack",
                        "children": [
                            {
                                "component": "Card",
                                "when": "selected($applicableTopics, 'employment')",
                                "title": "Details on employment services",
                                "children": [
                                    { "component": "Text", "text": "Describe all employment related services, such as support for job placement, vocational and skill training, job development and eliminating barriers to work." },
                                    { "component": "TextInput", "bind": "descriptions.employmentDesc" }
                                ]
                            },
                            {
                                "component": "Card",
                                "when": "selected($applicableTopics, 'childcare')",
                                "title": "Details on education services",
                                "children": [
                                    { "component": "Text", "text": "Describe all childcare, early childhood, youth development, and adult education services provided." },
                                    { "component": "TextInput", "bind": "descriptions.educationDesc" }
                                ]
                            },
                            {
                                "component": "Card",
                                "when": "selected($applicableTopics, 'assetBuilding')",
                                "title": "Details on income and asset building services",
                                "children": [
                                    { "component": "Text", "text": "Describe all income and asset building services provided." },
                                    { "component": "TextInput", "bind": "descriptions.incomeDesc" }
                                ]
                            },
                            {
                                "component": "Card",
                                "when": "selected($applicableTopics, 'housing')",
                                "title": "Details on housing services",
                                "children": [
                                    { "component": "Text", "text": "Describe all housing services provided." },
                                    { "component": "TextInput", "bind": "descriptions.housingDesc" }
                                ]
                            },
                            {
                                "component": "Card",
                                "when": "selected($applicableTopics, 'health')",
                                "title": "Details on health services",
                                "children": [
                                    { "component": "Text", "text": "Describe all health and nutrition services provided." },
                                    { "component": "TextInput", "bind": "descriptions.healthDesc" }
                                ]
                            },
                            {
                                "component": "Card",
                                "when": "selected($applicableTopics, 'civic')",
                                "title": "Details on civic engagement services",
                                "children": [
                                    { "component": "Text", "text": "Describe all civic engagement and community involvement services provided." },
                                    { "component": "TextInput", "bind": "descriptions.civicDesc" }
                                ]
                            },
                            {
                                "component": "Card",
                                "when": "selected($applicableTopics, 'transportation')",
                                "title": "Details on transportation services",
                                "children": [
                                    { "component": "Text", "text": "Describe all transportation services provided." },
                                    { "component": "TextInput", "bind": "descriptions.transportationDesc" }
                                ]
                            },
                            {
                                "component": "Card",
                                "when": "selected($applicableTopics, 'partnerships')",
                                "title": "Details on partnerships, linkages, and coordination",
                                "children": [
                                    { "component": "Text", "text": "Describe all partnerships, linkages, and coordination activities provided." },
                                    { "component": "TextInput", "bind": "descriptions.partnershipsDesc" }
                                ]
                            },
                            {
                                "component": "Card",
                                "when": "selected($applicableTopics, 'other')",
                                "title": "Details on other services",
                                "children": [
                                    { "component": "Text", "text": "Describe other services provided." },
                                    { "component": "TextInput", "bind": "descriptions.otherDesc" }
                                ]
                            }
                        ]
                    }
                ]
            },
            {
                "component": "Page",
                "title": "Demographic Information",
                "children": [
                    {
                        "component": "Card",
                        "title": "How many individuals did you serve?",
                        "children": [
                            { "component": "NumberInput", "bind": "demographics.totalServed", "min": 0, "step": 1 },
                            { "component": "NumberInput", "bind": "demographics.totalServedOver18", "min": 0, "step": 1 }
                        ]
                    },
                    {
                        "component": "Card",
                        "title": "Sex of individuals served (Age 18 and older)",
                        "children": [
                            { "component": "Heading", "text": "Sex of individuals served (Age 18 and older)", "level": 4 },
                            { "component": "NumberInput", "bind": "demographics.sexBreakdown.male", "min": 0, "step": 1 },
                            { "component": "NumberInput", "bind": "demographics.sexBreakdown.female", "min": 0, "step": 1 },
                            { "component": "Divider" },
                            { "component": "NumberInput", "bind": "demographics.sexBreakdown.sexTotal", "min": 0, "step": 1 }
                        ]
                    },
                    {
                        "component": "Card",
                        "title": "Work status of adults served (age 18 and older)",
                        "children": [
                            { "component": "Heading", "text": "Work status of adults served (age 18 and older)", "level": 4 },
                            { "component": "NumberInput", "bind": "demographics.employmentStatus.fullTime", "min": 0, "step": 1 },
                            { "component": "NumberInput", "bind": "demographics.employmentStatus.partTime", "min": 0, "step": 1 },
                            { "component": "NumberInput", "bind": "demographics.employmentStatus.migrantSeasonal", "min": 0, "step": 1 },
                            { "component": "NumberInput", "bind": "demographics.employmentStatus.unemployedShort", "min": 0, "step": 1 },
                            { "component": "NumberInput", "bind": "demographics.employmentStatus.unemployedLong", "min": 0, "step": 1 },
                            { "component": "NumberInput", "bind": "demographics.employmentStatus.notInLaborForce", "min": 0, "step": 1 },
                            { "component": "NumberInput", "bind": "demographics.employmentStatus.retired", "min": 0, "step": 1 },
                            { "component": "NumberInput", "bind": "demographics.employmentStatus.unknown", "min": 0, "step": 1 },
                            { "component": "Divider" },
                            { "component": "NumberInput", "bind": "demographics.employmentStatus.employmentTotal", "min": 0, "step": 1 }
                        ]
                    }
                ]
            }
            ,
            {
                "component": "Page",
                "title": "Review & Submit",
                "children": [
                    {
                        "component": "ValidationSummary",
                        "source": "live",
                        "mode": "submit",
                        "showFieldErrors": true,
                        "jumpLinks": true
                    },
                    {
                        "component": "SubmitButton",
                        "label": "Submit Report",
                        "mode": "submit",
                        "emitEvent": true,
                        "pendingLabel": "Submitting..."
                    }
                ]
            }
        ]
    }
}
