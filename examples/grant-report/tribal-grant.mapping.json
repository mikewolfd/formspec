{
    "version": "1.0.0",
    "definitionRef": "https://acf.hhs.gov/formspec/csbg/tribal-short",
    "definitionVersion": ">=3.0.0 <4.0.0",
    "direction": "forward",
    "targetSchema": {
        "format": "xml",
        "rootElement": "CSBGAnnualReport",
        "name": "HHS OLDC CSBG Tribal XML",
        "namespaces": {
            "": "http://acf.hhs.gov/schemas/csbg/2026"
        }
    },
    "rules": [
        {
            "sourcePath": "basicInfo.orgName",
            "targetPath": "OrganizationInfo.TribeName",
            "transform": "preserve",
            "priority": 100
        },
        {
            "sourcePath": "basicInfo.contactName",
            "targetPath": "OrganizationInfo.ContactName",
            "transform": "preserve",
            "priority": 100
        },
        {
            "sourcePath": "basicInfo.contactTitle",
            "targetPath": "OrganizationInfo.ContactTitle",
            "transform": "preserve",
            "priority": 100
        },
        {
            "sourcePath": "basicInfo.phone",
            "targetPath": "OrganizationInfo.PhoneNumber",
            "transform": "preserve",
            "priority": 100
        },
        {
            "sourcePath": "basicInfo.email",
            "targetPath": "OrganizationInfo.EmailAddress",
            "transform": "preserve",
            "priority": 100
        },
        {
            "sourcePath": "expenditures.employment",
            "targetPath": "Expenditures.Employment",
            "transform": "expression",
            "expression": "string(moneyAmount($))",
            "condition": "selected($expenditures.applicableTopics, 'employment')",
            "priority": 80
        },
        {
            "sourcePath": "expenditures.childcare",
            "targetPath": "Expenditures.Childcare",
            "transform": "expression",
            "expression": "string(moneyAmount($))",
            "condition": "selected($expenditures.applicableTopics, 'childcare')",
            "priority": 80
        },
        {
            "sourcePath": "expenditures.assetBuilding",
            "targetPath": "Expenditures.AssetBuilding",
            "transform": "expression",
            "expression": "string(moneyAmount($))",
            "condition": "selected($expenditures.applicableTopics, 'assetBuilding')",
            "priority": 80
        },
        {
            "sourcePath": "expenditures.housing",
            "targetPath": "Expenditures.Housing",
            "transform": "expression",
            "expression": "string(moneyAmount($))",
            "condition": "selected($expenditures.applicableTopics, 'housing')",
            "priority": 80
        },
        {
            "sourcePath": "expenditures.health",
            "targetPath": "Expenditures.Health",
            "transform": "expression",
            "expression": "string(moneyAmount($))",
            "condition": "selected($expenditures.applicableTopics, 'health')",
            "priority": 80
        },
        {
            "sourcePath": "expenditures.civic",
            "targetPath": "Expenditures.CivicEngagement",
            "transform": "expression",
            "expression": "string(moneyAmount($))",
            "condition": "selected($expenditures.applicableTopics, 'civic')",
            "priority": 80
        },
        {
            "sourcePath": "expenditures.transportation",
            "targetPath": "Expenditures.Transportation",
            "transform": "expression",
            "expression": "string(moneyAmount($))",
            "condition": "selected($expenditures.applicableTopics, 'transportation')",
            "priority": 80
        },
        {
            "sourcePath": "expenditures.partnerships",
            "targetPath": "Expenditures.Partnerships",
            "transform": "expression",
            "expression": "string(moneyAmount($))",
            "condition": "selected($expenditures.applicableTopics, 'partnerships')",
            "priority": 80
        },
        {
            "sourcePath": "expenditures.other",
            "targetPath": "Expenditures.Other",
            "transform": "expression",
            "expression": "string(moneyAmount($))",
            "condition": "selected($expenditures.applicableTopics, 'other')",
            "priority": 80
        },
        {
            "sourcePath": "expenditures.total",
            "targetPath": "Expenditures.Total",
            "transform": "expression",
            "expression": "string(moneyAmount($))",
            "priority": 90
        },
        {
            "sourcePath": "hasAdministrationCosts",
            "targetPath": "AdministrationCosts.HasAdmin",
            "transform": "valueMap",
            "valueMap": {
                "true": "Y",
                "false": "N"
            },
            "priority": 70
        },
        {
            "sourcePath": "administrationExpenditure",
            "targetPath": "AdministrationCosts.Amount",
            "transform": "expression",
            "expression": "string(moneyAmount($))",
            "condition": "$hasAdministrationCosts = true",
            "priority": 70
        }
    ]
}
