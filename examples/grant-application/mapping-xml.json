{
  "$schema": "https://formspec.org/schemas/mapping/1.0",
  "$formspecMapping": "1.0",
  "version": "1.0.0",
  "definitionRef": "https://example.gov/forms/grant-application",
  "definitionVersion": ">=1.0.0 <2.0.0",
  "direction": "forward",
  "conformanceLevel": "extended",
  "targetSchema": {
    "format": "xml",
    "name": "Grant Application XML Export",
    "url": "https://example.gov/schemas/grants-management/v1/grant-application.xsd",
    "rootElement": "GrantApplication",
    "namespaces": {
      "": "https://example.gov/ns/grants/application/v1",
      "xsi": "http://www.w3.org/2001/XMLSchema-instance"
    }
  },
  "adapters": {
    "xml": {
      "declaration": true,
      "indent": 2,
      "cdata": [
        "GrantApplication.Project.Abstract"
      ]
    }
  },
  "rules": [
    {
      "sourcePath": "applicantInfo.orgName",
      "targetPath": "GrantApplication.Applicant.OrganizationName",
      "transform": "preserve",
      "priority": 100
    },
    {
      "sourcePath": "applicantInfo.ein",
      "targetPath": "GrantApplication.Applicant.TaxId",
      "transform": "preserve",
      "priority": 95
    },
    {
      "sourcePath": "projectNarrative.projectTitle",
      "targetPath": "GrantApplication.Project.Title",
      "transform": "preserve",
      "priority": 90
    },
    {
      "sourcePath": "projectNarrative.abstract",
      "targetPath": "GrantApplication.Project.Abstract",
      "transform": "preserve",
      "priority": 85
    },
    {
      "sourcePath": "budget.requestedAmount.amount",
      "targetPath": "GrantApplication.Budget.RequestedAmount",
      "transform": "preserve",
      "priority": 80
    },
    {
      "sourcePath": "budget.requestedAmount.currency",
      "targetPath": "GrantApplication.Budget.RequestedAmount.@currency",
      "transform": "preserve",
      "priority": 75
    }
  ]
}
