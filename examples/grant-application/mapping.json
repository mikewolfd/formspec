{
  "$schema": "https://formspec.org/schemas/mapping/1.0",
  "$formspecMapping": "1.0",
  "version": "1.1.0",
  "definitionRef": "https://example.gov/forms/grant-application",
  "definitionVersion": ">=1.0.0 <2.0.0",
  "direction": "both",
  "conformanceLevel": "bidirectional",
  "targetSchema": {
    "format": "json",
    "name": "Grants Management System Payload",
    "url": "https://example.gov/schemas/grants-management/v1/payload.schema.json"
  },
  "defaults": {
    "meta.source": "formspec",
    "meta.profile": "grant-application",
    "submission.channel": "web"
  },
  "autoMap": true,
  "rules": [
    {
      "sourcePath": "applicantInfo.orgName",
      "targetPath": "organization.name",
      "transform": "preserve",
      "description": "Map legal organization name to external organization identity.",
      "priority": 120,
      "reversePriority": 110
    },
    {
      "sourcePath": "applicantInfo.ein",
      "targetPath": "organization.ein",
      "transform": "preserve",
      "description": "Carry EIN as-is for reconciliation with agency systems.",
      "priority": 118,
      "reversePriority": 108
    },
    {
      "sourcePath": "applicantInfo.orgType",
      "targetPath": "organization.type_code",
      "transform": "valueMap",
      "valueMap": {
        "forward": {
          "nonprofit": "NPO",
          "university": "EDU",
          "government": "GOV",
          "forprofit": "FP"
        },
        "reverse": {
          "NPO": "nonprofit",
          "EDU": "university",
          "GOV": "government",
          "FP": "forprofit"
        },
        "unmapped": "passthrough",
        "default": "unknown"
      },
      "reverse": {
        "transform": "valueMap",
        "valueMap": {
          "NPO": "nonprofit",
          "EDU": "university",
          "GOV": "government",
          "FP": "forprofit"
        }
      },
      "description": "Translate organization type codes bidirectionally between Formspec and external enum values.",
      "priority": 116,
      "reversePriority": 200
    },
    {
      "sourcePath": "applicantInfo.contactName",
      "targetPath": "organization.contact.name",
      "transform": "preserve",
      "priority": 110,
      "reversePriority": 100
    },
    {
      "sourcePath": "applicantInfo.contactEmail",
      "targetPath": "organization.contact.email",
      "transform": "preserve",
      "priority": 108,
      "reversePriority": 98
    },
    {
      "sourcePath": "applicantInfo.contactPhone",
      "targetPath": "organization.contact.phone",
      "transform": "preserve",
      "default": "not-provided",
      "description": "Fallback phone placeholder keeps payload shape stable for legacy import paths.",
      "priority": 106,
      "reversePriority": 96
    },
    {
      "targetPath": "organization.contact.display",
      "transform": "concat",
      "expression": "source.applicantInfo.contactName & ' <' & source.applicantInfo.contactEmail & '>'",
      "reverse": {
        "transform": "split",
        "expression": "$"
      },
      "description": "Build display contact line for human-readable review screens.",
      "priority": 104,
      "reversePriority": 130
    },
    {
      "sourcePath": "projectNarrative.projectTitle",
      "targetPath": "project.title",
      "transform": "preserve",
      "priority": 100,
      "reversePriority": 90
    },
    {
      "sourcePath": "projectNarrative.abstract",
      "targetPath": "project.abstract",
      "transform": "preserve",
      "default": "No abstract provided.",
      "priority": 98,
      "reversePriority": 88
    },
    {
      "sourcePath": "projectNarrative.projectTitle",
      "targetPath": "project.title_upper",
      "transform": "split",
      "expression": "upper($)",
      "description": "Split-transform example for derived title channel consumed by downstream ETL.",
      "priority": 96
    },
    {
      "sourcePath": "projectNarrative.startDate",
      "targetPath": "project.start_date",
      "transform": "coerce",
      "coerce": {
        "from": "string",
        "to": "date",
        "format": "YYYY-MM-DD"
      },
      "description": "Normalize start date using explicit object-form coercion.",
      "priority": 94,
      "reversePriority": 84
    },
    {
      "sourcePath": "projectNarrative.endDate",
      "targetPath": "project.end_date",
      "transform": "preserve",
      "priority": 92,
      "reversePriority": 82
    },
    {
      "sourcePath": "projectNarrative.startDate",
      "targetPath": "project.start_date_tree",
      "transform": "nest",
      "separator": "-",
      "description": "Exercise nest transform by expanding YYYY-MM-DD into nested path nodes.",
      "priority": 90
    },
    {
      "sourcePath": "projectNarrative.focusAreas",
      "targetPath": "project.focus_areas_csv",
      "transform": "flatten",
      "separator": "|",
      "reverse": {
        "transform": "nest",
        "separator": "|"
      },
      "description": "Flatten multiselect focus areas for a pipe-delimited downstream import field.",
      "priority": 88,
      "reversePriority": 78
    },
    {
      "targetPath": "meta.mappingVersion",
      "transform": "constant",
      "expression": "'2026.02'",
      "bidirectional": false,
      "description": "Emit static mapping bundle version for external audit logs.",
      "priority": 86
    },
    {
      "sourcePath": "projectNarrative.duration",
      "targetPath": "project.duration_months",
      "transform": "coerce",
      "coerce": "number",
      "priority": 84,
      "reversePriority": 74
    },
    {
      "sourcePath": "projectNarrative.indirectRate",
      "targetPath": "budget.indirect_rate_pct",
      "transform": "expression",
      "expression": "string(source.projectNarrative.indirectRate) & '%'",
      "reverse": {
        "transform": "expression",
        "expression": "$"
      },
      "priority": 82,
      "reversePriority": 72
    },
    {
      "sourcePath": "budget.requestedAmount.amount",
      "targetPath": "budget.requested_amount",
      "transform": "expression",
      "expression": "$",
      "reverse": {
        "transform": "expression",
        "expression": "$"
      },
      "description": "Extract money amount into scalar amount field while preserving reverse path.",
      "priority": 80,
      "reversePriority": 210
    },
    {
      "sourcePath": "budget.requestedAmount.currency",
      "targetPath": "budget.currency",
      "transform": "expression",
      "expression": "$",
      "priority": 78,
      "reversePriority": 70
    },
    {
      "sourcePath": "budget.lineItems",
      "targetPath": "budget.line_items",
      "transform": "preserve",
      "array": {
        "mode": "each",
        "innerRules": [
          {
            "sourcePath": "category",
            "targetPath": "cat",
            "transform": "preserve",
            "priority": 30
          },
          {
            "sourcePath": "description",
            "targetPath": "desc",
            "transform": "preserve",
            "priority": 28
          },
          {
            "sourcePath": "quantity",
            "targetPath": "qty",
            "transform": "coerce",
            "coerce": "number",
            "condition": "source.quantity > 0",
            "priority": 26
          },
          {
            "sourcePath": "unitCost",
            "targetPath": "unit_cost",
            "transform": "preserve",
            "priority": 24
          },
          {
            "sourcePath": "subtotal",
            "targetPath": "line_total",
            "transform": "preserve",
            "priority": 22
          }
        ]
      },
      "description": "Map each line item with inner rule priorities and condition guards.",
      "priority": 76,
      "reversePriority": 68
    },
    {
      "sourcePath": "projectPhases",
      "targetPath": "project.phase_slots",
      "transform": "preserve",
      "array": {
        "mode": "indexed",
        "innerRules": [
          {
            "index": 0,
            "sourcePath": "phaseName",
            "targetPath": "firstPhase",
            "transform": "preserve",
            "condition": "source != null",
            "priority": 20
          },
          {
            "index": 1,
            "sourcePath": "phaseName",
            "targetPath": "secondPhase",
            "transform": "preserve",
            "priority": 10
          }
        ]
      },
      "description": "Capture first two phase entries using indexed array mode.",
      "priority": 74,
      "reversePriority": 66
    },
    {
      "sourcePath": "subcontractors",
      "targetPath": "subcontractors",
      "transform": "preserve",
      "array": {
        "mode": "whole",
        "separator": ";"
      },
      "condition": "source.budget.usesSubcontractors = true",
      "priority": 72,
      "reversePriority": 64
    },
    {
      "sourcePath": "attachments",
      "targetPath": null,
      "transform": "drop",
      "bidirectional": false,
      "description": "Drop attachment metadata from outbound payload for privacy minimization.",
      "priority": 70
    }
  ]
}
