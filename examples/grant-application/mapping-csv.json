{
  "$schema": "https://formspec.org/schemas/mapping/1.0",
  "$formspecMapping": "1.0",
  "version": "1.0.0",
  "definitionRef": "https://example.gov/forms/grant-application",
  "definitionVersion": ">=1.0.0 <2.0.0",
  "direction": "forward",
  "conformanceLevel": "extended",
  "targetSchema": {
    "format": "csv",
    "name": "Grant Application CSV Export",
    "url": "https://example.gov/schemas/grants-management/v1/grant-application.csv-schema.json"
  },
  "adapters": {
    "csv": {
      "delimiter": ",",
      "quote": "\"",
      "header": true,
      "encoding": "utf-8",
      "lineEnding": "lf"
    }
  },
  "rules": [
    {
      "sourcePath": "applicantInfo.orgName",
      "targetPath": "org_name",
      "transform": "preserve",
      "priority": 100
    },
    {
      "sourcePath": "applicantInfo.ein",
      "targetPath": "org_ein",
      "transform": "preserve",
      "priority": 95
    },
    {
      "sourcePath": "projectNarrative.projectTitle",
      "targetPath": "project_title",
      "transform": "preserve",
      "priority": 90
    },
    {
      "sourcePath": "projectNarrative.startDate",
      "targetPath": "project_start_date",
      "transform": "coerce",
      "coerce": {
        "from": "string",
        "to": "date",
        "format": "YYYY-MM-DD"
      },
      "priority": 85
    },
    {
      "sourcePath": "projectNarrative.focusAreas",
      "targetPath": "focus_areas",
      "transform": "flatten",
      "separator": "|",
      "priority": 80
    },
    {
      "sourcePath": "projectPhases",
      "targetPath": "project_phases",
      "transform": "flatten",
      "separator": "; ",
      "priority": 75
    }
  ]
}
