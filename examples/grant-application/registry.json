{
  "$formspecRegistry": "1.0",
  "$schema": "https://formspec.org/schemas/registry/v1.0/registry.json",
  "publisher": {
    "name": "US Grants Modernization Office",
    "url": "https://grants.example.gov",
    "contact": "formspec-extensions@grants.example.gov"
  },
  "published": "2026-02-28T00:00:00Z",
  "entries": [
    {
      "name": "x-grants-gov-ssn",
      "category": "dataType",
      "version": "1.0.0",
      "status": "stable",
      "description": "Social Security Number with canonical ###-##-#### formatting.",
      "specUrl": "https://grants.example.gov/extensions/x-grants-gov-ssn/spec",
      "schemaUrl": "https://grants.example.gov/extensions/x-grants-gov-ssn/schema.json",
      "compatibility": {
        "formspecVersion": ">=1.0.0 <2.0.0",
        "mappingDslVersion": ">=1.0.0 <2.0.0"
      },
      "license": "Apache-2.0",
      "baseType": "string",
      "constraints": {
        "pattern": "^[0-9]{3}-[0-9]{2}-[0-9]{4}$"
      },
      "metadata": {
        "mask": "###-##-####",
        "displayName": "US SSN"
      },
      "examples": [
        {
          "type": "string",
          "key": "applicantInfo.ssn",
          "extensions": {
            "x-grants-gov-ssn": true
          }
        }
      ],
      "extensions": {
        "x-grants-gov-owner": "identity-team"
      }
    },
    {
      "name": "x-grants-gov-fiscal-year",
      "category": "function",
      "version": "0.9.0",
      "status": "draft",
      "description": "Returns the US federal fiscal year for an ISO date.",
      "compatibility": {
        "formspecVersion": ">=1.0.0 <2.0.0",
        "mappingDslVersion": ">=1.0.0 <2.0.0"
      },
      "parameters": [
        {
          "name": "date",
          "type": "date",
          "description": "Calendar date to classify."
        }
      ],
      "returns": "integer",
      "examples": [
        "@x-grants-gov-fiscal-year(/projectNarrative/projectStartDate)"
      ],
      "extensions": {
        "x-grants-gov-owner": "fel-runtime"
      }
    },
    {
      "name": "x-grants-gov-duns-valid",
      "category": "constraint",
      "version": "1.2.0",
      "status": "deprecated",
      "description": "DUNS checksum validator retained for legacy integrations.",
      "compatibility": {
        "formspecVersion": ">=1.0.0 <2.0.0",
        "mappingDslVersion": ">=1.0.0 <2.0.0"
      },
      "parameters": [
        {
          "name": "value",
          "type": "string",
          "description": "DUNS candidate value."
        }
      ],
      "deprecationNotice": "Use x-grants-gov-uei-valid after SAM migration.",
      "extensions": {
        "x-grants-gov-owner": "validation"
      }
    },
    {
      "name": "x-grants-gov-agency-code",
      "category": "property",
      "version": "1.0.0",
      "status": "retired",
      "description": "Legacy agency code property replaced by agency profile refs.",
      "compatibility": {
        "formspecVersion": ">=1.0.0 <2.0.0",
        "mappingDslVersion": ">=1.0.0 <2.0.0"
      },
      "extensions": {
        "x-grants-gov-retiredOn": "2025-12-31"
      }
    },
    {
      "name": "x-grants-gov",
      "category": "namespace",
      "version": "2.0.0",
      "status": "stable",
      "description": "Namespace for US federal grants extension set.",
      "compatibility": {
        "formspecVersion": ">=1.0.0 <2.0.0",
        "mappingDslVersion": ">=1.0.0 <2.0.0"
      },
      "members": [
        "x-grants-gov-ssn",
        "x-grants-gov-fiscal-year",
        "x-grants-gov-duns-valid",
        "x-grants-gov-agency-code"
      ],
      "examples": [
        {
          "registry": "x-grants-gov",
          "use": "grant-application"
        }
      ],
      "extensions": {
        "x-grants-gov-owner": "platform-architecture"
      }
    }
  ],
  "extensions": {
    "x-grants-gov-registryVersionNote": "Phase 3 parity fixture",
    "x-grants-gov-approval": {
      "board": "Schema Council",
      "ticket": "FSM-2031"
    }
  }
}
