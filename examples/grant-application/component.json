{
  "$formspecComponent": "1.0",
  "version": "1.0.0",
  "name": "grant-application-component",
  "title": "Grant Application Layout",
  "targetDefinition": {
    "url": "https://example.gov/forms/grant-application",
    "compatibleVersions": ">=1.0.0 <2.0.0"
  },
  "breakpoints": {
    "sm": 576,
    "md": 768,
    "lg": 1024
  },
  "tokens": {
    "space.lg": "32px",
    "color.accent": "#2e7d32",
    "border.card": "1px solid #dfe1e2"
  },
  "components": {
    "ContactField": {
      "params": ["field"],
      "tree": {
        "component": "Stack",
        "gap": "$token.space.sm",
        "children": [
          { "component": "TextInput", "bind": "{field}" }
        ]
      }
    },
    "SummaryRow": {
      "params": ["label", "field"],
      "tree": {
        "component": "Columns",
        "widths": ["1fr", "2fr"],
        "gap": "$token.space.md",
        "children": [
          { "component": "Text", "text": "{label}", "style": { "fontWeight": "bold" } },
          { "component": "Text", "bind": "{field}" }
        ]
      }
    }
  },
  "tree": {
    "component": "Wizard",
    "showProgress": true,
    "allowSkip": false,
    "children": [
      {
        "component": "Page",
        "title": "Applicant Info",
        "children": [
          {
            "component": "Columns",
            "widths": ["2fr", "1fr"],
            "children": [
              {
                "component": "Stack",
                "gap": "$token.space.lg",
                "children": [
                  {
                    "component": "Grid",
                    "columns": 2,
                    "responsive": { "sm": { "columns": 1 } },
                    "children": [
                      { "component": "TextInput", "bind": "applicantInfo.orgName", "placeholder": "Acme Nonprofit, Inc." },
                      { "component": "TextInput", "bind": "applicantInfo.ein", "placeholder": "12-3456789" }
                    ]
                  },
                  { "component": "RadioGroup", "bind": "applicantInfo.orgType", "orientation": "horizontal", "columns": 2 },
                  {
                    "component": "ConditionalGroup",
                    "when": "$applicantInfo.orgType != null",
                    "children": [
                      { "component": "TextInput", "bind": "applicantInfo.orgType.orgSubType", "placeholder": "e.g. 501(c)(3)" }
                    ]
                  },
                  { "component": "Divider" },
                  { "component": "Heading", "level": 3, "text": "Contact Details" },
                  {
                    "component": "Grid",
                    "columns": 3,
                    "responsive": { "sm": { "columns": 1 }, "md": { "columns": 2 } },
                    "children": [
                      { "component": "ContactField", "params": { "field": "applicantInfo.contactName" } },
                      { "component": "ContactField", "params": { "field": "applicantInfo.contactEmail" } },
                      { "component": "ContactField", "params": { "field": "applicantInfo.contactPhone" } }
                    ]
                  },
                  {
                    "component": "Text",
                    "text": "**Nonprofit organizations** must provide a primary phone number for federal reporting requirements.",
                    "format": "markdown",
                    "when": "$applicantInfo.orgType = 'nonprofit'"
                  }
                ]
              },
              {
                "component": "Panel",
                "position": "right",
                "title": "Applicant Help",
                "width": "280px",
                "children": [
                  { "component": "Alert", "severity": "info", "text": "EIN must be in XX-XXXXXXX format (e.g. 12-3456789)." },
                  { "component": "Heading", "level": 4, "text": "Organization Types" },
                  { "component": "Text", "text": "Nonprofit — 501(c)(3) or similar" },
                  { "component": "Text", "text": "University — accredited research institutions" },
                  { "component": "Text", "text": "Government — state or local agencies" },
                  { "component": "Text", "text": "For-Profit — commercial entities" }
                ]
              }
            ]
          }
        ]
      },
      {
        "component": "Page",
        "title": "Project Narrative",
        "children": [
          {
            "component": "Stack",
            "gap": "$token.space.lg",
            "children": [
              { "component": "TextInput", "bind": "projectNarrative.projectTitle", "placeholder": "Community Health Outreach Initiative" },
              { "component": "TextInput", "bind": "projectNarrative.abstract", "maxLines": 8 },
              { "component": "Badge", "text": "Draft", "variant": "warning", "when": "empty($projectNarrative.abstract)" },
              { "component": "Rating", "bind": "projectNarrative.selfAssessment", "max": 5 },
              {
                "component": "Tabs",
                "tabLabels": ["Schedule", "Rates & Areas"],
                "children": [
                  {
                    "component": "Stack",
                    "gap": "$token.space.md",
                    "children": [
                      {
                        "component": "Grid",
                        "columns": 2,
                        "children": [
                          { "component": "DatePicker", "bind": "projectNarrative.startDate", "format": "MM/DD/YYYY" },
                          { "component": "DatePicker", "bind": "projectNarrative.endDate" },
                          { "component": "NumberInput", "bind": "projectNarrative.duration" },
                          { "component": "Spacer", "size": "$token.space.lg" }
                        ]
                      }
                    ]
                  },
                  {
                    "component": "Stack",
                    "gap": "$token.space.md",
                    "children": [
                      {
                        "component": "Slider",
                        "bind": "projectNarrative.indirectRate",
                        "min": 0,
                        "max": 60,
                        "step": 0.5,
                        "showValue": true,
                        "showTicks": true,
                        "when": "$applicantInfo.orgType != 'government'"
                      },
                      { "component": "CheckboxGroup", "bind": "projectNarrative.focusAreas", "columns": 2, "selectAll": true }
                    ]
                  }
                ]
              },
              { "component": "ProgressBar", "value": 3, "max": 6, "label": "Narrative completion", "showPercent": true }
            ]
          }
        ]
      },
      {
        "component": "Page",
        "title": "Budget",
        "children": [
          {
            "component": "Stack",
            "gap": "$token.space.lg",
            "children": [
              { "component": "Text", "text": "Add one row per budget line item. Subtotals are calculated automatically." },
              {
                "component": "DataTable",
                "bind": "budget.lineItems",
                "allowAdd": true,
                "allowRemove": true,
                "showRowNumbers": true,
                "columns": [
                  { "header": "Category", "bind": "category" },
                  { "header": "Description", "bind": "description" },
                  { "header": "Qty", "bind": "quantity" },
                  { "header": "Unit Cost", "bind": "unitCost" },
                  { "header": "Subtotal", "bind": "subtotal" }
                ]
              },
              {
                "component": "Card",
                "title": "Budget Summary",
                "elevation": 1,
                "children": [
                  {
                    "component": "Summary",
                    "items": [
                      { "label": "Total Direct Costs", "bind": "totalDirect" },
                      { "label": "Indirect Costs", "bind": "indirectCosts" },
                      { "label": "Grand Total", "bind": "grandTotal" }
                    ]
                  }
                ]
              },
              {
                "component": "Grid",
                "columns": 2,
                "children": [
                  { "component": "MoneyInput", "bind": "budget.requestedAmount", "currency": "USD", "showCurrency": true },
                  { "component": "Spacer" }
                ]
              },
              { "component": "Toggle", "bind": "budget.usesSubcontractors", "onLabel": "Yes", "offLabel": "No" },
              {
                "component": "Popover",
                "triggerLabel": "Budget Guidelines",
                "placement": "bottom",
                "children": [
                  {
                    "component": "Text",
                    "format": "markdown",
                    "text": "**Budget Rules:**\n- Each line item must have a category and description\n- Subtotals are calculated as Qty × Unit Cost\n- Indirect costs apply to non-government organizations\n- Requested amount must match the grand total"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "component": "Page",
        "title": "Project Phases",
        "children": [
          {
            "component": "Stack",
            "gap": "$token.space.lg",
            "children": [
              { "component": "Text", "text": "Define project phases and their tasks. Costs are calculated automatically." },
              {
                "component": "Accordion",
                "bind": "projectPhases",
                "allowMultiple": true,
                "defaultOpen": 0,
                "labels": ["Phase Details"],
                "children": [
                  {
                    "component": "Card",
                    "title": "Phase",
                    "children": [
                      { "component": "TextInput", "bind": "phaseName", "placeholder": "e.g. Design Phase" },
                      {
                        "component": "DataTable",
                        "bind": "phaseTasks",
                        "allowAdd": true,
                        "allowRemove": true,
                        "columns": [
                          { "header": "Task Name", "bind": "taskName" },
                          { "header": "Hours", "bind": "hours" },
                          { "header": "Hourly Rate", "bind": "hourlyRate" },
                          { "header": "Task Cost", "bind": "taskCost" }
                        ]
                      },
                      {
                        "component": "Grid",
                        "columns": 2,
                        "children": [
                          { "component": "Text", "text": "Phase Total", "style": { "fontWeight": "bold" } },
                          { "component": "Text", "bind": "phaseTotal", "style": { "textAlign": "right", "fontWeight": "bold" } }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "component": "Card",
                "title": "Phases Summary",
                "children": [
                  {
                    "component": "Grid",
                    "columns": 2,
                    "children": [
                      { "component": "Text", "text": "Total Phases Cost" },
                      { "component": "Text", "bind": "projectPhasesTotal", "style": { "textAlign": "right", "fontWeight": "bold" } }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "component": "Page",
        "title": "Subcontractors",
        "children": [
          {
            "component": "ConditionalGroup",
            "when": "$budget.usesSubcontractors",
            "fallback": "No subcontractors are needed for this project.",
            "children": [
              {
                "component": "Stack",
                "gap": "$token.space.lg",
                "children": [
                  { "component": "Alert", "severity": "info", "text": "List all subcontractors. Total costs may not exceed 49% of the project budget.", "dismissible": true },
                  {
                    "component": "DataTable",
                    "bind": "subcontractors",
                    "allowAdd": true,
                    "allowRemove": true,
                    "columns": [
                      { "header": "Contact Name", "bind": "subName" },
                      { "header": "Organization", "bind": "subOrg" },
                      { "header": "Amount", "bind": "subAmount" },
                      { "header": "Scope of Work", "bind": "subScope" }
                    ]
                  },
                  {
                    "component": "Modal",
                    "title": "Subcontractor Certification Requirements",
                    "trigger": "button",
                    "triggerLabel": "View Certification Requirements",
                    "size": "md",
                    "closable": true,
                    "children": [
                      {
                        "component": "Text",
                        "format": "markdown",
                        "text": "**Federal Subcontractor Requirements:**\n\n1. All subcontractors must be registered in SAM.gov\n2. Subcontractor costs may not exceed 49% of total project budget\n3. Each subcontractor must provide a detailed scope of work\n4. Subcontracts over $25,000 require prior agency approval"
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "component": "Page",
        "title": "Review & Submit",
        "children": [
          {
            "component": "Stack",
            "gap": "$token.space.lg",
            "accessibility": {
              "role": "region",
              "description": "Application review and submission"
            },
            "children": [
              {
                "component": "Alert",
                "severity": "info",
                "text": "Review all information below before submitting. Use Previous to go back and make corrections."
              },
              {
                "component": "Collapsible",
                "title": "Applicant Information",
                "defaultOpen": true,
                "children": [
                  {
                    "component": "Summary",
                    "items": [
                      { "label": "Organization Name", "bind": "applicantInfo.orgName" },
                      { "label": "EIN", "bind": "applicantInfo.ein" },
                      { "label": "Organization Type", "bind": "applicantInfo.orgType", "optionSet": "orgTypes" },
                      { "label": "Sub-Type", "bind": "applicantInfo.orgType.orgSubType" },
                      { "label": "Contact Name", "bind": "applicantInfo.contactName" },
                      { "label": "Contact Email", "bind": "applicantInfo.contactEmail" },
                      { "label": "Contact Phone", "bind": "applicantInfo.contactPhone" }
                    ]
                  }
                ]
              },
              {
                "component": "Collapsible",
                "title": "Project Narrative",
                "defaultOpen": true,
                "children": [
                  {
                    "component": "Summary",
                    "items": [
                      { "label": "Project Title", "bind": "projectNarrative.projectTitle" },
                      { "label": "Start Date", "bind": "projectNarrative.startDate" },
                      { "label": "End Date", "bind": "projectNarrative.endDate" },
                      { "label": "Duration", "bind": "projectNarrative.duration" },
                      { "label": "Indirect Rate", "bind": "projectNarrative.indirectRate" },
                      { "label": "Focus Areas", "bind": "projectNarrative.focusAreas" },
                      { "label": "Confidence", "bind": "projectNarrative.selfAssessment" }
                    ]
                  }
                ]
              },
              {
                "component": "Collapsible",
                "title": "Budget",
                "defaultOpen": true,
                "children": [
                  {
                    "component": "Summary",
                    "items": [
                      { "label": "Total Direct Costs", "bind": "totalDirect" },
                      { "label": "Indirect Costs", "bind": "indirectCosts" },
                      { "label": "Grand Total", "bind": "grandTotal" },
                      { "label": "Requested Amount", "bind": "budget.requestedAmount" }
                    ]
                  }
                ]
              },
              {
                "component": "Collapsible",
                "title": "Project Phases",
                "defaultOpen": false,
                "children": [
                  {
                    "component": "Summary",
                    "items": [
                      { "label": "Total Phases Cost", "bind": "projectPhasesTotal" }
                    ]
                  }
                ]
              },
              { "component": "Divider", "label": "Supporting Documents" },
              {
                "component": "Stack",
                "gap": "$token.space.md",
                "children": [
                  {
                    "component": "FileUpload",
                    "bind": "attachments.narrativeDoc",
                    "accept": "application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document",
                    "maxSize": 10485760,
                    "dragDrop": true
                  },
                  {
                    "component": "FileUpload",
                    "bind": "attachments.budgetJustification",
                    "accept": "application/pdf,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                    "maxSize": 5242880,
                    "dragDrop": true
                  },
                  {
                    "component": "Signature",
                    "bind": "attachments.approverSignature",
                    "strokeColor": "#000000",
                    "height": 200,
                    "penWidth": 2,
                    "clearable": true
                  }
                ]
              },
              {
                "component": "Alert",
                "severity": "warning",
                "text": "Please ensure all required fields are completed before submitting your application.",
                "cssClass": "review-alert"
              }
            ]
          }
        ]
      }
    ]
  }
}
