{
  "$formspecTheme": "1.0",
  "version": "1.0.0",
  "name": "invoice-theme",
  "title": "Invoice Theme",
  "platform": "web",
  "targetDefinition": {
    "url": "https://formspec.org/examples/invoice",
    "compatibleVersions": ">=1.0.0 <2.0.0"
  },
  "tokens": {
    "color.primary": "#0f172a",
    "color.primaryDark": "#020617",
    "color.primaryLight": "#e2e8f0",
    "color.success": "#15803d",
    "color.warning": "#b45309",
    "color.error": "#b91c1c",
    "color.neutral50": "#f8fafc",
    "color.neutral100": "#f1f5f9",
    "color.neutral200": "#e2e8f0",
    "color.neutral700": "#334155",
    "color.text": "#0f172a",
    "space.sm": "8px",
    "space.md": "16px",
    "space.lg": "24px",
    "radius.sm": "6px",
    "radius.md": "10px",
    "type.fontFamily": "ui-sans-serif, system-ui, -apple-system, 'Segoe UI', sans-serif",
    "type.baseSize": "16px"
  },
  "defaults": {
    "labelPosition": "top"
  }
}
